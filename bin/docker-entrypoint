#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  # Apply staff roles from JACKPOT_*_EMAILS (Coolify / container env) on each deploy
  ./bin/rails jackpot:sync_roles_from_env
fi

exec "${@}"
