<% content_for :title, "Jackpot Hackathon - Info & Signup" %>

<% signup_pct = @signup_goal.positive? ? [(@signup_count.to_f / @signup_goal * 100).round(1), 100.0].min : 0 %>
<% back_href = user_signed_in? ? deck_path : root_path %>

<div class="faq-page">
  <div class="faq-floating-icons" aria-hidden="true">
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--1", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--2", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--3", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--4", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--5", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--6", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--7", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--8", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--9", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--10", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--11", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--12", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--13", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--14", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--15", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--16", alt: "" %>
  </div>
  <div class="faq-content">
    <%= link_to back_href, class: "faq-back-btn" do %>
      <%= image_tag "back_button.png", alt: "Back", class: "faq-back-btn-img" %>
    <% end %>

    <div class="hackathon-faq-title-row">
      <h1 class="hackathon-faq-main-title">Jackpot Hackathon - Info & Signup</h1>
      <%= image_tag "bunny_handwritten.png", alt: "", class: "hackathon-faq-bunny", loading: "lazy", aria: { hidden: true } %>
    </div>

    <p class="faq-disclaimer hackathon-faq-intro">
      A free, beginner-friendly weekend coding event. Build your own project and compete for tech prizes.
    </p>

    <div class="hackathon-guide-cta">
      <%= link_to "https://docs.google.com/document/d/1xQYY-eUh6fdCRqfcFcuZXOtApnHPA4k2EeMdn6KWZs8/edit?usp=sharing",
          target: "_blank",
          rel: "noopener noreferrer",
          class: "hackathon-guide-cta__link",
          aria: { label: "Full Hackathon Guide (opens Google Doc)" } do %>
        <%= image_tag "buttons/guideButton.png", alt: "", class: "hackathon-guide-cta__img", loading: "lazy" %>
      <% end %>
    </div>

    <section class="faq-section">
      <h2 class="faq-section-heading">— Before starting</h2>

      <div class="hackathon-signup-counter-bare" role="region" aria-label="<%= "Hackathon signups: #{@signup_count}" %>">
        <div class="hackathon-signup-progress hackathon-signup-progress--vegas">
          <div class="hackathon-signup-progress-head">
            <span class="hackathon-signup-label">Signups</span>
          </div>
          <div class="hackathon-progress-track hackathon-progress-track--vegas">
            <div class="hackathon-progress-fill hackathon-progress-fill--vegas" style="width: <%= signup_pct %>%"></div>
            <span class="hackathon-signup-count hackathon-signup-count--on-bar"><%= @signup_count %></span>
          </div>
          <% if @signup_count < @signup_goal %>
            <p class="hackathon-deadline-line hackathon-deadline-line--vegas">We need <%= @signup_goal - @signup_count %> more by April 10th to confirm the event.</p>
          <% end %>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="faq-section-heading">— Location</h2>
      <div class="faq-static-block hackathon-location-split">
        <div class="hackathon-location-split__text">
          <ul class="faq-list hackathon-faq-list--tight">
            <li><%= link_to "UNLV", "https://www.unlv.edu/", target: "_blank", rel: "noopener noreferrer", class: "faq-link" %> — Las Vegas Downtown</li>
            <li>May 9–10</li>
            <li>9am–7pm both days (no overnight)</li>
          </ul>
        </div>
        <div class="hackathon-location-split__logo">
          <%= image_tag "UNLV_logo.png", alt: "UNLV", class: "hackathon-unlv-logo" %>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="faq-section-heading">— General info</h2>
      <div class="faq-static-block hackathon-general-info-split">
        <div class="hackathon-general-info-split__text">
          <ul class="faq-list hackathon-faq-list--tight">
            <li>No hours required</li>
            <li>Free merch at the event (hoodies, shirts, stickers…)</li>
            <li>Build whatever you want</li>
            <li>Tech prizes for the final podium</li>
            <li>Included meals and snacks</li>
            <li>We will give you <strong>$20</strong> for each friend you invite who attends both days</li>
          </ul>
        </div>
        <div class="hackathon-general-info-split__visual">
          <%= image_tag "vegas.png", alt: "Welcome to Fabulous Hack Club Nevada", class: "hackathon-vegas-img" %>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="faq-section-heading">— Hack Club</h2>
      <div class="faq-static-block">
        <p class="faq-a">
          <%= link_to "Hack Club", "https://hackclub.com/", target: "_blank", rel: "noopener noreferrer", class: "faq-link" %>, a nonprofit and the world’s largest open-source community of teenagers passionate about coding and building technology. In this specific event:
        </p>
        <ul class="faq-list hackathon-faq-list--tight hackathon-hc-event-list">
          <li>
            Flight and hotel are not included, but you can request financial support in the
            <%= link_to "Jackpot Shop", shop_path, class: "faq-link" %>
            (you are 100% responsible for booking and managing travel; we only reimburse approved requests).
          </li>
          <li>Hack Club does not cover personal health insurance.</li>
          <li>If you request a travel or hotel stipend from Jackpot, you must participate on both days of the event—otherwise your reimbursement will not be issued.</li>
        </ul>
      </div>
    </section>

    <section class="faq-section faq-section--cta">
      <p class="hackathon-signup-disclaimer">
        Please fill out the signup form only if you are genuinely interested and at least 80% sure you can attend.
      </p>
      <%= link_to "https://forms.hackclub.com/t/dLwpqJseLMus",
          target: "_blank",
          rel: "noopener noreferrer",
          class: "hackathon-faq-signup hackathon-faq-signup--asset",
          aria: { label: "Sign up for the Jackpot Hackathon" } do %>
        <%= image_tag "buttons/signup_hack.png", alt: "", class: "hackathon-faq-signup-img" %>
      <% end %>
    </section>

    <section class="faq-section hackathon-section--questions">
      <h2 class="faq-section-heading">— Questions? We got you!</h2>
      <div class="hackathon-questions">
        <p class="hackathon-questions__lead">Write us here—our team will reply right away.</p>
        <p class="hackathon-questions__line">
          Email:
          <%= link_to "emmaborghi@hackclub.com", "mailto:emmaborghi@hackclub.com", class: "faq-link" %>
        </p>
        <p class="hackathon-questions__line">
          Slack:
          <%= link_to "@Emma", "https://hackclub.enterprise.slack.com/team/U078DFX40A2", target: "_blank", rel: "noopener noreferrer", class: "faq-link" %>
        </p>
      </div>
    </section>
  </div>
</div>

<style>
@font-face {
  font-family: "Katibeh";
  src: url(<%= asset_path "Katibeh/Katibeh-Regular.ttf" %>) format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

.faq-page {
  min-height: 100vh;
  color: #fff;
  padding: 2rem 2rem 4rem;
  max-width: 920px;
  margin: 0 auto;
  font-family: "Katibeh", serif;
  position: relative;
}

.faq-page::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  background: #000 url('<%= image_path("faq_bkg.jpg") %>') center center no-repeat;
  background-size: cover;
}

.faq-floating-icons {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.faq-icon {
  position: absolute;
  object-fit: contain;
  opacity: 0.5;
}

.faq-icon--1 { left: 3%;   top: 8%;   width: 56px;  animation: faq-float-1 42s ease-in-out infinite; animation-delay: 0s; }
.faq-icon--2 { left: 90%; top: 14%; width: 72px;  animation: faq-float-2 46s ease-in-out infinite; animation-delay: -4s; }
.faq-icon--3 { left: 12%; top: 48%; width: 44px;  animation: faq-float-3 38s ease-in-out infinite; animation-delay: -8s; }
.faq-icon--4 { left: 85%; top: 58%; width: 64px;  animation: faq-float-4 48s ease-in-out infinite; animation-delay: -12s; }
.faq-icon--5 { left: 92%; top: 32%; width: 40px;  animation: faq-float-5 40s ease-in-out infinite; animation-delay: -2s; }
.faq-icon--6 { left: 2%;  top: 75%; width: 68px;  animation: faq-float-6 52s ease-in-out infinite; animation-delay: -6s; }
.faq-icon--7 { left: 75%; top: 4%;  width: 48px;  animation: faq-float-7 44s ease-in-out infinite; animation-delay: -10s; }
.faq-icon--8 { left: 38%; top: 18%; width: 52px;  animation: faq-float-8 46s ease-in-out infinite; animation-delay: -15s; }
.faq-icon--9 { left: 22%; top: 68%; width: 60px;  animation: faq-float-9 50s ease-in-out infinite; animation-delay: -3s; }
.faq-icon--10 { left: 58%; top: 88%; width: 46px; animation: faq-float-10 42s ease-in-out infinite; animation-delay: -7s; }
.faq-icon--11 { left: 6%;  top: 32%; width: 50px;  animation: faq-float-11 45s ease-in-out infinite; animation-delay: -5s; }
.faq-icon--12 { left: 94%; top: 72%; width: 58px;  animation: faq-float-12 40s ease-in-out infinite; animation-delay: -11s; }
.faq-icon--13 { left: 48%; top: 6%;  width: 42px;  animation: faq-float-13 48s ease-in-out infinite; animation-delay: -9s; }
.faq-icon--14 { left: 65%; top: 42%; width: 66px;  animation: faq-float-14 44s ease-in-out infinite; animation-delay: -1s; }
.faq-icon--15 { left: 30%; top: 92%; width: 54px;  animation: faq-float-15 46s ease-in-out infinite; animation-delay: -13s; }
.faq-icon--16 { left: 82%; top: 82%; width: 48px;  animation: faq-float-16 38s ease-in-out infinite; animation-delay: -14s; }

@media (prefers-reduced-motion: reduce) {
  .faq-icon { animation: none; }
}

@keyframes faq-float-1 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(45px, -50px) rotate(12deg); }
  50% { transform: translate(-35px, 40px) rotate(-10deg); }
  75% { transform: translate(55px, 30px) rotate(8deg); }
}
@keyframes faq-float-2 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(-55px, 45px) rotate(-14deg); }
  66% { transform: translate(40px, -65px) rotate(12deg); }
}
@keyframes faq-float-3 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(70px, 55px) rotate(18deg); }
}
@keyframes faq-float-4 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(-45px, -35px) rotate(-12deg); }
  50% { transform: translate(25px, 60px) rotate(8deg); }
  75% { transform: translate(-55px, 20px) rotate(5deg); }
}
@keyframes faq-float-5 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(-40px, -48px) rotate(-10deg); }
}
@keyframes faq-float-6 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(55px, -40px) rotate(14deg); }
  66% { transform: translate(-70px, 35px) rotate(-12deg); }
}
@keyframes faq-float-7 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(35px, 55px) rotate(9deg); }
}
@keyframes faq-float-8 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(-52px, 28px) rotate(-9deg); }
  75% { transform: translate(58px, -35px) rotate(11deg); }
}
@keyframes faq-float-9 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(-65px, -52px) rotate(-16deg); }
}
@keyframes faq-float-10 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(42px, 48px) rotate(10deg); }
  66% { transform: translate(-48px, -28px) rotate(-8deg); }
}
@keyframes faq-float-11 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(50px, 35px) rotate(10deg); }
  75% { transform: translate(-40px, -45px) rotate(-12deg); }
}
@keyframes faq-float-12 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(-60px, 50px) rotate(-14deg); }
}
@keyframes faq-float-13 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(-45px, 40px) rotate(-10deg); }
  66% { transform: translate(55px, -35px) rotate(12deg); }
}
@keyframes faq-float-14 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(60px, -45px) rotate(14deg); }
  75% { transform: translate(-50px, 55px) rotate(-11deg); }
}
@keyframes faq-float-15 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(48px, -55px) rotate(15deg); }
}
@keyframes faq-float-16 {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(-55px, -40px) rotate(-13deg); }
  66% { transform: translate(40px, 45px) rotate(9deg); }
}

.faq-content {
  position: relative;
  z-index: 1;
  padding-top: 5.25rem;
}

.faq-back-btn {
  position: absolute;
  top: 0.5rem;
  left: -0.75rem;
  display: inline-block;
  line-height: 0;
  text-decoration: none;
  transition: transform 0.2s ease, filter 0.2s ease;
}

.faq-back-btn:hover {
  transform: scale(1.05);
  filter: drop-shadow(0 4px 12px rgba(255, 180, 80, 0.3));
}

.faq-back-btn-img {
  display: block;
  height: auto;
  max-height: 96px;
  width: auto;
  object-fit: contain;
}

.faq-disclaimer {
  margin: 0 auto 2rem;
  max-width: 520px;
  padding: 0.75rem 1rem;
  font-size: 1.15rem;
  line-height: 1.45;
  font-style: italic;
  color: rgba(255, 255, 255, 0.88);
  text-align: center;
  animation: faq-disclaimer-in 0.6s ease-out, faq-disclaimer-pulse 3s ease-in-out 0.6s infinite;
}

.faq-disclaimer strong {
  font-style: normal;
  color: rgba(255, 220, 140, 0.95);
}

.hackathon-faq-intro {
  max-width: min(95vw, 44rem);
  margin: 0 auto 1rem;
  font-size: clamp(1.3rem, 3.5vw, 1.85rem);
  line-height: 1.5;
  padding: 0.9rem 1.15rem;
  font-style: normal;
  font-weight: 800;
  letter-spacing: 0.03em;
  /* Solid red fill; keep stroke very thin so the red stays visible */
  color: #e01530;
  -webkit-text-fill-color: #e01530;
  -webkit-text-stroke: 0.45px #ffffff;
  text-shadow:
    0 2px 14px rgba(0, 0, 0, 0.55),
    0 0 18px rgba(236, 55, 80, 0.35);
}

.hackathon-guide-cta {
  margin: 0 auto 2.5rem;
  max-width: min(95vw, 38rem);
  text-align: center;
}

.hackathon-guide-cta__link {
  display: inline-block;
  padding: 0;
  margin: 0;
  line-height: 0;
  text-decoration: none;
  border: none;
  background: none;
  border-radius: 0;
  cursor: pointer;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.25s ease;
}

.hackathon-guide-cta__link:hover {
  transform: scale(1.04);
  filter: drop-shadow(0 10px 28px rgba(196, 30, 58, 0.5));
}

.hackathon-guide-cta__link:focus-visible {
  outline: 2px solid rgba(255, 160, 170, 0.95);
  outline-offset: 4px;
  border-radius: 8px;
}

.hackathon-guide-cta__img {
  display: block;
  width: clamp(200px, 72vw, 400px);
  height: auto;
  max-width: 100%;
  object-fit: contain;
}

@keyframes faq-disclaimer-in {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes faq-disclaimer-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.9; }
}

.hackathon-faq-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 0.65rem 1.25rem;
  margin: 0 auto 2rem;
  max-width: 100%;
}

.hackathon-faq-main-title {
  font-size: clamp(1.95rem, 5.5vw, 2.95rem);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 200, 100, 0.95);
  text-align: center;
  margin: 0;
  max-width: min(95vw, 36ch);
  line-height: 1.15;
}

.hackathon-faq-bunny {
  flex: 0 0 auto;
  width: clamp(88px, 24vw, 175px);
  height: auto;
  object-fit: contain;
  display: block;
}

.faq-title {
  display: block;
  max-width: 100%;
  width: clamp(280px, 50vw, 420px);
  height: auto;
  margin: 0 auto 2.5rem;
  object-fit: contain;
}

.faq-section {
  margin-bottom: 2.5rem;
}

.faq-section-heading {
  font-size: 1.45rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 200, 100, 0.95);
  margin: 0 0 1.25rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(255, 200, 100, 0.25);
}

.faq-static-block {
  padding: 1rem 1.25rem 1.25rem;
  border: 1px solid rgba(255, 200, 100, 0.45);
  border-radius: 10px;
  background: rgba(14, 10, 8, 0.82);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.faq-static-block .faq-a,
.faq-static-block .faq-list {
  color: rgba(255, 252, 248, 0.97);
}

.faq-static-block .faq-a strong {
  color: #fff;
  font-weight: 700;
}

.faq-static-block .faq-a:last-child {
  margin-bottom: 0;
}

.hackathon-signup-counter-bare {
  width: 100%;
  max-width: 52rem;
  margin: 0 auto;
  padding: 0.75rem 0 0;
}

.hackathon-faq-list--tight {
  margin-top: 0;
  margin-bottom: 0;
}

.hackathon-faq-list--tight li {
  margin-bottom: 0.35rem;
}

.hackathon-faq-list--tight li:last-child {
  margin-bottom: 0;
}

.hackathon-location-split {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1rem 1.75rem;
}

.hackathon-location-split__text {
  flex: 1 1 14rem;
  min-width: 0;
}

.hackathon-location-split__logo {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hackathon-unlv-logo {
  display: block;
  width: clamp(110px, 26vw, 200px);
  height: auto;
  object-fit: contain;
}

.hackathon-general-info-split {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.25rem 2rem;
}

.hackathon-general-info-split__text {
  flex: 1 1 17rem;
  min-width: 0;
}

.hackathon-general-info-split__text .faq-list {
  margin-top: 0;
}

.hackathon-general-info-split__visual {
  flex: 0 1 300px;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hackathon-vegas-img {
  display: block;
  width: 100%;
  max-width: min(340px, 100%);
  height: auto;
  object-fit: contain;
}

.hackathon-section--questions .faq-section-heading {
  text-align: center;
}

.hackathon-questions {
  text-align: center;
  padding: 0.25rem 0.5rem 0;
  max-width: 36rem;
  margin: 0 auto;
}

.hackathon-questions__lead,
.hackathon-questions__line {
  margin: 0 0 0.75rem;
  font-size: 1.45rem;
  line-height: 1.6;
  color: rgba(255, 252, 248, 0.96);
}

.hackathon-questions__line:last-child {
  margin-bottom: 0;
}

.hackathon-signup-progress--vegas {
  margin: 0;
  padding: 0;
}

.hackathon-signup-label {
  font-size: clamp(1.35rem, 3.2vw, 1.75rem);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 160, 160, 0.95);
}

.hackathon-signup-progress-head {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  min-height: auto;
  margin-bottom: 0.35rem;
  font-size: 1.35rem;
  font-weight: 600;
  text-align: center;
}

.hackathon-signup-count {
  font-variant-numeric: tabular-nums;
  font-size: clamp(2.85rem, 9vw, 4.35rem);
  line-height: 1;
  font-weight: 800;
  color: #fff;
  text-shadow:
    0 0 14px rgba(255, 80, 90, 0.9),
    0 0 36px rgba(255, 40, 50, 0.5);
