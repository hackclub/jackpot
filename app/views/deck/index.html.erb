<% content_for(:title) { "Deck (My Project)" } %>

<div class="deck-page <%= 'tutorial-active' if @show_tutorial %>">
  <div class="deck-table">
    <div class="cards-viewport">
      <% filled_count = @projects.count { |p| p.present? } %>
      <% if filled_count > 4 %>
        <button class="scroll-arrow scroll-arrow-left" id="scrollLeft" style="display: none;">&#9664;</button>
      <% end %>

      <div class="cards-track" id="cardsTrack">
        <% @projects.each_with_index do |project, i| %>
          <% if project.nil? %>
            <div
              class="card-slot card-slot-empty"
              data-empty="true"
            >
              <span class="empty-slot-icon">+</span>
              <span class="empty-slot-label">New Project</span>
            </div>
          <% else %>
            <div
               class="card-slot card-slot-filled<%= project["double_dip"] ? " card-slot--double-dip" : "" %>"
               data-index="<%= i %>"
               data-project-id="<%= project["id"] %>"
               data-project-name="<%= project["name"] %>"
               data-project-description="<%= project["description"] %>"
               data-project-type="<%= project["project_type"] %>"
               data-project-hours="<%= project["total_hours"] || project["hours"] || 0 %>"
               data-hackatime-hours="<%= project["hackatime_hours"] || 0 %>"
               data-journal-hours="<%= project["journal_hours"] || 0 %>"
               data-project-shipped="<%= project["shipped"] ? "true" : "false" %>"
               data-project-status="<%= project["status"].to_s %>"
               data-project-reviewed="<%= project["reviewed"] ? "true" : "false" %>"
               data-first-shipped-at="<%= project["first_shipped_at"].to_s %>"
               data-pending-review-hours="<%= project["pending_review_hours"].to_f %>"
               data-unshipped-hours-display="<%= (project["unshipped_hours_display"] || project["pending_review_hours"]).to_f %>"
               data-hours-logged-beyond-queue-submission="<%= (project["hours_logged_beyond_current_queue_submission"] || 0).to_f %>"
               data-reshippable="<%= project["reshippable"] ? "true" : "false" %>"
               data-user-has-other-pending-ship="<%= project["user_has_other_pending_ship"] ? "true" : "false" %>"
               data-main-hc-reship-locked="<%= project["main_hc_reship_locked"] ? "true" : "false" %>"
               data-playable-url="<%= project["playable_url"] %>"
               data-code-url="<%= project["code_url"] %>"
               data-github-username="<%= project["github_username"].to_s %>"
               data-banner-url="<%= project["banner_url"] %>"
               data-hackatime-projects="<%= (project["hackatime_projects"] || []).join(",") %>"
               data-double-dip="<%= project["double_dip"] ? "true" : "false" %>"
             >
              <% if project["double_dip"] %>
                <details class="card-double-dip-details">
                  <summary class="card-double-dip-pill">
                    <span class="card-double-dip-pill-title">Project Warning!</span>
                    <span class="card-double-dip-pill-hint">(open to read)</span>
                  </summary>
                  <div class="card-double-dip-panel">
                    <p class="card-double-dip-panel-lead">Project Warning!</p>
                    <p>Your code URL has been matched with a project in another HC program. Make sure that the hours sent are different, or your account could be flagged for fraud.</p>
                    <p>This project will be manually checked in both programs databases.</p>
                  </div>
                </details>
              <% end %>
              <span class="card-project-name"><%= project["name"] %></span>
              <div class="card-stats">
                <span class="card-hours"><%= "%.1f" % (project["total_hours"] || project["hours"] || 0) %></span>
                <span class="card-hours-label">hours</span>
              </div>
              <% if project["shipped"] %>
                <span class="card-shipped-badge">Shipped ✓</span>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <button class="add-project-btn" id="addProjectBtn" title="Add new project">
          <span class="add-icon">+</span>
        </button>
      </div>

      <% if filled_count > 4 %>
        <button class="scroll-arrow scroll-arrow-right" id="scrollRight">&#9654;</button>
      <% end %>
    </div>
  </div>
</div>

<% if @show_tutorial %>
<div class="tutorial-overlay" id="tutorialOverlay">
  <div class="tutorial-dim" id="tutorialDim"></div>
  <div class="tutorial-spotlight" id="tutorialSpotlight"></div>
  <div class="tutorial-tooltip" id="tutorialTooltip">
    <p class="tutorial-text">Click a slot to start your first project!</p>
    <div class="tutorial-arrow-down"></div>
  </div>
</div>
<% end %>

<div id="modalTutorialSpotlight" style="display:none; position:fixed; z-index:3001; border-radius:10px; background:transparent; box-shadow:0 0 0 9999px rgba(0,0,0,0.6); transition:all 0.25s ease; pointer-events:none;"></div>
<div id="modalTutorialTooltip" style="display:none; position:fixed; z-index:3002; text-align:center; pointer-events:auto;">
  <p id="modalTutorialText" class="tutorial-text" style="white-space:normal; max-width:280px; font-size:1rem;"></p>
  <button id="modalTutorialNext" style="display:block; margin:6px auto 0; background:#d4a017; border:none; color:#fff; font-family:'Georgia',serif; font-size:0.9rem; font-weight:700; padding:6px 18px; border-radius:6px; cursor:pointer; pointer-events:auto;">Next →</button>
  <div class="tutorial-arrow-down"></div>
</div>

<!-- Create / Edit modal -->
<div class="modal-overlay" id="projectModal" aria-hidden="true">
  <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="projectModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="projectModalTitle">New Project</h3>
      <button type="button" class="modal-close" id="projectModalClose" aria-label="Close">&times;</button>
    </div>

    <%= form_with url: save_project_path, method: :post, id: "projectModalForm", local: true do %>
      <input type="hidden" name="project_index" id="projectIndexInput">

      <div class="project-form-body">
      <div class="project-form-field">
        <label for="projectNameInput">Project name</label>
        <input type="text" id="projectNameInput" name="project_name" required>
      </div>

      <div class="project-form-field">
        <label for="projectDescriptionInput">Description</label>
        <textarea id="projectDescriptionInput" name="project_description" rows="3"></textarea>
      </div>

      <div class="project-form-field">
         <label>Type of project</label>
         <div class="project-type-grid">
           <div class="project-type-option">
             <input type="radio" id="projectTypeSoftware" name="project_type" value="Software">
             <label for="projectTypeSoftware">Software</label>
           </div>
           <div class="project-type-option">
             <input type="radio" id="projectTypeHardware" name="project_type" value="Hardware">
             <label for="projectTypeHardware">Hardware</label>
           </div>
           <div class="project-type-option">
             <input type="radio" id="projectTypeArt" name="project_type" value="Art">
             <label for="projectTypeArt">Art</label>
           </div>
           <div class="project-type-option">
             <input type="radio" id="projectTypeOther" name="project_type" value="Other">
             <label for="projectTypeOther">Other</label>
           </div>
         </div>
       </div>

      <div class="project-form-field">
         <label for="playableUrlInput">Playable URL (optional)</label>
         <input type="url" id="playableUrlInput" name="playable_url" placeholder="https://example.com">
       </div>

       <div class="project-form-field">
         <label for="codeUrlInput">Code URL (optional)</label>
         <input type="url" id="codeUrlInput" name="code_url" placeholder="https://github.com/...">
       </div>

       <div class="project-form-field">
         <label for="githubUsernameInput">GitHub username <span style="color:#c0392b;">*</span> <span class="hackatime-field-hint">(required before shipping)</span></label>
         <input type="text" id="githubUsernameInput" name="github_username" placeholder="your-username" autocomplete="username">
       </div>

       <div class="project-form-field">
         <label>Hackatime projects (optional)</label>
         <p id="hackatimePickerHint" class="hackatime-field-hint">Link your Hackatime projects to track hours.</p>
         <div class="hackatime-picker" id="hackatimePicker">
           <% if @hackatime_projects.present? %>
             <% @hackatime_projects.each do |hp_name| %>
               <label class="hackatime-option">
                 <input type="checkbox" name="hackatime_projects[]" value="<%= hp_name %>" class="hackatime-checkbox">
                 <span class="hackatime-option-name"><%= hp_name %></span>
               </label>
             <% end %>
           <% else %>
             <p class="hackatime-empty">No Hackatime projects found. Start coding to see them here!</p>
           <% end %>
         </div>
         </div>
         </div>

         <div class="project-form-actions">
        <button type="button" class="project-cancel-btn" id="projectModalCancel">Cancel</button>
        <button type="button" class="project-save-btn" id="projectModalSubmit">Save Project</button>
      </div>
    <% end %>
  </div>
</div>

 <div class="modal-overlay" id="projectDetailModal" aria-hidden="true">
   <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="projectDetailTitle">
     <div class="modal-header">
       <input type="text" class="modal-title-input" id="projectDetailTitle" placeholder="Project Name">
       <button type="button" class="modal-close" id="projectDetailClose" aria-label="Close">&times;</button>
     </div>

     <div class="project-detail-body">
       <div class="detail-main-panel" id="detailMainPanel">
         <div class="detail-stat-row" style="display: none;">
           <span class="detail-label">Hours coded</span>
           <span class="detail-value" id="detailHours">0.0 hrs</span>
         </div>
         
         <div class="detail-stat-row" id="detailDoubleDipRow" style="display: none;">
           <div class="detail-double-dip-notice">
             <strong class="detail-double-dip-heading">Project Warning!</strong>
             <p class="detail-double-dip-text">Your code URL has been matched with a project in another HC program. Make sure that the hours sent are different, or your account could be flagged for fraud.</p>
             <p class="detail-double-dip-text">This project will be manually checked in both programs databases.</p>
           </div>
         </div>

         <div class="detail-stat-row">
           <span class="detail-label">Description</span>
           <textarea class="detail-value detail-description-edit" id="detailDescription" rows="3"></textarea>
         </div>
         
         <div class="detail-stat-row">
           <span class="detail-label">Type</span>
           <span class="detail-value" id="detailType">—</span>
         </div>
         
         <div class="detail-stat-row" id="detailPlayableRow">
           <span class="detail-label">Playable URL</span>
           <input type="url" class="detail-value detail-url-input" id="detailPlayableUrl" placeholder="https://example.com">
         </div>
         
         <div class="detail-stat-row" id="detailCodeRow">
           <span class="detail-label">Code URL</span>
           <input type="url" class="detail-value detail-url-input" id="detailCodeUrl" placeholder="https://github.com/...">
         </div>

         <div class="detail-stat-row" id="detailGithubRow">
           <span class="detail-label">GitHub username <span style="color:#c0392b;">*</span></span>
           <input type="text" class="detail-value detail-url-input" id="detailGithubUsername" placeholder="your-username" autocomplete="username">
         </div>
         
         <div class="detail-stat-row" id="detailBannerRow">
            <span class="detail-label">Banner Photo <span style="color:#c0392b;">*</span></span>
            <div class="detail-value" id="detailBannerValue">
              <div class="banner-upload-area" id="bannerUploadArea">
                <img id="bannerPreview" class="banner-preview" style="display:none;">
                <div id="bannerPlaceholder" class="banner-placeholder">
                  <span class="banner-placeholder-icon">📷</span>
                  <span class="banner-placeholder-text">Click or drag & drop a screenshot</span>
                </div>
                <input type="file" id="bannerFileInput" accept="image/*" style="display:none;">
              </div>
            </div>
          </div>

          <div class="detail-stat-row" id="detailHackatimeRow" style="display: none;">
            <span class="detail-label">Hackatime</span>
            <span class="detail-value" id="detailHackatime">—</span>
          </div>
         
         <div class="detail-stat-row" id="detailShippedRow" style="display: none;">
           <span class="detail-label">Status</span>
           <span class="detail-value detail-shipped-text">Shipped ✓</span>
         </div>

         <div class="detail-journal-entries-section">
           <span class="detail-label">Journal Entries</span>
           <div id="detailJournalEntriesList" class="detail-journal-entries-list"></div>
         </div>

         <div class="detail-stat-row" id="detailShipSubmissionNoteRow" style="display: none;">
           <span class="detail-label">Update for reviewers <span class="detail-label-required" aria-hidden="true">*</span></span>
           <textarea class="detail-value detail-description-edit" id="detailShipSubmissionNote" rows="3" maxlength="10000" placeholder="Describe what changed in this submission — this does not replace your project description." aria-required="true"></textarea>
         </div>
         </div>


     </div>

     <div class="project-form-actions project-detail-form-actions">
       <div class="project-detail-actions-start">
         <input type="hidden" id="shipProjectIndex" name="project_index">
         <button type="button" class="project-cancel-btn" id="detailJournalBtn">Journal</button>
         <button type="button" class="project-cancel-btn" id="detailSaveBtn">Save Changes</button>
         <button type="button" class="project-ship-btn" id="detailShipBtn">Ship It</button>
         <button type="button" class="project-cancel-btn" id="detailUnshipBtn" style="display: none;">Remove from review queue</button>
         <button type="button" class="project-delete-btn" id="detailDeleteBtn">Delete</button>
       </div>
       <div class="detail-unshipped-hours-inline" id="detailUnshippedHoursRow" style="display: none;" aria-live="polite">
         <span class="detail-unshipped-hours-label">Unshipped hours</span>
         <span class="detail-unshipped-hours-value" id="detailUnshippedHours">0.0</span>
       </div>
     </div>
   </div>
 </div>

 <div class="modal-overlay" id="journalDrawer" aria-hidden="true">
   <div class="journal-modal-content" role="dialog" aria-modal="true" aria-labelledby="journalProjectTitle">
     <div class="journal-modal-header">
       <h3 class="journal-modal-title" id="journalProjectTitle">Project Journal</h3>
       <button type="button" class="modal-close" id="journalDrawerClose" aria-label="Close">&times;</button>
     </div>
   
     <div class="journal-modal-body">
       <div class="journal-entry-form">
       <div class="journal-form-field">
         <label for="journalTimeDone">Time Done</label>
         <input type="datetime-local" id="journalTimeDone" name="time_done">
       </div>
       
       <div class="journal-form-field">
         <label for="journalHoursWorked">Hours Worked</label>
         <input type="number" id="journalHoursWorked" name="hours_worked" step="0.5" min="0" placeholder="e.g. 2.5">
       </div>
       
       <div class="journal-form-field">
         <label for="journalDescription">Description</label>
         <textarea id="journalDescription" name="description" rows="3" placeholder="What did you work on? Drag & drop or paste images here."></textarea>
         <p style="margin: 4px 0 0; font-size: 0.75rem; color: #999; font-style: italic;">Attach images by dragging & dropping or pasting from clipboard.</p>
       </div>
       
       <div class="journal-form-field">
         <label for="journalToolsUsed">Tools Used</label>
         <input type="text" id="journalToolsUsed" name="tools_used" placeholder="e.g. React, TypeScript, Figma (comma-separated)">
       </div>
       
       <button type="button" class="project-save-btn" id="journalSaveBtn">Save Entry</button>
     </div>
     
     <div class="journal-entries-list" id="journalEntriesList">
     </div>
     </div>
   </div>
 </div>

<style>
.hackatime-option--locked { opacity: 0.55; }
.hackatime-option--locked .hackatime-option-name { font-style: italic; }
</style>
<script type="application/json" id="deckHackatimeClaimed"><%= raw @hackatime_owner_by_name.to_json %></script>

<script>
function initDeck() {
  var deckHackatimeClaimed = {};
  (function() {
    var el = document.getElementById('deckHackatimeClaimed');
    if (!el || !el.textContent) return;
    try { deckHackatimeClaimed = JSON.parse(el.textContent); } catch (e) { console.warn(e); }
  })();

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderDescription(str) {
    if (!str) return '';
    var escaped = escapeHtml(str);
    return escaped.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, function(match, alt, url) {
      if (!/^https?:\/\//i.test(url)) return match;
      return '<img src="' + url + '" alt="' + alt + '" style="max-width:100%;border-radius:6px;margin:6px 0;display:block;">';
    });
  }

  function setupImageUpload(textarea) {
    var uploadUrl = '<%= upload_journal_image_path %>';
    var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

    function handleFiles(files) {
      Array.from(files).forEach(function(file) {
        if (!file.type.startsWith('image/')) return;

        var placeholder = '![Uploading ' + file.name + '...]()';
        var start = textarea.selectionStart;
        var before = textarea.value.substring(0, start);
        var after = textarea.value.substring(textarea.selectionEnd);
        textarea.value = before + placeholder + after;
        textarea.selectionStart = textarea.selectionEnd = start + placeholder.length;

        var formData = new FormData();
        formData.append('file', file);

        fetch(uploadUrl, {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrfToken },
          body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.url) {
            var md = '![' + file.name + '](' + data.url + ')';
            textarea.value = textarea.value.replace(placeholder, md);
          } else {
            textarea.value = textarea.value.replace(placeholder, '');
            alert(data.error || 'Upload failed');
          }
        })
        .catch(function() {
          textarea.value = textarea.value.replace(placeholder, '');
          alert('Upload failed');
        });
      });
    }

    textarea.addEventListener('dragover', function(e) {
      e.preventDefault();
      textarea.style.borderColor = '#d4a017';
    });
    textarea.addEventListener('dragleave', function() {
      textarea.style.borderColor = '';
    });
    textarea.addEventListener('drop', function(e) {
      e.preventDefault();
      textarea.style.borderColor = '';
      if (e.dataTransfer.files.length > 0) handleFiles(e.dataTransfer.files);
    });
    textarea.addEventListener('paste', function(e) {
      var items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      var imageFiles = [];
      for (var i = 0; i < items.length; i++) {
        if (items[i].type.startsWith('image/')) {
          imageFiles.push(items[i].getAsFile());
        }
      }
      if (imageFiles.length > 0) {
        e.preventDefault();
        handleFiles(imageFiles);
      }
    });
  }

  var isTutorialMode = <%= @show_tutorial ? 'true' : 'false' %>;

  var track = document.getElementById('cardsTrack');
  var leftBtn = document.getElementById('scrollLeft');
  var rightBtn = document.getElementById('scrollRight');

  if (track && leftBtn && rightBtn) {
    var scrollAmount = 150;

    function updateArrows() {
      leftBtn.style.display = track.scrollLeft > 0 ? 'flex' : 'none';
      rightBtn.style.display = (track.scrollLeft + track.clientWidth) < track.scrollWidth - 5 ? 'flex' : 'none';
    }

    leftBtn.addEventListener('click', function() {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    rightBtn.addEventListener('click', function() {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);
    setTimeout(updateArrows, 100);
  }

  var projectModal = document.getElementById('projectModal');
  var projectModalClose = document.getElementById('projectModalClose');
  var projectModalCancel = document.getElementById('projectModalCancel');
  var projectIndexInput = document.getElementById('projectIndexInput');
   var projectNameInput = document.getElementById('projectNameInput');
   var projectDescriptionInput = document.getElementById('projectDescriptionInput');
   var projectModalTitle = document.getElementById('projectModalTitle');

   function applyHackatimeCheckboxLocks(editingProjectId) {
     var claimed = deckHackatimeClaimed && typeof deckHackatimeClaimed === 'object' ? deckHackatimeClaimed : {};
     var editId = editingProjectId != null && editingProjectId !== '' ? String(editingProjectId) : null;
     document.querySelectorAll('#hackatimePicker .hackatime-checkbox').forEach(function(cb) {
       var key = (cb.value || '').toLowerCase();
       var owner = claimed[key];
       var takenByOther = owner != null && String(owner) !== editId;
       cb.disabled = takenByOther;
       var label = cb.closest('.hackatime-option');
       if (label) {
         label.classList.toggle('hackatime-option--locked', takenByOther);
         label.title = takenByOther ? 'Already linked to another deck project.' : '';
       }
       if (takenByOther) cb.checked = false;
     });
   }

   var hackatimePickerHintEl = document.getElementById('hackatimePickerHint');
   function openProjectModal(data) {
     if (!projectModal) return;
     projectIndexInput.value = data.index;
     projectNameInput.value = data.name || '';
     projectDescriptionInput.value = data.description || '';
     
     var typeRadios = document.querySelectorAll('input[name="project_type"]');
     typeRadios.forEach(function(radio) {
       radio.checked = radio.value === data.projectType;
     });
     
     var playableUrlInput = document.getElementById('playableUrlInput');
     var codeUrlInput = document.getElementById('codeUrlInput');
     var githubUsernameInput = document.getElementById('githubUsernameInput');
     if (playableUrlInput) playableUrlInput.value = data.playableUrl || '';
     if (codeUrlInput) codeUrlInput.value = data.codeUrl || '';
     if (githubUsernameInput) githubUsernameInput.value = data.githubUsername || '';
     
     projectModalTitle.textContent = data.isNew ? 'New Project' : 'Edit Project';

    var linked = (data.hackatimeProjects || '').split(',').filter(function(s) { return s.length > 0; });
    var checkboxes = document.querySelectorAll('#hackatimePicker .hackatime-checkbox');
    checkboxes.forEach(function(cb) {
      cb.disabled = false;
      var lbl = cb.closest('.hackatime-option');
      if (lbl) {
        lbl.classList.remove('hackatime-option--locked');
        lbl.title = '';
      }
      cb.checked = linked.indexOf(cb.value) !== -1;
    });
    applyHackatimeCheckboxLocks(data.id);

    if (hackatimePickerHintEl) {
      hackatimePickerHintEl.textContent = 'Link your Hackatime projects to track hours.';
    }

    projectModal.classList.add('active');
    projectModal.setAttribute('aria-hidden', 'false');
    projectNameInput.focus();

    if (isTutorialMode && data.isNew) {
      setTimeout(startModalTutorial, 350);
    }
   }

  function closeProjectModal() {
    if (!projectModal) return;
    projectModal.classList.remove('active');
    projectModal.setAttribute('aria-hidden', 'true');
    stopModalTutorial();
  }

  var modalTutorialSpotlight= document.getElementById('modalTutorialSpotlight');
  var modalTutorialTooltip  = document.getElementById('modalTutorialTooltip');
  var modalTutorialText     = document.getElementById('modalTutorialText');
  var modalTutorialNext     = document.getElementById('modalTutorialNext');
  var modalTutorialStep     = 0;
  var modalTutorialResizeTimer = null;

  var modalTutorialSteps = [
    { getEl: function() { return document.getElementById('projectNameInput'); },
      text: 'Enter a project name' },
    { getEl: function() { return document.getElementById('projectDescriptionInput'); },
      text: 'Add a description' },
    { getEl: function() { return document.querySelector('.project-type-grid'); },
      text: 'Choose your type of project' },
    { getEl: function() { return document.getElementById('playableUrlInput'); },
      text: 'Playable URL — skip if you don\'t have one yet' },
    { getEl: function() { return document.getElementById('codeUrlInput'); },
      text: 'Code URL — paste your repo link' },
    { getEl: function() { return document.getElementById('githubUsernameInput'); },
      text: 'GitHub username — required before you ship' },
    { getEl: function() { return document.getElementById('hackatimePicker'); },
      text: 'Pick Hackatime projects to track your hours (optional)' },
    { getEl: function() { return document.getElementById('projectModalSubmit'); },
      text: 'All set — save your project!', isLast: true }
  ];

  function positionModalTutorialStep(stepIndex) {
    var step = modalTutorialSteps[stepIndex];
    if (!step) return;
    var el = step.getEl();
    if (!el) return;

    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    setTimeout(function() {
      requestAnimationFrame(function() {
        var rect = el.getBoundingClientRect();
        var pad = 12;

        modalTutorialSpotlight.style.left   = (rect.left - pad) + 'px';
        modalTutorialSpotlight.style.top    = (rect.top  - pad) + 'px';
        modalTutorialSpotlight.style.width  = (rect.width  + pad * 2) + 'px';
        modalTutorialSpotlight.style.height = (rect.height + pad * 2) + 'px';

        modalTutorialText.textContent = step.text;
        modalTutorialNext.textContent = step.isLast ? 'Got it! →' : 'Next →';

        var tipX = rect.left + rect.width / 2;
        var tooltipHeight = modalTutorialTooltip.offsetHeight || 90;
        var spaceAbove = rect.top - pad - 8;
        var belowY = rect.bottom + pad + 8;

        modalTutorialTooltip.classList.remove('tutorial-bounce-up', 'tutorial-bounce-down');

        if (spaceAbove >= tooltipHeight) {
          modalTutorialTooltip.classList.add('tutorial-bounce-up');
          modalTutorialTooltip.style.top  = spaceAbove + 'px';
        } else {
          modalTutorialTooltip.classList.add('tutorial-bounce-down');
          modalTutorialTooltip.style.top  = belowY + 'px';
        }
        modalTutorialTooltip.style.left = tipX + 'px';
      });
    }, 350);
  }

  function startModalTutorial() {
    if (!modalTutorialSpotlight) return;
    modalTutorialStep = 0;
    modalTutorialSpotlight.style.display = 'block';
    modalTutorialTooltip.style.display = 'block';
    positionModalTutorialStep(0);

    window.addEventListener('resize', onModalTutorialResize);
  }

  function stopModalTutorial() {
    if (!modalTutorialSpotlight) return;
    modalTutorialSpotlight.style.display = 'none';
    modalTutorialTooltip.style.display = 'none';
    window.removeEventListener('resize', onModalTutorialResize);
  }

  function onModalTutorialResize() {
    clearTimeout(modalTutorialResizeTimer);
    modalTutorialResizeTimer = setTimeout(function() {
      positionModalTutorialStep(modalTutorialStep);
    }, 80);
  }

  if (modalTutorialNext) {
    modalTutorialNext.addEventListener('click', function() {
      modalTutorialStep++;
      if (modalTutorialStep >= modalTutorialSteps.length) {
        stopModalTutorial();
      } else {
        positionModalTutorialStep(modalTutorialStep);
      }
    });
  }
  // ─────────────────────────────────────────────────────────────────────────────

  if (projectModalClose) projectModalClose.addEventListener('click', closeProjectModal);
  if (projectModalCancel) projectModalCancel.addEventListener('click', closeProjectModal);
  if (projectModal) {
    projectModal.addEventListener('click', function(e) {
      if (e.target === projectModal && !isTutorialMode) closeProjectModal();
    });
  }

  var projectModalSubmit = document.getElementById('projectModalSubmit');
  var projectModalSubmitInProgress = false;
  if (projectModalSubmit) {
    projectModalSubmit.addEventListener('click', function() {
      if (projectModalSubmitInProgress) return;
      if (!projectNameInput.value.trim()) {
        alert('Project name is required');
        return;
      }

      var toolsArray = [];
      var typeRadios = document.querySelectorAll('input[name="project_type"]');
      var selectedType = '';
      typeRadios.forEach(function(radio) {
        if (radio.checked) selectedType = radio.value;
      });

      var formData = new FormData();
      formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
      formData.append('project_index', projectIndexInput.value);
      formData.append('project_name', projectNameInput.value);
      formData.append('project_description', projectDescriptionInput.value);
      formData.append('project_type', selectedType);
      formData.append('playable_url', document.getElementById('playableUrlInput').value);
      formData.append('code_url', document.getElementById('codeUrlInput').value);
      formData.append('github_username', document.getElementById('githubUsernameInput').value);

      var hackatimeCheckboxes = document.querySelectorAll('#hackatimePicker .hackatime-checkbox:checked');
      hackatimeCheckboxes.forEach(function(cb) {
        formData.append('hackatime_projects[]', cb.value);
      });

      projectModalSubmitInProgress = true;
      projectModalSubmit.disabled = true;
      fetch('<%= save_project_path %>', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          closeProjectModal();
          stopModalTutorial();
          if (isTutorialMode) {
            fetch('<%= complete_tutorial_path %>', {
              method: 'POST',
              headers: {
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
                'Content-Type': 'application/json'
              }
            }).then(function() {
              window.location.href = '<%= leaderboard_path %>?welcome=1';
            });
          } else {
            location.reload();
          }
        } else if (data.error) {
          alert(data.error);
        }
      })
      .catch(function(e) { console.error('Error saving project:', e); })
      .finally(function() {
        projectModalSubmitInProgress = false;
        projectModalSubmit.disabled = false;
      });
    });
  }

