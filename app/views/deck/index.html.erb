   var SHIP_BLOCKED_OTHER_PENDING_MSG = [
     "Shipping a project means submitting a working and complete demo (even if only partial) of your project. From there, it will enter the review queue.",
     "The ship button shouldn't be used for every single change, but only a couple of times to submit meaningful project updates.",
     "You already have an update in the queue, and removing it would place you back at the end (the queue is long…). Are you sure that, compared to the previously submitted version of your project, you've added extremely significant improvements (for example, an entirely new demo)? If not, it's better to wait before submitting again."
   ].join("\n\n");
   var SHIP_NEED_HOURS_BEYOND_QUEUE_MSG = 'Log more hours on this project since your last ship, then use Ship update to add them to your pending submission and move it to the back of the queue.';

   function applyDeckProjectTotalsFromServer(project) {
     if (!project || project.id == null) return;
     var card = document.querySelector('.card-slot-filled[data-project-id="' + project.id + '"]');
     if (card) {
       var hrs = project.hours != null ? project.hours : 0;
       var hoursEl = card.querySelector('.card-hours');
       if (hoursEl) hoursEl.textContent = parseFloat(hrs, 10).toFixed(1);
       card.dataset.projectHours = String(hrs);
       card.dataset.hackatimeHours = String(project.hackatime_hours != null ? project.hackatime_hours : 0);
       card.dataset.journalHours = String(project.journal_hours != null ? project.journal_hours : 0);
       card.dataset.pendingReviewHours = String(project.pending_review_hours != null ? project.pending_review_hours : 0);
       card.dataset.unshippedHoursDisplay = String(project.unshipped_hours_display != null ? project.unshipped_hours_display : 0);
       card.dataset.hoursLoggedBeyondQueueSubmission = String(project.hours_logged_beyond_queue_submission != null ? project.hours_logged_beyond_queue_submission : 0);
       card.dataset.reshippable = project.reshippable ? 'true' : 'false';
       card.dataset.userHasOtherPendingShip = project.user_has_other_pending_ship ? 'true' : 'false';
       card.dataset.mainHcReshipLocked = project.main_hc_reship_locked ? 'true' : 'false';
     }
     function mergeHoursInto(data) {
       if (!data) return;
       data.hours = String(project.hours);
       data.hackatimeHours = String(project.hackatime_hours || 0);
       data.journalHours = String(project.journal_hours || 0);
       data.pendingReviewHours = String(project.pending_review_hours || 0);
       data.unshippedHoursDisplay = String(project.unshipped_hours_display || 0);
       data.hoursLoggedBeyondQueueSubmission = String(project.hours_logged_beyond_queue_submission || 0);
       data.reshippable = project.reshippable ? 'true' : 'false';
       data.userHasOtherPendingShip = project.user_has_other_pending_ship ? 'true' : 'false';
       data.mainHcReshipLocked = project.main_hc_reship_locked ? 'true' : 'false';
     }
     if (currentJournalData && String(currentJournalData.id) === String(project.id)) mergeHoursInto(currentJournalData);
     if (currentDetailData && String(currentDetailData.id) === String(project.id)) {
       mergeHoursInto(currentDetailData);
       if (detailModal && detailModal.classList.contains('active')) {
         var totalHrs = parseFloat(project.hours || 0).toFixed(1);
         if (detailHours) detailHours.textContent = totalHrs + ' hrs';
         if (detailUnshippedHoursRow && detailUnshippedHours) {
           var unsh = parseFloat(project.unshipped_hours_display, 10);
           if (isNaN(unsh)) unsh = 0;
           detailUnshippedHours.textContent = unsh.toFixed(1);
         }
       }
     }
   }

   function detailCanEditPlayableBanner() {
     if (!currentDetailData) return false;
     if (currentDetailData.shipped !== 'true') return true;
     var locked = currentDetailData.firstShippedAt && String(currentDetailData.firstShippedAt).trim().length > 0;
     var st = currentDetailData.status || '';
     return locked && (st === 'approved' || st === 'in-review');
   }

   function loadDetailJournalEntries(projectId) {
     if (!detailJournalEntriesList) return;
     if (projectId == null || projectId === '') {
       detailJournalEntriesList.innerHTML = '<p class="detail-journal-empty">No journal entries yet.</p>';
       return;
     }
     fetch('/deck/journal_entries/' + encodeURIComponent(projectId))
       .then(function(r) { return r.json(); })
       .then(function(entries) {
         detailJournalEntriesList.innerHTML = '';
         if (!entries || entries.length === 0) {
           detailJournalEntriesList.innerHTML = '<p class="detail-journal-empty">No journal entries yet.</p>';
           return;
         }
         entries.forEach(function(entry) {
           var entryEl = document.createElement('div');
           entryEl.className = 'detail-journal-entry';
           var timeStr = entry.time_done ? new Date(entry.time_done).toLocaleDateString() : 'N/A';
           entryEl.innerHTML = '<div class="detail-journal-entry-header">' +
             '<span class="detail-journal-entry-date">' + timeStr + '</span>' +
             '<span class="detail-journal-entry-hours">' + (entry.hours_worked || 0) + ' hrs</span>' +
             '</div>' +
             '<div class="detail-journal-entry-desc">' + renderDescription(entry.description) + '</div>';
           if (entry.tools_used && entry.tools_used.length > 0) {
             entryEl.innerHTML += '<p class="detail-journal-entry-tools"><strong>Tools:</strong> ' + entry.tools_used.map(escapeHtml).join(', ') + '</p>';
           }
           detailJournalEntriesList.appendChild(entryEl);
         });
       })
       .catch(function(e) { console.error('Failed to load journal entries:', e); });
   }

   function openDetailModal(data) {
     if (!detailModal) return;
     currentDetailData = data;
     detailTitle.value = data.name;
     var totalHrs = parseFloat(data.hours || 0).toFixed(1);
     detailHours.textContent = totalHrs + ' hrs';
     detailDescription.value = data.description || '';
     if (detailDoubleDipRow) {
       detailDoubleDipRow.style.display = (data.doubleDip === 'true') ? 'flex' : 'none';
     }
     detailType.textContent = data.projectType || '—';
     detailPlayableUrl.value = data.playableUrl || '';
     detailCodeUrl.value = data.codeUrl || '';
     if (detailGithubUsername) detailGithubUsername.value = data.githubUsername || '';
     shipProjectIndex.value = data.index;

     var linked = (data.hackatimeProjects || '').split(',').filter(function(s) { return s.length > 0; });
     if (linked.length > 0) {
       detailHackatime.textContent = linked.join(', ');
       detailHackatimeRow.style.display = 'flex';
     } else {
       detailHackatimeRow.style.display = 'none';
     }

     currentBannerUrl = data.bannerUrl || '';
     if (currentBannerUrl) {
       bannerPreview.src = currentBannerUrl;
       bannerPreview.style.display = 'block';
       bannerPlaceholder.style.display = 'none';
     } else {
       bannerPreview.style.display = 'none';
       bannerPlaceholder.style.display = 'flex';
     }

     var isShipped = data.shipped === 'true';
     var hasFirstShippedAt = !!(data.firstShippedAt && String(data.firstShippedAt).trim().length > 0);
     var lockedAfterShip = isShipped && hasFirstShippedAt;
     var canReship = data.reshippable === 'true';
     var mainHcLocked = data.mainHcReshipLocked === 'true';
     var pendingHrsModal = parseFloat(data.pendingReviewHours, 10);
     if (isNaN(pendingHrsModal)) pendingHrsModal = 0;
     var showShipUpdateLocked = isShipped && data.status === 'approved' && pendingHrsModal > 0 && mainHcLocked;
     var hoursBeyondQueue = parseFloat(data.hoursLoggedBeyondQueueSubmission || 0, 10) || 0;
     var pendingQueueShipUpdate = isShipped && data.status === 'in-review' && data.reviewed !== 'true' && hoursBeyondQueue > 1e-6;
     var canUnship = isShipped && data.status === 'in-review' && data.reviewed !== 'true';
     var shipUpdateSameProject = isShipped && data.status === 'in-review' && data.reviewed !== 'true';
     var inReviewQueue = shipUpdateSameProject;
     var otherPending = data.userHasOtherPendingShip === 'true';
     var blockShipOtherPending = otherPending && !shipUpdateSameProject && isShipped && !(data.status === 'approved' && canReship);
     // Always show Ship while waiting for review (not only when there are hours beyond the queue snapshot)
     var showShipBtn = !isShipped || canReship || showShipUpdateLocked || pendingQueueShipUpdate || inReviewQueue;

     if (detailUnshippedHoursRow && detailUnshippedHours) {
       var unshipped = parseFloat(data.unshippedHoursDisplay, 10);
       if (isNaN(unshipped)) unshipped = 0;
       detailUnshippedHours.textContent = unshipped.toFixed(1);
       detailUnshippedHoursRow.style.display = (lockedAfterShip || isShipped) ? 'flex' : 'none';
     }

     var detailShipSubmissionNoteRow = document.getElementById('detailShipSubmissionNoteRow');
     var detailShipSubmissionNote = document.getElementById('detailShipSubmissionNote');
     if (detailShipSubmissionNoteRow && detailShipSubmissionNote) {
       var showShipNote = showShipBtn && !showShipUpdateLocked && !blockShipOtherPending && (!inReviewQueue || pendingQueueShipUpdate);
       detailShipSubmissionNoteRow.style.display = showShipNote ? 'flex' : 'none';
       if (showShipNote) detailShipSubmissionNote.value = '';
       detailShipSubmissionNote.required = !!showShipNote;
     }

     if (bannerUploadArea) {
       var bannerVisuallyLocked = lockedAfterShip && !detailCanEditPlayableBanner();
       bannerUploadArea.classList.toggle('banner-upload-area--locked', bannerVisuallyLocked);
     }

     detailShippedRow.style.display = isShipped ? 'flex' : 'none';
     if (detailShipBtn) {
       detailShipBtn.classList.toggle('ship-update--main-hc-locked', showShipUpdateLocked);
       var needMoreHoursForQueueUpdate = !!(inReviewQueue && !pendingQueueShipUpdate && !showShipUpdateLocked && !blockShipOtherPending);
       detailShipBtn.classList.toggle('ship-btn--other-pending', !!(blockShipOtherPending && !showShipUpdateLocked));
       detailShipBtn.classList.toggle('ship-btn--need-more-hours', needMoreHoursForQueueUpdate);
       if (showShipUpdateLocked) {
         detailShipBtn.style.display = 'inline-block';
         detailShipBtn.textContent = 'Ship update';
         detailShipBtn.style.opacity = '0.65';
         detailShipBtn.style.cursor = 'not-allowed';
         detailShipBtn.title = 'This project has already been submitted to the main HC database - please contact @Emma';
       } else if (blockShipOtherPending) {
         // Always show Ship (same as when nothing blocks); only the popup stops the action
         detailShipBtn.style.display = 'inline-block';
         detailShipBtn.textContent = (inReviewQueue || pendingQueueShipUpdate || canReship) ? 'Ship update' : 'Ship It';
         detailShipBtn.style.opacity = '';
         detailShipBtn.style.cursor = '';
         detailShipBtn.title = 'You already have an update in the queue — click for the full message';
       } else if (needMoreHoursForQueueUpdate) {
         detailShipBtn.style.display = 'inline-block';
         detailShipBtn.textContent = 'Ship update';
         detailShipBtn.style.opacity = '';
         detailShipBtn.style.cursor = '';
         detailShipBtn.title = SHIP_NEED_HOURS_BEYOND_QUEUE_MSG;
       } else {
         detailShipBtn.style.opacity = '';
         detailShipBtn.style.cursor = '';
         detailShipBtn.title = pendingQueueShipUpdate ? 'Add new logged hours to your pending submission and move to the back of the review queue' : '';
         detailShipBtn.style.display = showShipBtn ? 'inline-block' : 'none';
         detailShipBtn.textContent = (inReviewQueue || pendingQueueShipUpdate || canReship) ? 'Ship update' : 'Ship It';
       }
     }
     if (currentDetailData) currentDetailData.blockShipOtherPending = blockShipOtherPending;
     if (detailUnshipBtn) detailUnshipBtn.style.display = canUnship ? 'inline-block' : 'none';
     detailDeleteBtn.style.display = isShipped ? 'none' : 'inline-block';
     detailSaveBtn.style.display = 'none';

     if (lockedAfterShip) {
       if (detailBannerRow) detailBannerRow.style.display = 'flex';
       if (detailGithubRow) detailGithubRow.style.display = 'flex';
       if (detailCodeRow) detailCodeRow.style.display = 'flex';
       if (detailPlayableRow) detailPlayableRow.style.display = 'flex';
       if (detailCodeUrl) detailCodeUrl.readOnly = true;
       if (detailGithubUsername) detailGithubUsername.readOnly = true;
       if (detailDescription) detailDescription.readOnly = true;
     } else {
       if (detailCodeUrl) detailCodeUrl.readOnly = false;
       if (detailGithubUsername) detailGithubUsername.readOnly = false;
       if (detailDescription) detailDescription.readOnly = false;
       if (detailBannerRow) detailBannerRow.style.display = isShipped ? 'none' : 'flex';
       if (detailGithubRow) detailGithubRow.style.display = isShipped ? 'none' : 'flex';
       if (detailCodeRow) detailCodeRow.style.display = isShipped ? 'none' : 'flex';
       if (detailPlayableRow) detailPlayableRow.style.display = 'flex';
     }

     if (detailTitle) {
       detailTitle.readOnly = false;
       detailTitle.classList.toggle('modal-title-input--readonly', false);
     }
     if (detailMainPanel) detailMainPanel.hidden = false;
     
     loadDetailJournalEntries(data.id);

     detailModal.classList.add('active');
     detailModal.setAttribute('aria-hidden', 'false');
     }

   function closeDetailModal() {
     if (!detailModal) return;
     detailModal.classList.remove('active');
     detailModal.setAttribute('aria-hidden', 'true');
   }

   if (detailClose) detailClose.addEventListener('click', closeDetailModal);
   if (detailModal) {
     detailModal.addEventListener('click', function(e) { if (e.target === detailModal) closeDetailModal(); });
   }

   function showSaveBtn() {
     if (!detailSaveBtn || !currentDetailData) return;
     if (currentDetailData.shipped !== 'true' || detailCanEditPlayableBanner()) {
       detailSaveBtn.style.display = 'inline-block';
     }
   }
   if (detailTitle) detailTitle.addEventListener('input', showSaveBtn);
   if (detailDescription) detailDescription.addEventListener('input', showSaveBtn);
   if (detailPlayableUrl) detailPlayableUrl.addEventListener('input', showSaveBtn);
   if (detailGithubUsername) detailGithubUsername.addEventListener('input', showSaveBtn);
   if (detailCodeUrl) detailCodeUrl.addEventListener('input', showSaveBtn);

   function uploadBannerFile(file) {
     if (!file || !file.type.startsWith('image/')) {
       alert('Please select an image file');
       return;
     }
     if (file.size > 10 * 1024 * 1024) {
       alert('File too large (max 10MB)');
       return;
     }
     bannerPlaceholder.innerHTML = '<span class="banner-placeholder-text">Uploading...</span>';
     var formData = new FormData();
     formData.append('file', file);
     fetch('<%= upload_journal_image_path %>', {
       method: 'POST',
       headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
       body: formData
     })
     .then(function(r) { return r.json(); })
     .then(function(data) {
       if (data.url) {
         currentBannerUrl = data.url;
         bannerPreview.src = data.url;
         bannerPreview.style.display = 'block';
         bannerPlaceholder.style.display = 'none';
         showSaveBtn();
       } else {
         alert(data.error || 'Upload failed');
         bannerPlaceholder.innerHTML = '<span class="banner-placeholder-icon">📷</span><span class="banner-placeholder-text">Click or drag & drop a screenshot</span>';
       }
     })
     .catch(function() {
       alert('Upload failed');
       bannerPlaceholder.innerHTML = '<span class="banner-placeholder-icon">📷</span><span class="banner-placeholder-text">Click or drag & drop a screenshot</span>';
     });
   }

   if (bannerUploadArea) {
     bannerUploadArea.addEventListener('click', function() {
       if (detailCanEditPlayableBanner() || (currentDetailData && currentDetailData.shipped !== 'true')) {
         bannerFileInput.click();
       }
     });
     bannerUploadArea.addEventListener('dragover', function(e) {
       e.preventDefault();
       bannerUploadArea.style.borderColor = '#d4a017';
     });
     bannerUploadArea.addEventListener('dragleave', function() {
       bannerUploadArea.style.borderColor = '';
     });
     bannerUploadArea.addEventListener('drop', function(e) {
       e.preventDefault();
       bannerUploadArea.style.borderColor = '';
       if (e.dataTransfer.files.length > 0 && (detailCanEditPlayableBanner() || (currentDetailData && currentDetailData.shipped !== 'true'))) {
         uploadBannerFile(e.dataTransfer.files[0]);
       }
     });
   }
   if (bannerFileInput) {
     bannerFileInput.addEventListener('change', function() {
       if (bannerFileInput.files.length > 0) uploadBannerFile(bannerFileInput.files[0]);
     });
   }

   if (detailSaveBtn) {
     detailSaveBtn.addEventListener('click', function() {
       if (!currentDetailData) return;
       
       var formData = new FormData();
       var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
       formData.append('authenticity_token', csrfToken);
       formData.append('project_index', currentDetailData.index);
       formData.append('project_name', detailTitle.value);
       formData.append('project_description', detailDescription.value);
       formData.append('project_type', currentDetailData.projectType || '');
       formData.append('playable_url', detailPlayableUrl.value);
       formData.append('code_url', detailCodeUrl.value);
       if (detailGithubUsername) formData.append('github_username', detailGithubUsername.value);
       formData.append('banner_url', currentBannerUrl);
       
       var hackatimeProjects = (currentDetailData.hackatimeProjects || '').split(',').filter(function(s) { return s.length > 0; });
       hackatimeProjects.forEach(function(project) {
         formData.append('hackatime_projects[]', project);
       });
       
       fetch('<%= save_project_path %>', {
         method: 'POST',
         body: formData,
         headers: {
           'X-Requested-With': 'XMLHttpRequest'
         }
       })
       .then(function(r) { return r.json(); })
       .then(function(data) {
         if (data.success) {
           var btn = detailSaveBtn;
           btn.textContent = 'Saved!';
           setTimeout(function() {
             btn.textContent = 'Save Changes';
             btn.style.display = 'none';
           }, 1500);
         }
       })
       .catch(function(e) { console.error('Error saving project:', e); });
     });
   }

   if (detailShipBtn) {
     detailShipBtn.addEventListener('click', function() {
       if (!currentDetailData) return;
       if (currentDetailData.blockShipOtherPending) {
         alert(SHIP_BLOCKED_OTHER_PENDING_MSG);
         return;
       }

       var totalShipHrs = parseFloat(currentDetailData.hours || 0, 10) || 0;
       if (totalShipHrs <= 0) {
         alert('You need logged hours (Hackatime + journal) before you can ship.');
         return;
       }
       var pendShip = parseFloat(currentDetailData.pendingReviewHours || 0, 10) || 0;
       if (currentDetailData.shipped === 'true' && currentDetailData.status === 'approved' && pendShip > 0 && currentDetailData.mainHcReshipLocked === 'true') {
         alert('This project has already been submitted to the main HC database - please contact @Emma');
         return;
       }

       var beyondQ = parseFloat(currentDetailData.hoursLoggedBeyondQueueSubmission || 0, 10) || 0;
       if (currentDetailData.shipped === 'true' && currentDetailData.status === 'in-review' && currentDetailData.reviewed !== 'true') {
         if (beyondQ <= 1e-6) {
           alert(SHIP_NEED_HOURS_BEYOND_QUEUE_MSG);
           return;
         }
       }

       if (!detailPlayableUrl.value.trim()) {
         alert('Playable URL is required to ship');
         return;
       }
       if (!detailCodeUrl.value.trim()) {
          alert('Code URL is required to ship');
          return;
        }
        if (!detailGithubUsername || !detailGithubUsername.value.trim()) {
          alert('GitHub username is required to ship');
          return;
        }
        if (!currentBannerUrl) {
          alert('Banner photo is required to ship');
          return;
        }
        
        var hasSaveBtn = detailSaveBtn && detailSaveBtn.style.display !== 'none';
       if (hasSaveBtn) {
         alert('Please click "Save Changes" before shipping your project');
         return;
       }

       var shipNoteEl = document.getElementById('detailShipSubmissionNote');
       var shipNoteTrim = shipNoteEl ? shipNoteEl.value.trim() : '';
       if (!shipNoteTrim) {
         alert('Describe what changed in this submission (Update for reviewers) before shipping.');
         if (shipNoteEl) shipNoteEl.focus();
         return;
       }

       var formData = new FormData();
       formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
       formData.append('project_index', currentDetailData.index);
       formData.append('ship_submission_note', shipNoteTrim);
       
       fetch('<%= ship_project_path %>', {
         method: 'POST',
         body: formData,
         headers: {
           'X-Requested-With': 'XMLHttpRequest'
         }
       })
       .then(function(r) { return r.json(); })
       .then(function(data) {
         if (data.success) {
           closeDetailModal();
           location.reload();
         } else {
           alert('Error: ' + (data.error || 'Unknown error'));
         }
       })
       .catch(function(e) { console.error('Error shipping project:', e); alert('Failed to ship project'); });
     });
   }

   if (detailUnshipBtn) {
     detailUnshipBtn.addEventListener('click', function() {
       if (!currentDetailData) return;
       if (!confirm('Remove this project from the review queue? You can ship it again later.')) return;

       var formData = new FormData();
       formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
       formData.append('project_index', currentDetailData.index);

       fetch('<%= unship_project_path %>', {
         method: 'POST',
         body: formData,
         headers: { 'X-Requested-With': 'XMLHttpRequest' }
       })
       .then(function(r) { return r.json(); })
       .then(function(data) {
         if (data.success) {
           closeDetailModal();
           location.reload();
         } else {
           alert('Error: ' + (data.error || 'Unknown error'));
         }
       })
       .catch(function(e) { console.error('Error removing from queue:', e); alert('Failed to remove from queue'); });
     });
   }

   if (detailJournalBtn) {
     detailJournalBtn.addEventListener('click', function() {
       closeDetailModal();
       if (currentDetailData) {
         openJournalDrawer(currentDetailData);
       }
     });
   }

   if (detailDeleteBtn) {
     detailDeleteBtn.addEventListener('click', function() {
       if (!currentDetailData) return;
       
       if (confirm('Are you sure you want to delete this project? This action cannot be undone.')) {
         var formData = new FormData();
         formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
         formData.append('project_index', currentDetailData.index);
         
         fetch('<%= delete_project_path %>', {
           method: 'DELETE',
           body: formData,
           headers: {
             'X-Requested-With': 'XMLHttpRequest'
           }
         })
         .then(function(r) { return r.json(); })
         .then(function(data) {
           if (data.success) {
             closeDetailModal();
             location.reload();
           } else {
             alert('Error: ' + (data.error || 'Unknown error'));
           }
         })
         .catch(function(e) { console.error('Error deleting project:', e); alert('Failed to delete project'); });
       }
     });
   }

   var emptyCards = Array.from(document.querySelectorAll('.card-slot-empty'));
  var filledCards = Array.from(document.querySelectorAll('.card-slot-filled'));

  emptyCards.forEach(function(card) {
    card.addEventListener('click', function() {
      openProjectModal({ index: '', name: '', description: '', projectType: '', playableUrl: '', codeUrl: '', githubUsername: '', isNew: true });
    });
  });

  filledCards.forEach(function(card) {
    card.addEventListener('click', function() {
      openDetailModal({
        id: card.dataset.projectId,
        index: card.dataset.index,
        name: card.dataset.projectName,
        description: card.dataset.projectDescription,
        projectType: card.dataset.projectType,
        hours: card.dataset.projectHours,
        hackatimeHours: card.dataset.hackatimeHours,
        journalHours: card.dataset.journalHours,
        shipped: card.dataset.projectShipped,
        status: card.dataset.projectStatus || '',
        reviewed: card.dataset.projectReviewed || 'false',
        firstShippedAt: card.dataset.firstShippedAt || '',
        pendingReviewHours: card.dataset.pendingReviewHours || '0',
        unshippedHoursDisplay: card.dataset.unshippedHoursDisplay || '0',
        hoursLoggedBeyondQueueSubmission: card.dataset.hoursLoggedBeyondQueueSubmission || '0',
        reshippable: card.dataset.reshippable || 'false',
        userHasOtherPendingShip: card.dataset.userHasOtherPendingShip || 'false',
        mainHcReshipLocked: card.dataset.mainHcReshipLocked || 'false',
        playableUrl: card.dataset.playableUrl,
        codeUrl: card.dataset.codeUrl,
        githubUsername: card.dataset.githubUsername,
        bannerUrl: card.dataset.bannerUrl,
        hackatimeProjects: card.dataset.hackatimeProjects,
        doubleDip: card.dataset.doubleDip || 'false'
      });
    });
  });

  document.querySelectorAll('.card-double-dip-details').forEach(function(d) {
    d.addEventListener('click', function(e) { e.stopPropagation(); });
  });

  var addBtn = document.getElementById('addProjectBtn');
  if (addBtn) {
    addBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      openProjectModal({ index: '', name: '', description: '', projectType: '', playableUrl: '', codeUrl: '', githubUsername: '', isNew: true });
    });
  }

  var journalDrawer = document.getElementById('journalDrawer');
  var journalDrawerClose = document.getElementById('journalDrawerClose');
  var journalSaveBtn = document.getElementById('journalSaveBtn');
  var journalTimeDone = document.getElementById('journalTimeDone');
  var journalHoursWorked = document.getElementById('journalHoursWorked');
  var journalDescription = document.getElementById('journalDescription');
  var journalToolsUsed = document.getElementById('journalToolsUsed');
  var journalEntriesList = document.getElementById('journalEntriesList');
  var journalProjectTitle = document.getElementById('journalProjectTitle');
  var currentJournalData = null;

  if (journalDescription) setupImageUpload(journalDescription);

  function openJournalDrawer(projectData) {
    if (!journalDrawer) return;
    currentJournalData = projectData;
    journalProjectTitle.textContent = projectData.name + ' - Journal';
    journalTimeDone.value = '';
    journalHoursWorked.value = '';
    journalDescription.value = '';
    journalToolsUsed.value = '';
    
    journalDrawer.classList.add('active');
    journalDrawer.setAttribute('aria-hidden', 'false');
    
    loadJournalEntries(projectData.id);
  }

  function closeJournalDrawer() {
    if (!journalDrawer) return;
    journalDrawer.classList.remove('active');
    journalDrawer.setAttribute('aria-hidden', 'true');
  }

  function loadJournalEntries(projectId) {
    if (!journalEntriesList) return;
    if (projectId == null || projectId === '') {
      journalEntriesList.innerHTML = '<p class="journal-empty">Unable to load journal (refresh the page if this persists).</p>';
      return;
    }
    fetch('/deck/journal_entries/' + encodeURIComponent(projectId))
      .then(function(r) { return r.json(); })
      .then(function(entries) {
        journalEntriesList.innerHTML = '';
        if (entries.length === 0) {
          journalEntriesList.innerHTML = '<p class="journal-empty">No journal entries yet.</p>';
          return;
        }
        entries.forEach(function(entry) {
          var entryEl = document.createElement('div');
          entryEl.className = 'journal-entry';
          var timeStr = entry.time_done ? new Date(entry.time_done).toLocaleDateString() : 'N/A';
          entryEl.innerHTML = '<div class="journal-entry-header">' +
            '<span class="journal-entry-time">' + timeStr + '</span>' +
            '<span class="journal-entry-hours">' + (entry.hours_worked || 0) + ' hrs</span>' +
            '</div>' +
            '<div class="journal-entry-description">' + renderDescription(entry.description) + '</div>' +
                         (entry.tools_used && entry.tools_used.length > 0 ? 
                           '<p class="journal-entry-tools"><strong>Tools:</strong> ' + entry.tools_used.map(escapeHtml).join(', ') + '</p>' : '');
          journalEntriesList.appendChild(entryEl);
        });
      })
      .catch(function(e) { console.error('Failed to load journal entries:', e); });
  }

  if (journalDrawerClose) journalDrawerClose.addEventListener('click', closeJournalDrawer);
  if (journalDrawer) {
    journalDrawer.addEventListener('click', function(e) {
      if (e.target === journalDrawer) closeJournalDrawer();
    });
  }
  
  if (journalSaveBtn) {
    journalSaveBtn.addEventListener('click', function() {
      if (!currentJournalData) return;
      
      var toolsArray = journalToolsUsed.value.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t.length > 0; });
      
      fetch('<%= create_journal_entry_path %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({
          project_index: currentJournalData.index,
          time_done: journalTimeDone.value || new Date().toISOString(),
          hours_worked: parseFloat(journalHoursWorked.value) || 0,
          description: journalDescription.value,
          tools_used: toolsArray
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var entry = data.entry != null ? data.entry : data;
        if (data.project) applyDeckProjectTotalsFromServer(data.project);
        journalTimeDone.value = '';
        journalHoursWorked.value = '';
        journalDescription.value = '';
        journalToolsUsed.value = '';
        loadJournalEntries(entry.project_id || currentJournalData.id);
      })
      .catch(function(e) { console.error('Failed to save journal entry:', e); });
    });
  }

   document.addEventListener('keydown', function(e) {
     if (e.key === 'Escape') {
       closeProjectModal();
       closeDetailModal();
       closeJournalDrawer();
     }
   });

  var overlay = document.getElementById('tutorialOverlay');
  if (overlay) {
    var spotlight = document.getElementById('tutorialSpotlight');
    var tooltip = document.getElementById('tutorialTooltip');
    var tutorialTarget = document.querySelector('.card-slot-empty') || document.querySelector('.card-slot');

    if (tutorialTarget) {
      function positionTutorial() {
        var rect = tutorialTarget.getBoundingClientRect();
        var pad = 16;
        spotlight.style.left = (rect.left - pad) + 'px';
        spotlight.style.top = (rect.top - pad) + 'px';
        spotlight.style.width = (rect.width + pad * 2) + 'px';
        spotlight.style.height = (rect.height + pad * 2) + 'px';
        tooltip.style.left = (rect.left + rect.width / 2) + 'px';
        tooltip.style.top = (rect.top - pad - 16) + 'px';
      }

      function runPositionTutorial() {
        requestAnimationFrame(function() {
          requestAnimationFrame(positionTutorial);
        });
      }
      runPositionTutorial();
      setTimeout(runPositionTutorial, 100);
      window.addEventListener('resize', runPositionTutorial);

      tutorialTarget.addEventListener('click', function handleTutorialClick() {
        overlay.classList.add('tutorial-fade-out');
        document.querySelector('.deck-page').classList.remove('tutorial-active');
        tutorialTarget.removeEventListener('click', handleTutorialClick);
        setTimeout(function() {
          overlay.remove();
          openProjectModal({ index: '', name: '', description: '', projectType: '', playableUrl: '', codeUrl: '', githubUsername: '', hackatimeProjects: '', isNew: true });
        }, 400);
      });
    }
  }
}

var deckInitialized = false;
function safeInitDeck() {
  if (!deckInitialized) {
    deckInitialized = true;
    initDeck();
  }
}

document.addEventListener('turbo:load', safeInitDeck);
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', safeInitDeck);
} else {
  safeInitDeck();
}
</script>
