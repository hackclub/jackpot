<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jackpot" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jackpot">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "pfp_icon.png" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= controller_name %>-body">
    <% if user_signed_in? %>
      <nav class="toolbar">
        <div class="toolbar-bg"></div>
        <div class="toolbar-content">
          <div class="nav-links">
            <%= link_to "Deck", deck_path, class: "nav-item #{'nav-active' if controller_name == 'deck'}" %>
            <%= link_to "Shop", shop_path, class: "nav-item #{'nav-active' if controller_name == 'shop'}" %>
            <%= link_to "FAQ", faq_path, class: "nav-item #{'nav-active' if controller_name == 'home' && action_name == 'faq'}" %>
            <%= link_to "Status", "#", class: "nav-item" %>
            <%= link_to "Leaderboard", leaderboard_path, class: "nav-item #{'nav-active' if controller_name == 'leaderboard'}" %>
            <% if admin? %>
              <%= link_to "Admin", admin_path, class: "nav-item nav-admin" %>
            <% end %>
          </div>
          <div class="toolbar-right">
            <span class="token-count"><%= current_user.chip_am %></span>
            <div class="avatar-chip-wrapper">
              <button class="avatar-chip-btn" id="profileDropdownBtn" type="button">
                <div class="avatar-chip">
                  <%= image_tag(current_user.profile_photo_url || "https://avatars.githubusercontent.com/u/0", alt: current_user.name, class: "avatar-img") %>
                  <div class="avatar-frame"></div>
                </div>
              </button>
              <div class="profile-dropdown" id="profileDropdown" style="display: none;">
                <%= link_to "Sign Out", signout_path, method: :delete, data: { turbo_method: :delete }, class: "dropdown-item" %>
              </div>
            </div>
          </div>
        </div>
      </nav>
    <% else %>
      <% if params[:login] == "1" %>
        <header style="padding: 1rem; margin-bottom: 1rem; display: flex; justify-content: flex-end; align-items: center;">
          <%= button_to "Sign in with Hack Club", "/auth/hack_club",
              method: :post,
              data: { turbo: false },
              style: "padding: 0.5rem 1rem; background: #ec3750; color: white; border-radius: 4px; border: none; cursor: pointer;" %>
        </header>
      <% end %>
    <% end %>

    <% if flash.any? %>
      <div style="padding: 1rem;">
        <% flash.each do |type, message| %>
          <div style="padding: 1rem; margin-bottom: 0.5rem; background: <%= type == 'notice' ? '#d4edda' : '#f8d7da' %>; border-radius: 4px;">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
    
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('profileDropdownBtn');
        const dropdown = document.getElementById('profileDropdown');
        if (btn && dropdown) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
          });
          document.addEventListener('click', function() {
            dropdown.style.display = 'none';
          });
        }
      });
    </script>
  </body>
</html>
