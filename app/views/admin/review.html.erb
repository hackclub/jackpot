<div style="background: linear-gradient(135deg, #1e1410 0%, #2a2015 100%); min-height: 100vh; padding: 2rem; font-family: 'Georgia', 'Times New Roman', serif;">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #1e1410 0%, #2a2015 100%);
      font-family: 'Georgia', 'Times New Roman', serif;
      color: #e8dcc8;
    }

    .review-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .page-title {
      font-size: 2.5rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1rem;
      text-shadow: 1px 2px 3px rgba(0, 0, 0, 0.7);
    }

    .search-bar {
      width: 100%;
      padding: 1rem 1.5rem;
      background: rgba(30, 20, 10, 0.85);
      border: 2px solid #8b6914;
      border-radius: 50px;
      color: #e8dcc8;
      font-size: 0.95rem;
      margin-bottom: 2rem;
      font-family: 'Georgia', serif;
    }

    .search-bar::placeholder {
      color: #8b6914;
    }

    .search-bar-hint {
      font-size: 0.8rem;
      color: #7a7058;
      margin: -1.25rem 0 1.75rem;
      padding-left: 0.25rem;
      font-family: 'Georgia', serif;
    }

    .tabs-row {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem 1.5rem;
      margin-bottom: 2rem;
      border-bottom: 2px solid #8b6914;
      padding-bottom: 0;
    }

    .tabs {
      display: flex;
      gap: 2rem;
      flex: 1;
      min-width: 0;
    }

    .ship-sort-wrap {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
      flex-shrink: 0;
    }

    .ship-sort-label {
      font-size: 0.8rem;
      color: #b0a080;
      font-weight: 600;
      font-family: 'Georgia', serif;
      white-space: nowrap;
    }

    .ship-sort-select {
      padding: 0.45rem 2rem 0.45rem 0.65rem;
      background: rgba(30, 20, 10, 0.9);
      border: 2px solid #8b6914;
      border-radius: 8px;
      color: #e8dcc8;
      font-size: 0.85rem;
      font-family: 'Georgia', serif;
      cursor: pointer;
      min-width: 10.5rem;
    }

    .ship-sort-select:focus {
      outline: none;
      border-color: #d4a017;
    }

    .fraud-filter-wrap,
    .status-filter-wrap {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
      flex-shrink: 0;
    }

    .fraud-filter-label,
    .status-filter-label {
      font-size: 0.8rem;
      color: #b0a080;
      font-weight: 600;
      font-family: 'Georgia', serif;
      white-space: nowrap;
    }

    .fraud-filter-select,
    .status-filter-select {
      padding: 0.45rem 2rem 0.45rem 0.65rem;
      background: rgba(30, 20, 10, 0.9);
      border: 2px solid #8b6914;
      border-radius: 8px;
      color: #e8dcc8;
      font-size: 0.85rem;
      font-family: 'Georgia', serif;
      cursor: pointer;
      min-width: 9rem;
    }

    .status-filter-select {
      min-width: 11rem;
    }

    .fraud-filter-select:focus,
    .status-filter-select:focus {
      outline: none;
      border-color: #d4a017;
    }

    .shipped-stat {
      color: #c8b898;
      font-size: 0.75rem;
      max-width: 11rem;
      text-align: right;
      line-height: 1.25;
    }

    .shipped-stat.muted {
      color: #7a7058;
    }

    .tab-btn {
      padding: 1rem 0;
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      color: #b0a080;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Georgia', serif;
    }

    .tab-btn.active {
      color: #d4a017;
      border-bottom-color: #d4a017;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .project-card {
      background: rgba(30, 20, 10, 0.85);
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      transition: all 0.3s;
      border: 2px solid #8b6914;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .project-card:hover {
      transform: translateY(-4px);
      border-color: #d4a017;
      box-shadow: 0 8px 24px rgba(212, 160, 23, 0.3);
    }

    .project-thumbnail {
      width: 100%;
      height: 180px;
      background: #0B0D17;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #666;
      font-size: 0.85rem;
      overflow: hidden;
    }

    .project-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .project-content {
      padding: 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      border-left: 3px solid #8b6914;
    }

    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      margin-bottom: 0.5rem;
      gap: 1rem;
    }

    .project-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f0e6d2;
      margin: 0;
      flex: 1;
      word-break: break-word;
      font-family: 'Georgia', serif;
    }

    .status-badge {
      background: #8b6914;
      color: #f0e6d2;
      padding: 0.3rem 0.7rem;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      white-space: nowrap;
      font-family: 'Georgia', serif;
    }

    .project-description {
      color: #d0c8b8;
      font-size: 0.85rem;
      margin: 0.8rem 0;
      line-height: 1.4;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .project-tags {
      display: flex;
      gap: 0.5rem;
      margin: 0.8rem 0;
      flex-wrap: wrap;
    }

    .tag {
      display: inline-block;
      padding: 0.4rem 0.8rem;
      background: rgba(139, 105, 20, 0.4);
      color: #e8dcc8;
      border-radius: 16px;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: 'Georgia', serif;
    }

    .project-warning-badge-external {
      display: inline-block;
      padding: 0.4rem 0.85rem;
      background: #b22222;
      color: #fff;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      font-family: 'Georgia', serif;
      letter-spacing: 0.02em;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
    }

    .project-fraud-check-badge {
      display: inline-block;
      padding: 0.4rem 0.85rem;
      background: #c2410c;
      color: #fff;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      font-family: 'Georgia', serif;
      letter-spacing: 0.02em;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
    }

    .project-priority-badge {
      display: inline-block;
      padding: 0.4rem 0.85rem;
      background: #6d28d9;
      color: #ede9fe;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      font-family: 'Georgia', serif;
      letter-spacing: 0.02em;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    }

    /* Same treatment as .project-priority-badge, blue palette */
    .project-reship-badge {
      display: inline-block;
      padding: 0.4rem 0.85rem;
      background: #1d4ed8;
      color: #dbeafe;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      font-family: 'Georgia', serif;
      letter-spacing: 0.02em;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    }

    .project-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid #8b6914;
      font-size: 0.8rem;
    }

    .project-user {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #d0c8b8;
    }

    .user-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #8b6914;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #f0e6d2;
      font-weight: 700;
      font-size: 0.75rem;
    }

    .project-stats {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .stat-badge {
      background: #d4a017;
      color: #1e1410;
      padding: 0.3rem 0.7rem;
      border-radius: 12px;
      font-weight: 600;
      white-space: nowrap;
      font-family: 'Georgia', serif;
    }

    .review-count {
      color: #d0c8b8;
    }

    .empty-state {
      text-align: center;
      padding: 3rem;
      color: #666;
    }

    a {
      text-decoration: none;
      color: inherit;
    }
  </style>

  <div class="review-container">
    <div class="page-header">
      <h1 class="page-title">Project Reviews</h1>
      <%= render "admin/staff_panel_back_link" %>
    </div>

    <input type="text" class="search-bar" placeholder="Search by project title, description, or participant…" id="searchInput" autocomplete="off">
    <p class="search-bar-hint">Includes participant name, email, Slack username, and Hack Club ID.</p>

    <div class="tabs-row">
      <div class="tabs">
        <button type="button" class="tab-btn active" onclick="switchTab('all', this)">All Projects (<%= @all_projects.length %>)</button>
        <button type="button" class="tab-btn" onclick="switchTab('pending', this)">Pending Review (<%= @projects_for_review.length %>)</button>
      </div>
      <div style="display: flex; flex-wrap: wrap; align-items: flex-end; gap: 1rem 1.5rem;">
        <div class="ship-sort-wrap">
          <label class="ship-sort-label" for="shipSortSelect">Ship date</label>
          <select id="shipSortSelect" class="ship-sort-select" aria-label="Sort projects by ship date">
            <option value="asc" <%= "selected" if (@ship_sort || "desc") == "asc" %>>Oldest first</option>
            <option value="desc" <%= "selected" if (@ship_sort || "desc") == "desc" %>>Newest first</option>
          </select>
        </div>
        <div class="status-filter-wrap">
          <label class="status-filter-label" for="statusFilter">Status</label>
          <select id="statusFilter" class="status-filter-select" aria-label="Filter by project status">
            <option value="any">Any status</option>
            <option value="pending">Pending</option>
            <option value="in-review">In review</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
          </select>
        </div>
        <div class="fraud-filter-wrap">
          <label class="fraud-filter-label" for="fraudCheckFilter">Ask fraud check</label>
          <select id="fraudCheckFilter" class="fraud-filter-select" aria-label="Filter by whether Ask fraud check is set">
            <option value="any">Any</option>
            <option value="on">On</option>
            <option value="off">Off</option>
          </select>
        </div>
      </div>
    </div>

    <!-- All Projects Tab -->
    <div id="all" class="tab-content active">
      <% if @all_projects.empty? %>
        <div class="empty-state">
          No projects yet.
        </div>
      <% else %>
        <div class="projects-grid">
          <% @all_projects.each do |item| %>
            <% next if item.nil? || item[:project].nil? %>
            <% project = item[:project] %>
            <% u = item[:user] %>
            <% user_search_blob = [ u&.email, u&.jackpot_profile_name, u&.slack_username, u&.display_name, u&.slack_id, u&.hack_club_id ].compact.map(&:to_s).join(" ").downcase %>
            <a href="<%= admin_review_project_path(project["id"]) %>">
              <div class="project-card" data-fraud-check="<%= project["fraud_check"] ? "true" : "false" %>" data-status="<%= ERB::Util.html_escape((project["status"].presence || "pending").to_s.downcase) %>" data-user-search="<%= ERB::Util.html_escape(user_search_blob) %>">
                <div class="project-thumbnail">
                  <% if project["banner_url"].present? && project["banner_url"].match?(/\Ahttps?:\/\//i) %>
                    <img src="<%= project["banner_url"] %>" alt="<%= project["name"] %>" loading="lazy" decoding="async" fetchpriority="low" width="640" height="180">
                  <% else %>
                    Image could not be loaded
                  <% end %>
                </div>
                <div class="project-content">
                  <div class="project-header">
                    <h3 class="project-title"><%= project["name"] || "Untitled Project" %></h3>
                    <span class="status-badge"><%= project["status"] || "pending" %></span>
                  </div>
                  <p class="project-description"><%= project["description"] || "" %></p>
                  <div class="project-tags">
                    <% if u&.review_queue_priority? %>
                      <span class="project-priority-badge">Priority</span>
                    <% end %>
                    <% if u&.reship_shipping_enabled? || ActiveModel::Type::Boolean.new.cast(project["reship_submission"]) %>
                      <span class="project-reship-badge">Reship</span>
                    <% end %>
                    <% if project["double_dip"] %>
                      <span class="project-warning-badge-external">Project Warning!</span>
                    <% end %>
                    <% if project["fraud_check"] %>
                      <span class="project-fraud-check-badge">Ask fraud check</span>
                    <% end %>
                    <% if project["project_type"].present? %>
                      <span class="tag"><%= project["project_type"] %></span>
                    <% end %>
                  </div>
                  <div class="project-footer">
                    <div class="project-user">
                      <div class="user-avatar"><%= item[:user]&.email&.first&.upcase || "?" %></div>
                      <span><%= item[:user]&.jackpot_profile_name || item[:user]&.email || "Unknown" %></span>
                    </div>
                    <div class="project-stats">
                       <span class="stat-badge"><%= "%.1f" % (project["total_hours"] || project["hours"] || 0).to_f %>h</span>
                       <% shipped_at = project["shipped_at"].presence %>
                       <% shipped_line, shipped_muted = if shipped_at
                            begin
                              t = Time.zone.parse(shipped_at)
                              [ "Shipped #{t.strftime('%b %d, %Y')}", false ]
                            rescue StandardError
                              [ "Shipped (unknown date)", true ]
                            end
                          elsif project["shipped"]
                            [ "Shipped (unknown date)", true ]
                          else
                            [ "Not shipped", true ]
                          end %>
                       <span class="shipped-stat<%= ' muted' if shipped_muted %>" title="<%= shipped_at %>"><%= shipped_line %></span>
                       <span class="review-count">Reviews: 1</span>
                     </div>
                  </div>
                </div>
              </div>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Pending Review Tab -->
    <div id="pending" class="tab-content">
      <% if @projects_for_review.empty? %>
        <div class="empty-state">
          All projects have been reviewed!
        </div>
      <% else %>
        <div class="projects-grid">
          <% @projects_for_review.each do |item| %>
            <% next if item.nil? || item[:project].nil? %>
            <% project = item[:project] %>
            <% u = item[:user] %>
            <% user_search_blob = [ u&.email, u&.jackpot_profile_name, u&.slack_username, u&.display_name, u&.slack_id, u&.hack_club_id ].compact.map(&:to_s).join(" ").downcase %>
            <div class="project-card" data-fraud-check="<%= project["fraud_check"] ? "true" : "false" %>" data-status="<%= ERB::Util.html_escape((project["status"].presence || "pending").to_s.downcase) %>" data-user-search="<%= ERB::Util.html_escape(user_search_blob) %>">
              <a href="<%= admin_review_project_path(project["id"]) %>">
                <div class="project-thumbnail">
                  <% if project["banner_url"].present? && project["banner_url"].match?(/\Ahttps?:\/\//i) %>
                    <img src="<%= project["banner_url"] %>" alt="<%= project["name"] %>" loading="lazy" decoding="async" fetchpriority="low" width="640" height="180">
                  <% else %>
                    Image could not be loaded
                  <% end %>
                </div>
                <div class="project-content">
                  <div class="project-header">
                    <h3 class="project-title"><%= project["name"] || "Untitled Project" %></h3>
                    <span class="status-badge"><%= project["status"] || "pending" %></span>
                  </div>
                  <p class="project-description"><%= project["description"] || "" %></p>
                  <div class="project-tags">
                    <% if u&.review_queue_priority? %>
                      <span class="project-priority-badge">Priority</span>
                    <% end %>
                    <% if u&.reship_shipping_enabled? || ActiveModel::Type::Boolean.new.cast(project["reship_submission"]) %>
                      <span class="project-reship-badge">Reship</span>
                    <% end %>
                    <% if project["double_dip"] %>
                      <span class="project-warning-badge-external">Project Warning!</span>
                    <% end %>
                    <% if project["fraud_check"] %>
                      <span class="project-fraud-check-badge">Ask fraud check</span>
                    <% end %>
                    <% if project["project_type"].present? %>
                      <span class="tag"><%= project["project_type"] %></span>
                    <% end %>
                  </div>
                  <div class="project-footer">
                    <div class="project-user">
                      <div class="user-avatar"><%= item[:user]&.email&.first&.upcase || "?" %></div>
                      <span><%= item[:user]&.jackpot_profile_name || item[:user]&.email || "Unknown" %></span>
                    </div>
                    <div class="project-stats">
                      <span class="stat-badge"><%= "%.1f" % (project["total_hours"] || project["hours"] || 0) %>h</span>
                      <% shipped_at = project["shipped_at"].presence %>
                      <% shipped_line, shipped_muted = if shipped_at
                           begin
                             t = Time.zone.parse(shipped_at)
                             [ "Shipped #{t.strftime('%b %d, %Y')}", false ]
                           rescue StandardError
                             [ "Shipped (unknown date)", true ]
                           end
                         elsif project["shipped"]
                           [ "Shipped (unknown date)", true ]
                         else
                           [ "Not shipped", true ]
                         end %>
                      <span class="shipped-stat<%= ' muted' if shipped_muted %>" title="<%= shipped_at %>"><%= shipped_line %></span>
                      <span class="review-count">Reviews: 1</span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
            <% end %>
          </div>
        <% end %>
    </div>

  <script>
    function switchTab(tabName, evtOrElement) {
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
      });
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      document.getElementById(tabName).classList.add('active');
      var activeButton = null;
      if (evtOrElement instanceof Event && evtOrElement.target) {
        activeButton = evtOrElement.target;
      } else if (evtOrElement && evtOrElement.nodeType === 1) {
        // A DOM element was passed directly (e.g., switchTab('all', this))
        activeButton = evtOrElement;
      } else if (typeof event !== 'undefined' && event && event.target) {
        // Backwards-compatible fallback for browsers exposing a global event
        activeButton = event.target;
      }
      if (activeButton) {
        activeButton.classList.add('active');
      }
    }

    function applyReviewFilters() {
      const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
      const fraudMode = document.getElementById('fraudCheckFilter').value;
      const statusMode = document.getElementById('statusFilter').value;
      document.querySelectorAll('.project-card').forEach(card => {
        const title = card.querySelector('.project-title').textContent.toLowerCase();
        const desc = card.querySelector('.project-description').textContent.toLowerCase();
        const userBlob = (card.getAttribute('data-user-search') || '').toLowerCase();
        const fraudOn = card.getAttribute('data-fraud-check') === 'true';
        const cardStatus = (card.getAttribute('data-status') || 'pending').toLowerCase();
        const matchSearch = !searchTerm ||
          title.includes(searchTerm) ||
          desc.includes(searchTerm) ||
          userBlob.includes(searchTerm);
        let matchFraud = true;
        if (fraudMode === 'on') matchFraud = fraudOn;
        else if (fraudMode === 'off') matchFraud = !fraudOn;
        let matchStatus = true;
        if (statusMode !== 'any') matchStatus = cardStatus === statusMode;
        const hideTarget = card.parentElement && card.parentElement.tagName === 'A' ? card.parentElement : card;
        hideTarget.style.display = (matchSearch && matchFraud && matchStatus) ? '' : 'none';
      });
    }

    document.getElementById('searchInput').addEventListener('input', applyReviewFilters);
    document.getElementById('fraudCheckFilter').addEventListener('change', applyReviewFilters);
    document.getElementById('statusFilter').addEventListener('change', applyReviewFilters);

    document.getElementById('shipSortSelect').addEventListener('change', function() {
      const base = '<%= admin_review_path %>';
      window.location.assign(base + (base.indexOf('?') >= 0 ? '&' : '?') + 'ship_sort=' + encodeURIComponent(this.value));
    });
  </script>
</div>
