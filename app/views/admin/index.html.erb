<% content_for(:title) { "Admin Panel" } %>

<div class="admin-page">
  <div class="admin-content">
    <h1>Admin Panel</h1>

    <div class="admin-links">
      <%= link_to admin_stats_path, class: "admin-link" do %>
        <span class="admin-link-icon"></span>
        <div>
          Platform Statistics
          <span class="admin-link-desc">Overview of projects, hours, users, and shop activity</span>
        </div>
      <% end %>

      <%= link_to admin_review_path, class: "admin-link" do %>
        <span class="admin-link-icon">📋</span>
        <div>
          Project Review
          <span class="admin-link-desc">Review shipped projects and approve hours</span>
        </div>
      <% end %>

      <%= link_to admin_shop_path, class: "admin-link" do %>
        <span class="admin-link-icon">🛒</span>
        <div>
          Shop Admin
          <span class="admin-link-desc">Manage catalog, categories, and pricing</span>
        </div>
      <% end %>

      <%= link_to admin_shop_orders_path, class: "admin-link" do %>
        <span class="admin-link-icon">📦</span>
        <div>
          Shop orders
          <span class="admin-link-desc">Fulfillment queue, group by user or item, refunds</span>
        </div>
      <% end %>

      <%= link_to admin_items_request_path, class: "admin-link" do %>
        <span class="admin-link-icon">📝</span>
        <div>
          Items Request
          <span class="admin-link-desc">View Exchange Desk item requests</span>
        </div>
      <% end %>

      <%= link_to "/admin/blazer", class: "admin-link" do %>
        <span class="admin-link-icon">🔍</span>
        <div>
          Blazer
          <span class="admin-link-desc">Database queries and dashboards</span>
        </div>
      <% end %>

      <%= link_to "/admin/flipper", class: "admin-link" do %>
        <span class="admin-link-icon">🚩</span>
        <div>
          Flipper
          <span class="admin-link-desc">Feature flags</span>
        </div>
      <% end %>

      <%= link_to "/admin/jobs", class: "admin-link" do %>
        <span class="admin-link-icon">⚙️</span>
        <div>
          Solid Queue
          <span class="admin-link-desc">Background job queue</span>
        </div>
      <% end %>

      <%= link_to admin_airtable_sync_path, class: "admin-link" do %>
        <span class="admin-link-icon"></span>
        <div>
          Airtable Sync
          <span class="admin-link-desc">Sync status, logs, and diagnostics</span>
        </div>
      <% end %>

      <%= link_to admin_console_path, class: "admin-link" do %>
        <span class="admin-link-icon">💎</span>
        <div>
          Ruby Console
          <span class="admin-link-desc">Execute Ruby code on the server</span>
        </div>
      <% end %>
    </div>

    <div class="admin-silly">
      <pre>
(\_/)
(o.o)
(> <)
      </pre>
      <p class="admin-emojis">🦄🌈🔮💎🎪🎭🎨🎬🎤🎧🎼🎹🥁🎷🎺🎸🪕🎻🎲🎯🎳🎮🎰🎱🔮💎🌈🦄</p>
      <p class="admin-tagline">sillies be upon ye</p>
    </div>
  </div>
</div>
