<% content_for(:title) { "Users — Admin" } %>

<div class="admin-page">
  <div class="admin-content admin-content--wide">
    <h1>Users</h1>

    <p style="margin: 0 0 1rem;">
      <%= link_to "← Admin home", admin_path, class: "admin-link-inline" %>
    </p>

    <p class="admin-users-lead">
      Participant, role, wallet and lifetime chips, approved and logged hours, shop order USD (pending + fulfilled, and fulfilled-only), last sign-in. Search and label filter (Priority / Reship flags from super-admin settings) narrow the table; sort reorders rows. Open a participant for their project list and (super-admin) internal notes.
    </p>

    <div class="admin-users-export">
      <%= form_with url: admin_users_path, method: :get, local: true, class: "admin-users-export-form", data: { turbo: false } do %>
        <%= hidden_field_tag :format, "csv" %>
        <span class="admin-users-export-title">Export CSV</span>
        <label class="admin-users-export-label" for="exportFilter">Include</label>
        <select name="filter" id="exportFilter" class="admin-users-export-select" aria-label="Rows to include in CSV export">
          <option value="all" <%= "selected" if (@export_filter || "all") == "all" %>>Everyone</option>
          <option value="with_chips" <%= "selected" if @export_filter == "with_chips" %>>With bolts (&gt; 0)</option>
          <option value="have_or_had_chips" <%= "selected" if @export_filter == "have_or_had_chips" %>>Have or had bolts</option>
          <option value="without_chips" <%= "selected" if @export_filter == "without_chips" %>>No bolts (0)</option>
          <option value="with_projects" <%= "selected" if @export_filter == "with_projects" %>>Has at least one project</option>
          <option value="without_projects" <%= "selected" if @export_filter == "without_projects" %>>No projects</option>
        </select>
        <%= submit_tag "Download .csv", class: "admin-users-export-btn" %>
      <% end %>
      <p class="admin-users-export-hint">Export matches the table columns (plus id, email, and raw timestamps). Filters apply only to the download, not the on-page list.</p>
    </div>

    <% if @users.any? %>
    <div class="admin-users-toolbar admin-users-toolbar--split">
      <input type="search" id="adminUsersSearch" class="admin-users-search" placeholder="Search by name, email, Hack Club ID, Slack…" autocomplete="off" aria-label="Filter users">
      <div class="admin-users-toolbar-filters">
        <div class="admin-users-filter-wrap">
          <label class="admin-users-sort-label" for="adminUsersLabelFilter">Label</label>
          <select id="adminUsersLabelFilter" class="admin-users-sort-select admin-users-label-filter-select" aria-label="Filter users by Priority or Reship label">
            <option value="any" selected>Any label</option>
            <option value="priority">Priority</option>
            <option value="reship">Reship</option>
            <option value="both">Priority &amp; Reship</option>
          </select>
        </div>
        <div class="admin-users-sort-wrap">
          <label class="admin-users-sort-label" for="adminUsersSort">Sort by</label>
          <select id="adminUsersSort" class="admin-users-sort-select" aria-label="Sort users">
          <option value="created_desc" selected>Newest first</option>
          <option value="created_asc">Oldest first</option>
          <option value="name_asc">Name A–Z</option>
          <option value="name_desc">Name Z–A</option>
          <option value="chips_desc">Current bolts (high → low)</option>
          <option value="chips_asc">Current bolts (low → high)</option>
          <option value="total_chips_desc">Total bolts ever (high → low)</option>
          <option value="total_chips_asc">Total bolts ever (low → high)</option>
          <option value="approved_h_desc">Approved hours (high → low)</option>
          <option value="approved_h_asc">Approved hours (low → high)</option>
          <option value="logged_h_desc">Logged hours (high → low)</option>
          <option value="logged_h_asc">Logged hours (low → high)</option>
          <option value="shop_usd_tot_desc">Shop $ total (pending + fulfilled, high → low)</option>
          <option value="shop_usd_tot_asc">Shop $ total (pending + fulfilled, low → high)</option>
          <option value="shop_usd_fulfilled_desc">Shop $ fulfilled (high → low)</option>
          <option value="shop_usd_fulfilled_asc">Shop $ fulfilled (low → high)</option>
          <option value="last_sign_desc">Last sign-in (newest)</option>
          <option value="last_sign_asc">Last sign-in (oldest)</option>
          </select>
        </div>
      </div>
    </div>

    <div class="admin-users-table-wrap">
      <table class="admin-users-table">
        <thead>
          <tr>
            <th>Participant</th>
            <th>Role</th>
            <th class="admin-users-num" title="Wallet balance">Current</th>
            <th class="admin-users-num" title="Lifetime bolts awarded on approved projects">Total (ever)</th>
            <th class="admin-users-num" title="Sum of approved hours on approved projects">Approved h</th>
            <th class="admin-users-num" title="Hackatime hours on all projects plus journal hours">Logged h</th>
            <th class="admin-users-num" title="USD at checkout: pending + fulfilled orders (not refunded)">$ total orders</th>
            <th class="admin-users-num" title="USD at checkout: fulfilled (sent) orders only">$ fulfilled</th>
            <th>Last sign-in</th>
            <th>Profile</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <% m = user.admin_user_row_metrics %>
            <% search_blob = [ user.email, user.jackpot_profile_name, user.hack_club_id, user.slack_username, user.slack_id, user.display_name ].compact.map(&:to_s).join(" ").downcase %>
            <tr
              data-user-search="<%= ERB::Util.html_escape(search_blob) %>"
              data-user-priority="<%= user.review_queue_priority? ? "true" : "false" %>"
              data-user-reship="<%= user.reship_shipping_enabled? ? "true" : "false" %>"
              data-sort-created="<%= user.created_at.to_i %>"
              data-sort-name="<%= ERB::Util.html_escape(user.jackpot_profile_name.to_s.downcase) %>"
              data-sort-chips="<%= user.chip_am.to_f %>"
              data-sort-total-chips="<%= m[:total_chips_ever] %>"
              data-sort-approved-h="<%= m[:total_approved_hours] %>"
              data-sort-logged-h="<%= m[:total_logged_hours] %>"
              data-sort-shop-usd-tot="<%= m[:shop_usd_pending_and_fulfilled] %>"
              data-sort-shop-usd-fulfilled="<%= m[:shop_usd_fulfilled] %>"
              data-sort-last-sign="<%= user.last_sign_in_at ? user.last_sign_in_at.to_i : 0 %>"
            >
              <td class="admin-users-participant">
                <%= link_to admin_user_path(user), class: "admin-users-profile-link" do %>
                  <span class="admin-users-name"><%= user.jackpot_profile_name %></span>
                <% end %>
                <span class="admin-users-email"><%= user.email %></span>
                <% if user.hack_club_id.present? %>
                  <span class="admin-users-meta">HC ID: <%= user.hack_club_id %></span>
                <% end %>
                <% if user.slack_username.present? %>
                  <span class="admin-users-meta">@<%= user.slack_username %></span>
                <% end %>
              </td>
              <td><span class="admin-users-role admin-users-role--<%= user.role %>"><%= user.role.to_s.humanize %></span></td>
              <td class="admin-users-num"><%= number_with_precision(user.chip_am.to_f, precision: 1) %></td>
              <td class="admin-users-num"><%= number_with_precision(m[:total_chips_ever], precision: 1) %></td>
              <td class="admin-users-num"><%= number_with_precision(m[:total_approved_hours], precision: 1) %></td>
              <td class="admin-users-num"><%= number_with_precision(m[:total_logged_hours], precision: 1) %></td>
              <td class="admin-users-num"><%= number_to_currency(m[:shop_usd_pending_and_fulfilled], precision: 0) %></td>
              <td class="admin-users-num"><%= number_to_currency(m[:shop_usd_fulfilled], precision: 0) %></td>
              <td class="admin-users-date"><%= user.last_sign_in_at ? user.last_sign_in_at.strftime("%b %d, %Y") : "—" %></td>
              <td><%= link_to "View", admin_user_path(user), class: "admin-link-inline" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% else %>
      <p class="admin-users-empty">No users yet.</p>
    <% end %>
  </div>
</div>

<% if @users.any? %>
<script>
  (function() {
    var input = document.getElementById('adminUsersSearch');
    var labelFilter = document.getElementById('adminUsersLabelFilter');
    var sortSelect = document.getElementById('adminUsersSort');
    var tbody = document.querySelector('.admin-users-table tbody');
    if (!tbody) return;

    var SORT_KEY_ATTR = {
      created: 'data-sort-created',
      name: 'data-sort-name',
      chips: 'data-sort-chips',
      total_chips: 'data-sort-total-chips',
      approved_h: 'data-sort-approved-h',
      logged_h: 'data-sort-logged-h',
      shop_usd_tot: 'data-sort-shop-usd-tot',
      shop_usd_fulfilled: 'data-sort-shop-usd-fulfilled',
      last_sign: 'data-sort-last-sign'
    };

    function parseSort(val) {
      var m = val.match(/^(.+)_(asc|desc)$/);
      if (!m) return { key: 'created', desc: true };
      return { key: m[1], desc: m[2] === 'desc' };
    }

    function sortRows() {
      var sel = sortSelect.value;
      var p = parseSort(sel);
      var attr = SORT_KEY_ATTR[p.key] || SORT_KEY_ATTR.created;
      var mult = p.desc ? -1 : 1;
      var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
      rows.sort(function(a, b) {
        var av = a.getAttribute(attr) || '';
        var bv = b.getAttribute(attr) || '';
        if (attr === 'data-sort-name') {
          return mult * av.localeCompare(bv);
        }
        var an = parseFloat(av, 10);
        var bn = parseFloat(bv, 10);
        if (!isNaN(an) && !isNaN(bn)) return mult * (an - bn);
        return mult * String(av).localeCompare(String(bv));
      });
      rows.forEach(function(r) { tbody.appendChild(r); });
    }

    function filterUsers() {
      var q = input.value.toLowerCase().trim();
      var labelVal = labelFilter ? labelFilter.value : 'any';
      tbody.querySelectorAll('tr').forEach(function(tr) {
        var blob = (tr.getAttribute('data-user-search') || '').toLowerCase();
        var priority = tr.getAttribute('data-user-priority') === 'true';
        var reship = tr.getAttribute('data-user-reship') === 'true';
        var matchSearch = !q || blob.indexOf(q) !== -1;
        var matchLabel = true;
        if (labelVal === 'priority') matchLabel = priority;
        else if (labelVal === 'reship') matchLabel = reship;
        else if (labelVal === 'both') matchLabel = priority && reship;
        tr.style.display = (matchSearch && matchLabel) ? '' : 'none';
      });
    }

    input.addEventListener('input', filterUsers);
    if (labelFilter) labelFilter.addEventListener('change', filterUsers);
    sortSelect.addEventListener('change', sortRows);
  })();
</script>
<% end %>
