<style>
@font-face {
  font-family: "Katibeh";
  src: url(<%= asset_path "Katibeh/Katibeh-Regular.ttf" %>) format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

:root {
  --first-section-height: 56.25vw;
  --content-width: min(92vw, 1024px);
  --content-width-narrow: min(88vw, 760px);
  --cream: #efe394;
  --cream-soft: #f1dfc5;
  --brown: #6b2218;
  --brown-dark: #43110e;
}

@media (max-aspect-ratio: 1/1) {
  :root {
    --first-section-height: 100vw;
  }
}

html {
  overflow-x: hidden;
  -webkit-text-size-adjust: 100%;
}

body {
  margin: 0;
  padding: 0;
  min-height: max(100vh, 500vw);
  min-height: max(100dvh, 500vw);
  width: 100%;
  max-width: 100vw;
  box-sizing: border-box;
  overflow-x: hidden;
  background: #000;
  color: #fff8ec;
}

.main,
.main * {
  box-sizing: border-box;
}

.main {
  position: relative;
  width: 100%;
  max-width: 100vw;
}

.page-section--hero {
  position: relative;
  height: var(--first-section-height);
  min-height: var(--first-section-height);
  margin: 0;
  background: url(<%= image_path "first_bkg.jpg" %>) no-repeat top center #000;
  background-size: 100% auto;
}

.hero-overlays {
  position: absolute;
  inset: 0;
  pointer-events: none;
  transform: translateY(2vh);
  max-width: 100vw;
  overflow: hidden;
}

.hero-title {
  position: absolute;
  left: 50%;
  top: clamp(-76vh, -3vh, 20vh);
  transform: translateX(-50%) rotate(3deg);
  max-width: min(85vw, 580px);
  width: clamp(280px, 44vw, 580px);
  height: auto;
  filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35));
  animation: title-flicker 4.5s infinite steps(1, end);
}

.hero-title::after {
  content: "";
  position: absolute;
  inset: -8px;
  pointer-events: none;
  background: linear-gradient(75deg, rgba(255, 240, 180, 0) 0%, rgba(255, 240, 180, 0) 35%, rgba(255, 240, 180, 0.45) 50%, rgba(255, 240, 180, 0) 65%, rgba(255, 240, 180, 0) 100%);
  mix-blend-mode: screen;
  transform: translateX(-160%);
  animation: title-sheen 5.75s infinite;
}

.hero-center {
  position: absolute;
  left: 50%;
  top: clamp(-28vh, 9vh, 42vh);
  transform: translateX(-51%);
  max-width: min(92vw, 1200px);
  width: clamp(520px, 200vw, 1210px);
  height: auto;
  filter:
    drop-shadow(0 0 18px rgba(255, 230, 170, 0.35))
    drop-shadow(0 0 48px rgba(255, 170, 60, 0.22));
  animation: center-glow 2.8s ease-in-out infinite;
}

@keyframes title-sheen {
  0%   { transform: translateX(-160%); opacity: 0; }
  12%  { transform: translateX(160%); opacity: 1; }
  100% { transform: translateX(160%); opacity: 0; }
}

@keyframes title-flicker {
  0%, 87%, 100% { filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35)) brightness(1); }
  88%           { filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35)) brightness(0.8); }
  89%           { filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.55)) brightness(1.2); }
  90%           { filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.3)) brightness(0.9); }
  92%           { filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.6)) brightness(1.25); }
}

@keyframes center-glow {
  0%, 100% {
    filter:
      drop-shadow(0 0 16px rgba(255, 230, 170, 0.28))
      drop-shadow(0 0 40px rgba(255, 170, 60, 0.15))
      brightness(1);
  }
  50% {
    filter:
      drop-shadow(0 0 32px rgba(255, 240, 190, 0.55))
      drop-shadow(0 0 80px rgba(255, 180, 70, 0.35))
      brightness(1.08);
  }
}

.hero-logo-link {
  position: absolute;
  top: 0;
  left: 50px;
  pointer-events: auto;
  display: block;
  line-height: 0;
}

.hero-logo {
  width: clamp(100px, 22vw, 180px);
  height: auto;
  display: block;
}

.hero-dateline-stack {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: calc(135px + 10vh);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  max-width: min(92vw, 640px);
  width: 100%;
  pointer-events: none;
}

.hero-event-warning {
  pointer-events: auto;
  margin: 0;
  padding: 0;
  max-width: 100%;
  text-align: left;
  font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
  overflow: hidden;
  border-radius: 6px;
  border: 3px solid #f5c400;
  outline: 2px solid #0a0a0a;
  box-shadow:
    0 0 0 1px rgba(245, 196, 0, 0.5),
    0 6px 28px rgba(0, 0, 0, 0.75),
    0 0 40px rgba(245, 196, 0, 0.35);
  animation: hero-warning-glow 1.8s ease-in-out infinite;
}

.hero-event-warning__hazard {
  height: 11px;
  background: repeating-linear-gradient(
    -45deg,
    #0a0a0a,
    #0a0a0a 8px,
    #f5c400 8px,
    #f5c400 16px
  );
  background-size: 22.63px 11px;
  animation: hero-hazard-marquee 0.9s linear infinite;
}

