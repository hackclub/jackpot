<div class="main">
  <section class="page-section page-section--hero ext-section--0" id="section-0">
      <%= link_to image_tag("HC_logo.png", alt: "Hack Club Logo", class: "hero-logo"), "https://hackclub.com", class: "hero-logo-link" %>
    <div class="hero-overlays">
      <%= image_tag "title.PNG", alt: "Jackpot Title", class: "hero-title" %>
      <%= image_tag "centralmg.png", alt: "Center Art", class: "hero-center" %>
      <div class="hero-dateline-stack">
        <div class="hero-event-warning" role="alert">
          <div class="hero-event-warning__hazard" aria-hidden="true"></div>
          <div class="hero-event-warning__inner">
            <span class="hero-event-warning__icon" aria-hidden="true">!</span>
            <div class="hero-event-warning__copy">
              <p class="hero-event-warning__banner">Warning — event update</p>
              <p class="hero-event-warning__text">
                <strong class="hero-event-warning__strong">Important:</strong> The in-person event will no longer take place. The online program remains active.<br>
                More info <%= link_to "HERE", "https://hackclub.slack.com/archives/C0ADEGZL5HD/p1774043876004439", target: "_blank", rel: "noopener noreferrer", class: "hero-event-warning__link" %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%= render "home/rsvp" %>
  </section>

  <div id="steps" class="ext-content">
    <div class="ext-content__lighty-line--top"></div>
    <%# Section 1: How does it work %>
    <section class="ext-section ext-section--1">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_1.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--1">
        <h2 class="section-title section-title--center">How does it work</h2>
        <div class="section-1__panel">
          <%= image_tag "RSVP_comp/first_section/yellow_box.png", alt: "", class: "section-1__panel-bg", aria: { hidden: true } %>
          <div class="section-1__panel-content">
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon1_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">Work on a <span class="section-1__step-accent">software/hardware/art</span> project and track your time with <%= link_to "Hackatime", "https://hackatime.hackclub.com", target: "_blank", rel: "noopener", class: "section-1__step-accent section-1__step-link" %>.</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon2_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">Post your project on <%= link_to "GitHub", "https://github.com", target: "_blank", rel: "noopener", class: "section-1__step-accent section-1__step-link" %> as an open-source project and ship it on the <span class="section-1__step-accent">Jackpot website</span>.</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon3_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">Wait for a <span class="section-1__step-accent">review</span> from our team and redeem poker chips (<span class="section-1__step-accent">points</span>).</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon4_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">Spend your points on <span class="section-1__step-accent">free prizes</span> or use them to get an official invitation to the <span class="section-1__step-accent section-1__step-accent--yellow">Las Vegas Hackathon</span>.</p>
            </div>
          </div>
        </div>
        <div class="section-1__join-wrap">
          <%= button_to "/auth/hack_club", method: :post, data: { turbo: false }, class: "section-1__join-link" do %>
            <%= image_tag "RSVP_comp/first_section/join_button.png", alt: "Join", class: "section-1__join-btn" %>
          <% end %>
        </div>
        <div class="section-1__carousel-wrap">
          <%= image_tag "RSVP_comp/first_section/subtitle_carousel.png", alt: "", class: "section-1__carousel-subtitle", aria: { hidden: true } %>
          <div class="section-1__carousel">
          <div class="section-1__carousel-viewport">
            <div class="section-1__carousel-track">
              <% carousel_images = [
                "RSVP_comp/first_section/shop_items_carousel/cloud Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/console.png",
                "RSVP_comp/first_section/shop_items_carousel/drone.png",
                "RSVP_comp/first_section/shop_items_carousel/ebook Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/gpu.png",
                "RSVP_comp/first_section/shop_items_carousel/headp Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/ipad.png",
                "RSVP_comp/first_section/shop_items_carousel/mac Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/mic Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/monitor Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/mouse Background Removed.png",
                "RSVP_comp/first_section/shop_items_carousel/rasp.png"
              ] %>
              <% (carousel_images + carousel_images).each do |img_path| %>
                <div class="section-1__carousel-box">
                  <%= image_tag "RSVP_comp/first_section/carousel_box.png", alt: "", class: "section-1__carousel-box-bg", aria: { hidden: true } %>
                  <%= image_tag img_path, alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
                </div>
              <% end %>
            </div>
          </div>
          </div>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 2: About Hack Club / Jackpot Trailer %>
    <section class="ext-section ext-section--2">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_2.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--2">
        <div class="section-2__about">
          <%= link_to "https://hackclub.com", target: "_blank", rel: "noopener noreferrer", class: "section-2__about-link" do %>
            <%= image_tag "RSVP_comp/second_section/hackclub_box.png", alt: "About Hack Club", class: "section-2__hackclub-box" %>
          <% end %>
        </div>
        <div class="section-2__trailer">
          <%= link_to "https://www.youtube.com/watch?v=4pV9bcxCTDo", target: "_blank", rel: "noopener", class: "section-2__trailer-link" do %>
            <%= image_tag "RSVP_comp/second_section/jackpottrailer_box.png", alt: "Jackpot Trailer", class: "section-2__trailer-box" %>
          <% end %>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 3: You can create EVERYTHING! %>
    <section class="ext-section ext-section--3">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_3.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--3">
        <div class="section-3__title-row">
          <%= image_tag "RSVP_comp/third_section/card_draw.png", alt: "", class: "section-3__title-card-draw", aria: { hidden: true } %>
          <%= image_tag "RSVP_comp/third_section/title_section_3.png", alt: "You can create everything", class: "section-3__title-image" %>
        </div>
        <div class="section-3__cards">
          <%= image_tag "RSVP_comp/third_section/prj_card_1.png", alt: "Project card", class: "section-3__prj-card" %>
          <%= image_tag "RSVP_comp/third_section/prj_card_2.png", alt: "Project card", class: "section-3__prj-card" %>
          <%= image_tag "RSVP_comp/third_section/prj_card_3.png", alt: "Project card", class: "section-3__prj-card" %>
        </div>
        <%= link_to image_tag("RSVP_comp/third_section/seeMoreButton.png", alt: "See your projects", class: "section-3__see-more"), "https://scrapbook.hackclub.com/", target: "_blank", rel: "noopener", class: "section-3__see-more-link" %>
        <div class="section-3__where-start">
          <%= image_tag "RSVP_comp/third_section/where_to_start_box.png", alt: "Get started", class: "section-3__where-start-box" %>
          <div class="section-3__where-start-content">
            <a class="section-3__where-start-item" href="https://workshops.hackclub.com/personal_website/" target="_blank" rel="noopener">
              <span class="section-3__where-start-label"><span class="section-3__where-start-symbol">♧</span> Personal website</span>
              <span class="section-3__where-start-url">https://workshops.hackclub.com/personal_website/</span>
            </a>
            <a class="section-3__where-start-item" href="https://workshops.hackclub.com/particle_physics/" target="_blank" rel="noopener">
              <span class="section-3__where-start-label"><span class="section-3__where-start-symbol">♧</span> Particle Physics simulation</span>
              <span class="section-3__where-start-url">https://workshops.hackclub.com/particle_physics/</span>
            </a>
            <a class="section-3__where-start-item" href="https://boba.hackclub.com/" target="_blank" rel="noopener">
              <span class="section-3__where-start-label"><span class="section-3__where-start-symbol">♧</span> Boba Drops - make a website!</span>
              <span class="section-3__where-start-url">https://boba.hackclub.com/</span>
            </a>
          </div>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 4: Past Events %>
    <section class="ext-section ext-section--4">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_4.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--4">
        <%= image_tag "RSVP_comp/fourth_section/title_section_4.png", alt: "Past Events", class: "section-4__title-image" %>
        <div class="section-5__intro">
          <%= link_to "https://emmaborghi.tech/", target: "_blank", rel: "noopener noreferrer", class: "section-5__emma-box-link" do %>
            <%= image_tag "RSVP_comp/fourth_section/emma_box.png", alt: "Past events intro", class: "section-5__emma-box" %>
          <% end %>
        </div>
        <div class="section-5__events">
          <div class="section-5__event section-5__event--juice">
            <%= link_to "https://www.youtube.com/watch?v=fuTlToZ1SX8&t=2s&pp=ygUPaGFjayBjbHViIGp1aWNl", target: "_blank", rel: "noopener noreferrer", class: "section-5__event-img-link" do %>
              <%= image_tag "RSVP_comp/fourth_section/juice_img.png", alt: "Juice event", class: "section-5__event-img" %>
            <% end %>
            <%= image_tag "RSVP_comp/fourth_section/juice_txt.png", alt: "Juice", class: "section-5__event-txt" %>
          </div>
          <div class="section-5__event section-5__event--moonshot">
            <%= image_tag "RSVP_comp/fourth_section/moonshot_txt.png", alt: "Moonshot", class: "section-5__event-txt" %>
            <%= link_to "https://moonshot.hackclub.com/", target: "_blank", rel: "noopener noreferrer", class: "section-5__event-img-link" do %>
              <%= image_tag "RSVP_comp/fourth_section/moonshot_img.png", alt: "Moonshot event", class: "section-5__event-img" %>
            <% end %>
          </div>
          <div class="section-5__event section-5__event--overglade">
            <%= link_to "https://overglade.hackclub.com/", target: "_blank", rel: "noopener noreferrer", class: "section-5__event-img-link" do %>
              <%= image_tag "RSVP_comp/fourth_section/overglade_img.png", alt: "Overglade event", class: "section-5__event-img" %>
            <% end %>
            <%= image_tag "RSVP_comp/fourth_section/overglade_txt.png", alt: "Overglade", class: "section-5__event-txt" %>
          </div>
        </div>
        <%= link_to image_tag("RSVP_comp/fourth_section/seeMoreHackathonsButton.png", alt: "See more hackathons", class: "section-5__see-more"), "https://hackclub.com/hackathons/", target: "_blank", rel: "noopener noreferrer", class: "section-5__see-more-link" %>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 5: Info / Footer %>
    <section class="ext-section ext-section--5">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_5.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--5">
        <h2 class="section-title section-title--center section-title--info">info</h2>
        <div class="section-6__cards">
          <div class="section-6__comm-buttons">
            <%= link_to "https://hackclub.enterprise.slack.com/archives/C0AEQ8ZJ7EU", target: "_blank", rel: "noopener noreferrer", class: "section-6__card-link" do %>
              <%= image_tag "RSVP_comp/fifth_section/joinComm_box/communityCard_1.png", alt: "Ask a question", class: "section-6__comm-card", aria: { hidden: true } %>
            <% end %>
            <%= link_to "https://hackclub.enterprise.slack.com/archives/C0ADEGZL5HD", target: "_blank", rel: "noopener noreferrer", class: "section-6__card-link" do %>
              <%= image_tag "RSVP_comp/fifth_section/joinComm_box/communityCard_2.png", alt: "Updates and News", class: "section-6__comm-card", aria: { hidden: true } %>
            <% end %>
            <%= link_to "https://hackclub.enterprise.slack.com/archives/C0AEQ8VAPA4", target: "_blank", rel: "noopener noreferrer", class: "section-6__card-link" do %>
              <%= image_tag "RSVP_comp/fifth_section/joinComm_box/communityCard_3.png", alt: "Join the community", class: "section-6__comm-card", aria: { hidden: true } %>
            <% end %>
          </div>
          <%= image_tag "RSVP_comp/fifth_section/joinComm_box/communityBox_bkg.png", alt: "Ask a question, Updates and News, Join the community", class: "section-6__comm-box" %>
        </div>
        <div class="section-6__questions">
          <div class="section-6__questions-buttons">
            <%= link_to "https://jackpot.hackclub.com/faq", target: "_blank", rel: "noopener noreferrer", class: "section-6__card-link" do %>
              <%= image_tag "RSVP_comp/fifth_section/joinComm_box/FAQ_card_1.png", alt: "FAQ", class: "section-6__question-card", aria: { hidden: true } %>
            <% end %>
            <%= link_to "https://jackpot.hackclub.com/rules", target: "_blank", rel: "noopener noreferrer", class: "section-6__card-link" do %>
              <%= image_tag "RSVP_comp/fifth_section/joinComm_box/rules_card_2.png", alt: "Rules", class: "section-6__question-card", aria: { hidden: true } %>
            <% end %>
          </div>
          <%= image_tag "RSVP_comp/fifth_section/joinComm_box/questionBox_bkg.png", alt: "Questions FAQ Rules", class: "section-6__questions-box" %>
        </div>
        <footer class="section-6__footer">
          <div class="section-6__footer-line"></div>
          <p class="section-6__questions-cta">
            Have more questions? Email us at <%= link_to "emmaborghi@hackclub.com", "mailto:emmaborghi@hackclub.com", class: "section-6__questions-cta-link" %>
          </p>
          <div class="section-6__footer-links">
            <div class="section-6__footer-col">
              <span class="section-6__footer-col-title">Hack Club</span>
              <a href="https://hackclub.com/philosophy/" target="_blank" rel="noopener noreferrer">Philosophy</a>
              <a href="https://hackclub.com/team/" target="_blank" rel="noopener noreferrer">Our Team &amp; Board</a>
              <a href="https://hackclub.com/jobs/" target="_blank" rel="noopener noreferrer">Jobs</a>
              <a href="https://hackclub.com/brand/" target="_blank" rel="noopener noreferrer">Brand Guide</a>
              <a href="https://hackclub.com/press/" target="_blank" rel="noopener noreferrer">Press Inquiries</a>
              <a href="https://hackclub.com/philanthropy/" target="_blank" rel="noopener noreferrer">Donate</a>
            </div>
            <div class="section-6__footer-col">
              <span class="section-6__footer-col-title">Resources</span>
              <a href="https://events.hackclub.com/" target="_blank" rel="noopener noreferrer">Community Events</a>
              <a href="https://jams.hackclub.com/" target="_blank" rel="noopener noreferrer">Jams</a>
              <a href="https://toolbox.hackclub.com/" target="_blank" rel="noopener noreferrer">Toolbox</a>
              <a href="https://hackclub.com/map" target="_blank" rel="noopener noreferrer">Clubs Map</a>
              <a href="https://hackclub.com/conduct/" target="_blank" rel="noopener noreferrer">Code of Conduct</a>
              <a href="https://hackclub.com/privacy/" target="_blank" rel="noopener noreferrer">Privacy &amp; Terms</a>
            </div>
          </div>
          <p class="section-6__copyright">© <%= Date.current.year %> Hack Club. All rights reserved.</p>
        </footer>
      </div>
      <div class="ext-section__lighty-line"></div>
