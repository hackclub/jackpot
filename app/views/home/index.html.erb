<div class="main">
<div class="page-section page-section--hero">
  <div class="hero-overlays">
    <%= image_tag 'title.PNG', alt: 'Jackpot Title', class: 'hero-title' %>
    <%= image_tag 'centralmg.png', alt: 'Center Art', class: 'hero-center' %>
    <%= link_to image_tag('HC_logo.png', alt: 'Hack Club Logo', class: 'hero-logo'), 'https://hackclub.com', class: 'hero-logo-link' %>
  </div>
  <%= render "home/rsvp" %>
</div>
</div>

<style>
/* --- First section height: hero shows full first_bkg; ext_bkg starts right below (no overlap) --- */
:root {
  --first-section-height: 56.25vw; /* 16:9; change to e.g. 100vw for 1:1, 62.5vw for 16:10 */
}
@media (max-aspect-ratio: 1/1) {
  :root { --first-section-height: 100vw; }
}
/* --- Base: works for all screens --- */
html {
  overflow-x: hidden;
  -webkit-text-size-adjust: 100%;
}
body {
  background: url(<%= image_path 'ext_bkg.png' %>) no-repeat left top #000;
  background-size: 100% auto;
  background-position: 0 var(--first-section-height);
  min-height: max(100vh, 500vw);
  min-height: max(100dvh, 500vw);
  margin: 0;
  padding: 0;
  width: 100%;
  min-width: 100%;
  max-width: 100vw;
  box-sizing: border-box;
  overflow-x: hidden;
}
.main {
  color: white;
  text-align: center;
  position: relative;
  width: 100%;
  min-width: 100%;
  max-width: 100vw;
  box-sizing: border-box;
  overflow-x: hidden;
}
.page-section {
  min-height: 100vh;
  min-height: 100dvh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 100vw;
}
.page-section--hero {
  position: relative;
  min-height: var(--first-section-height);
  height: var(--first-section-height);
  background: url(<%= image_path 'first_bkg.jpg' %>) no-repeat top center #000;
  background-size: 100% auto;
  background-position: top center;
}
</style>

<style>
.hero-overlays {
  position: absolute;
  inset: 0;
  pointer-events: none;
  transform: translateY(-8vh);
  max-width: 100vw;
  overflow: hidden;
}
.hero-title {
  position: absolute;
  left: 50%;
  top: clamp(-12vh, -16vh, -10vh);
  transform: translateX(-50%) rotate(3deg);
  max-width: min(90vw, 520px);
  width: clamp(280px, 42vw, 520px);
  height: auto;
  filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35));
  animation: title-flicker 4.5s infinite steps(1, end);
}
.hero-title::after {
  content: "";
  position: absolute;
  inset: -8px;
  pointer-events: none;
  background: linear-gradient(75deg, rgba(255,240,180,0) 0%, rgba(255,240,180,0.0) 35%, rgba(255,240,180,0.45) 50%, rgba(255,240,180,0.0) 65%, rgba(255,240,180,0) 100%);
  mix-blend-mode: screen;
  transform: translateX(-160%);
  animation: title-sheen 5.75s infinite;
}
.hero-center {
  position: absolute;
  left: 50%;
  top: clamp(12vh, 16vh, 20vh);
  transform: translateX(-50%);
  max-width: min(85vw, 720px);
  width: clamp(280px, 85vw, 720px);
  height: auto;
  filter:
    drop-shadow(0 0 18px rgba(255, 230, 170, 0.35))
    drop-shadow(0 0 48px rgba(255, 170, 60, 0.22));
  animation: center-glow 2.8s ease-in-out infinite;
}
.hero-logo-link {
  position: absolute;
  top: clamp(8px, 10vh, 12vh);
  left: max(8px, env(safe-area-inset-left));
  pointer-events: auto;
  display: block;
  line-height: 0;
}
.hero-logo {
  width: clamp(100px, 22vw, 180px);
  height: auto;
  display: block;
}
@keyframes title-sheen {
  0%   { transform: translateX(-160%); opacity: 0.0; }
  12%  { transform: translateX(160%);  opacity: 1.0; }
  100% { transform: translateX(160%);  opacity: 0.0; }
}
@keyframes title-flicker {
  0%, 87%, 100%   { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.35)) brightness(1) }
  88%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.35)) brightness(0.8) }
  89%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.55)) brightness(1.2) }
  90%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.30)) brightness(0.9) }
  92%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.60)) brightness(1.25) }
}
@keyframes center-glow {
  0%, 100% {
    filter:
      drop-shadow(0 0 16px rgba(255, 230, 170, 0.28))
      drop-shadow(0 0 40px rgba(255, 170, 60, 0.15))
      brightness(1);
  }
  50% {
    filter:
      drop-shadow(0 0 32px rgba(255, 240, 190, 0.55))
      drop-shadow(0 0 80px rgba(255, 180, 70, 0.35))
      brightness(1.08);
  }
}

/* --- Tablet (768px - 1023px) --- */
@media (max-width: 1023px) {
  .hero-title { width: clamp(240px, 50vw, 420px); }
  .hero-center { width: clamp(260px, 90vw, 600px); }
  .hero-logo { width: clamp(100px, 18vw, 160px); }
}

/* --- Small tablet / large phone (600px - 767px) --- */
@media (max-width: 767px) {
  .hero-overlays { transform: translateY(2vh); }
  .hero-title { top: -18vh; width: clamp(220px, 55vw, 380px); }
  .hero-center { top: 14vh; width: clamp(240px, 95vw, 500px); }
  .hero-logo-link { top: 8vh; }
  .hero-logo { width: 130px; }
}

/* --- Mobile (480px - 599px) --- */
@media (max-width: 599px) {
  html, body { width: 100%; min-width: 100%; overflow-x: hidden; }
  .main { min-width: 100%; width: 100%; }
  .page-section { min-width: 100%; }
  .hero-overlays { transform: translateY(4vh); }
  .hero-title { top: -20vh; width: 85vw; max-width: 320px; }
  .hero-center { top: 14vh; width: 120vw; max-width: 420px; }
  .hero-logo-link { top: 6vh; left: max(8px, env(safe-area-inset-left)); }
  .hero-logo { width: 120px; }
  .scroll-down-v { bottom: 140px; }
}

/* --- Small mobile (< 480px) --- */
@media (max-width: 479px) {
  .hero-title { top: -18vh; width: 95vw; }
  .hero-center { top: 12vh; width: 130vw; max-width: 380px; }
  .hero-logo { width: 100px; }
  .scroll-down-v { bottom: 120px; }
}
</style>