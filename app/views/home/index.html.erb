<div class="main">
<div class="page-section page-section--hero">
  <div class="hero-overlays">
    <%= image_tag 'title.PNG', alt: 'Jackpot Title', class: 'hero-title' %>
    <%= image_tag 'centralmg.png', alt: 'Center Art', class: 'hero-center' %>
    <%= image_tag 'HC_logo.png', alt: 'Hack Club Logo', class: 'hero-logo' %>
  </div>
  <%= render "home/rsvp" %>
</div>
<div class="page-section page-section--steps">
  <div class="steps-content">
    <%= image_tag 'RSVP_steps.png', alt: 'RSVP Steps', class: 'steps-image' %>
    <div class="steps-cards">
      <a href="https://hackclub.enterprise.slack.com/archives/C0AEQ8ZJ7EU" target="_blank" rel="noopener noreferrer" class="steps-card-link"><%= image_tag 'Card_1.png', alt: 'Ask a question', class: 'steps-card' %></a>
      <a href="https://hackclub.enterprise.slack.com/archives/C0ADEGZL5HD" target="_blank" rel="noopener noreferrer" class="steps-card-link"><%= image_tag 'Card_2.png', alt: 'Updates and News!', class: 'steps-card' %></a>
      <a href="https://hackclub.enterprise.slack.com/archives/C0AEQ8VAPA4" target="_blank" rel="noopener noreferrer" class="steps-card-link"><%= image_tag 'Card_3.png', alt: 'Join the community', class: 'steps-card' %></a>
    </div>
    <p class="steps-coming-soon">
    More info<br>coming soon
  </p>
    </div>
</div>
<div class="page-section page-section--tail"></div>
</div>

<style>
body {
background: url(<%= image_path 'RSVP_extended2.jpg' %>);
min-height: 100vh;
margin: 0;
padding: 0;
background-repeat: no-repeat;
background-size: 100% 400vh;
background-position: top center;
background-color: #000;
width: 100%;
min-width: 100%;
box-sizing: border-box;
}

.main {
color: white;
text-align: center;
position: relative;
width: 100%;
min-width: 100%;
box-sizing: border-box;
}

.page-section {
min-height: 100vh;
position: relative;
display: flex;
align-items: center;
justify-content: center;
}
.page-section--tail {
min-height: 55vh;
}
.page-section--steps .steps-content {
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 6vh;
width: 100%;
margin-top: 8vh;
}
.page-section--steps .steps-image {
max-width: 70vw;
width: 100%;
height: auto;
object-fit: contain;
}
.page-section--steps .steps-cards {
display: flex;
flex-direction: row;
align-items: center;
justify-content: center;
gap: 2vw;
flex-wrap: wrap;
}
.page-section--steps .steps-coming-soon {
margin: 0;
margin-top: 40vh;
font-size: 8rem;
color: rgba(255, 240, 200, 0.9);
font-style: italic;
letter-spacing: 0.15em;
animation: coming-soon-pulse 2.5s ease-in-out infinite;
}
@keyframes coming-soon-pulse {
0%, 100% { opacity: 0.7; transform: scale(1); }
50% { opacity: 1; transform: scale(1.05); }
}
.page-section--steps .steps-card-link {
display: block;
transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease, box-shadow 0.3s ease;
}
.page-section--steps .steps-card-link:hover {
transform: scale(1.08) translateY(-8px);
filter: drop-shadow(0 12px 24px rgba(255, 180, 80, 0.4));
}
.page-section--steps .steps-card {
max-width: 380px;
width: 32vw;
height: auto;
object-fit: contain;
display: block;
pointer-events: none;
}
.page-section--hero {
position: relative;
min-height: 100vh;
}
.page-section--hero #rsvp-container {
bottom: calc(40px + 8vh);
}
</style>

<style>
.hero-overlays {
position: absolute;
inset: 0;
pointer-events: none;
transform: translateY(-12vh);
}
.hero-title {
position: absolute;
left: 50%;
top: -20vh;
transform: translateX(-50%) rotate(3deg);
max-width: 90vw;
width: 42vw;
height: auto;
/* gentle glow + occasional flicker */
filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35));
animation: title-flicker 4.5s infinite steps(1, end);
}
.hero-title::after {
content: "";
position: absolute;
inset: -8px;
pointer-events: none;
/* sweeping sheen to mimic moving lights */
background: linear-gradient(75deg, rgba(255,240,180,0) 0%, rgba(255,240,180,0.0) 35%, rgba(255,240,180,0.45) 50%, rgba(255,240,180,0.0) 65%, rgba(255,240,180,0) 100%);
mix-blend-mode: screen;
transform: translateX(-160%);
animation: title-sheen 5.75s infinite;
}
.hero-center {
position: absolute;
left: 50%;
top: 12vh;
transform: translateX(-50%);
max-width: 80vw; 
width: 85vw; /* IMG SIZE */
height: auto;
/* bright pulsing glow around the image */
filter:
  drop-shadow(0 0 18px rgba(255, 230, 170, 0.35))
  drop-shadow(0 0 48px rgba(255, 170, 60, 0.22));
animation: center-glow 2.8s ease-in-out infinite;
}
.hero-logo {
position: absolute;
top: 6vh;
left: 8px;
width: 180px;
height: auto;
}
@keyframes title-sheen {
  0%   { transform: translateX(-160%); opacity: 0.0; }
  12%  { transform: translateX(160%);  opacity: 1.0; }
  100% { transform: translateX(160%);  opacity: 0.0; }
}
@keyframes title-flicker {
  0%, 87%, 100%   { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.35)) brightness(1) }
  88%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.35)) brightness(0.8) }
  89%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.55)) brightness(1.2) }
  90%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.30)) brightness(0.9) }
  92%             { filter: drop-shadow(0 2px 0 rgba(0,0,0,0.5)) drop-shadow(0 8px 18px rgba(255,180,80,0.60)) brightness(1.25) }
}
@keyframes center-glow {
  0%, 100% {
    filter:
      drop-shadow(0 0 16px rgba(255, 230, 170, 0.28))
      drop-shadow(0 0 40px rgba(255, 170, 60, 0.15))
      brightness(1);
  }
  50% {
    filter:
      drop-shadow(0 0 32px rgba(255, 240, 190, 0.55))
      drop-shadow(0 0 80px rgba(255, 180, 70, 0.35))
      brightness(1.08);
  }
}

@media (max-width: 600px) {
  .page-section--steps .steps-cards {
    gap: 3vw;
  }
  .page-section--steps .steps-card {
    max-width: 240px;
    width: 85vw;
  }
  .page-section--steps .steps-card-link:hover {
    transform: scale(1.05) translateY(-4px);
  }
  .page-section--steps .steps-coming-soon {
    font-size: 2.5rem;
    margin-top: 12vh;
  }
}

/* Mobile adjustments */
@media (max-width: 600px) {
  html, body {
    width: 100%;
    min-width: 100vw;
    overflow-x: hidden;
  }
  body {
    background-size: 102% 315vh;
    background-position: top center;
  }
  .main {
    min-width: 100vw;
    width: 100%;
  }
  .page-section {
    min-width: 100%;
  }
  .hero-overlays {
    transform: translateY(4vh);   /* less upward shift so image + button sit lower */
  }
  .hero-title {
    width: 110vw;                  /* title sz */
    max-width: none;
    top: -12vh;                   
  }
  .hero-center {
    width: 150vw;                /* image sz */
    max-width: none;
    top: 22vh;                   /* lower so central image is more centered */
  }
  .hero-logo {
    width: 140px;                /* logo pos */
    top: 0;
    left: 8px;
  }
  .page-section--hero #rsvp-container {
    bottom: 32px;                /* lower button on mobile */
  }
}
</style>