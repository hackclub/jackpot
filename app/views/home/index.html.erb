<div class="main">
  <section class="page-section page-section--hero">
    <div class="hero-overlays">
      <%= image_tag "title.PNG", alt: "Jackpot Title", class: "hero-title" %>
      <%= image_tag "centralmg.png", alt: "Center Art", class: "hero-center" %>
      <%= link_to image_tag("HC_logo.png", alt: "Hack Club Logo", class: "hero-logo"), "https://hackclub.com", class: "hero-logo-link" %>
    </div>
    <%= render "home/rsvp" %>
  </section>

  <div id="steps" class="ext-content">
    <div class="ext-content__lighty-line--top"></div>
    <%# Section 1: How does it work %>
    <section class="ext-section ext-section--1">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_1.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--1">
        <h2 class="section-title section-title--center">How does it work</h2>
        <div class="section-1__panel">
          <%= image_tag "RSVP_comp/first_section/yellow_box.png", alt: "", class: "section-1__panel-bg", aria: { hidden: true } %>
          <div class="section-1__panel-content">
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon1_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">The first thing that you need is to get your dream project.</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon2_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">The game system will allow you to earn rewards with incredible opportunities.</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon3_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">But to do it, first you need to take a look at your project.</p>
            </div>
            <div class="section-1__step">
              <%= image_tag "RSVP_comp/first_section/icon4_box.png", alt: "", class: "section-1__step-icon", aria: { hidden: true } %>
              <p class="section-1__step-text">Spend your gains on the platform and show support for your favorite projects, or take part in hackathons.</p>
            </div>
          </div>
        </div>
        <div class="section-1__join-wrap">
          <%= button_to "/auth/hack_club", method: :post, data: { turbo: false }, class: "section-1__join-link" do %>
            <%= image_tag "RSVP_comp/first_section/join_button.png", alt: "Join", class: "section-1__join-btn" %>
          <% end %>
          <%= image_tag "RSVP_comp/second_section/poker_chip.png", alt: "", class: "section-1__poker-chip", aria: { hidden: true } %>
        </div>
        <p class="section-1__tagline">next jackpot</p>
        <div class="section-1__carousel">
          <%= image_tag "RSVP_comp/first_section/shop_items_carousel/cloud Background Removed.png", alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
          <%= image_tag "RSVP_comp/first_section/shop_items_carousel/monitor Background Removed.png", alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
          <%= image_tag "RSVP_comp/first_section/shop_items_carousel/console.png", alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
          <%= image_tag "RSVP_comp/first_section/shop_items_carousel/rasp.png", alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
          <%= image_tag "RSVP_comp/first_section/shop_items_carousel/gpu.png", alt: "", class: "section-1__carousel-item", aria: { hidden: true } %>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 2: About Hack Club / Jackpot Trailer %>
    <section class="ext-section ext-section--2">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_2.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--2">
        <div class="section-2__about">
          <h2 class="section-title">About Hack Club</h2>
          <%= image_tag "RSVP_comp/second_section/hackclub_box.png", alt: "About Hack Club", class: "section-2__hackclub-box" %>
        </div>
        <div class="section-2__trailer">
          <h2 class="section-title section-title--center">Jackpot Trailer</h2>
          <%= image_tag "RSVP_comp/second_section/jackpottrailer_box.png", alt: "Jackpot Trailer", class: "section-2__trailer-box" %>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 3: You can create EVERYTHING! %>
    <section class="ext-section ext-section--3">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_3.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--3">
        <div class="section-3__header">
          <%= image_tag "RSVP_comp/third_section/card_draw.png", alt: "", class: "section-3__card-icon", aria: { hidden: true } %>
          <h2 class="section-title section-3__title">
            You can create <span class="section-3__title-accent">EVERYTHING!</span>
          </h2>
        </div>
        <div class="section-3__cards">
          <%= image_tag "RSVP_comp/third_section/prj_card_1.png", alt: "Project card", class: "section-3__prj-card" %>
          <%= image_tag "RSVP_comp/third_section/prj_card_2.png", alt: "Project card", class: "section-3__prj-card" %>
          <%= image_tag "RSVP_comp/third_section/prj_card_3.png", alt: "Project card", class: "section-3__prj-card" %>
        </div>
        <%= link_to image_tag("RSVP_comp/third_section/seeMoreButton.png", alt: "See your projects", class: "section-3__see-more"), "#", class: "section-3__see-more-link" %>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 4: Don't know where to start? %>
    <section class="ext-section ext-section--4">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_4.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--4">
        <h2 class="section-title section-title--center">Don't know where to start?</h2>
        <div class="section-4__content">
          <%= image_tag "RSVP_comp/third_section/where_to_start_box.png", alt: "Get started", class: "section-4__box" %>
          <%= image_tag "RSVP_comp/second_section/poker_chip.png", alt: "", class: "section-4__poker-chip", aria: { hidden: true } %>
        </div>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>

    <%# Section 5: Past Events %>
    <section class="ext-section ext-section--5">
      <%= image_tag "RSVP_comp/bkgs/extBkg_section_5.png", alt: "", class: "ext-section__bkg", aria: { hidden: true } %>
      <div class="ext-section__inner ext-section__inner--5">
        <h2 class="section-title section-title--center">Past Events</h2>
        <p class="section-5__subtitle">and projects organized by us!</p>
        <div class="section-5__intro">
          <%= image_tag "RSVP_comp/fourth_section/emma_box.png", alt: "Past events intro", class: "section-5__emma-box" %>
        </div>
        <div class="section-5__events">
          <div class="section-5__event section-5__event--juice">
            <%= image_tag "RSVP_comp/fourth_section/juice_img.png", alt: "Juice event", class: "section-5__event-img" %>
            <%= image_tag "RSVP_comp/fourth_section/juice_txt.png", alt: "Juice", class: "section-5__event-txt" %>
          </div>
          <div class="section-5__event section-5__event--moonshot">
            <%= image_tag "RSVP_comp/fourth_section/moonshot_txt.png", alt: "Moonshot", class: "section-5__event-txt" %>
            <%= image_tag "RSVP_comp/fourth_section/moonshot_img.png", alt: "Moonshot event", class: "section-5__event-img" %>
          </div>
          <div class="section-5__event section-5__event--overglade">
            <%= image_tag "RSVP_comp/fourth_section/overglade_img.png", alt: "Overglade event", class: "section-5__event-img" %>
            <%= image_tag "RSVP_comp/fourth_section/overglade_txt.png", alt: "Overglade", class: "section-5__event-txt" %>
          </div>
        </div>
        <%= link_to image_tag("RSVP_comp/fourth_section/seeMoreHackathonsButton.png", alt: "See more hackathons", class: "section-5__see-more"), "#", class: "section-5__see-more-link" %>
        <h2 class="section-title section-title--center section-title--info">info</h2>
        <p class="section-6__subtitle">Join the community</p>
        <div class="section-6__cards">
          <%= image_tag "RSVP_comp/fifth_section/joinComm_box.png", alt: "Ask a question, Updates and News, Join the community", class: "section-6__comm-box" %>
        </div>
        <div class="section-6__questions">
          <%= image_tag "RSVP_comp/fifth_section/questions_box.png", alt: "Questions FAQ Rules", class: "section-6__questions-box" %>
        </div>
        <footer class="section-6__footer">
          <div class="section-6__footer-links">
            <div class="section-6__footer-col">
              <a href="mailto:highschoolhackathons@hackclub.com">Email</a>
              <a href="https://hackclub.enterprise.slack.com/archives/C0AEQ8VAPA4" target="_blank" rel="noopener noreferrer">Slack</a>
              <a href="https://discord.gg/hackclub" target="_blank" rel="noopener noreferrer">Discord</a>
              <a href="https://twitter.com/hackclub" target="_blank" rel="noopener noreferrer">Twitter</a>
              <a href="https://www.patreon.com/hackclub" target="_blank" rel="noopener noreferrer">Patreon</a>
            </div>
            <div class="section-6__footer-col">
              <a href="/contact">Contact Us</a>
              <a href="/terms">Terms of Use</a>
              <a href="/privacy">Privacy Policy</a>
              <a href="/sitemap">Sitemap</a>
            </div>
          </div>
          <p class="section-6__copyright">© <%= Date.current.year %> Hack Club. All rights reserved.</p>
        </footer>
      </div>
      <div class="ext-section__lighty-line"></div>
    </section>
  </div>
</div>

<style>
@font-face {
  font-family: "Katibeh";
  src: url(<%= asset_path "Katibeh/Katibeh-Regular.ttf" %>) format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

:root {
  --first-section-height: 56.25vw;
  --content-width: min(92vw, 1024px);
  --content-width-narrow: min(88vw, 760px);
  --cream: #efe394;
  --cream-soft: #f1dfc5;
  --brown: #6b2218;
  --brown-dark: #43110e;
}

@media (max-aspect-ratio: 1/1) {
  :root {
    --first-section-height: 100vw;
  }
}

html {
  overflow-x: hidden;
  -webkit-text-size-adjust: 100%;
}

body {
  margin: 0;
  padding: 0;
  min-height: max(100vh, 500vw);
  min-height: max(100dvh, 500vw);
  width: 100%;
  max-width: 100vw;
  box-sizing: border-box;
  overflow-x: hidden;
  background: #000;
  color: #fff8ec;
}

.main,
.main * {
  box-sizing: border-box;
}

.main {
  position: relative;
  width: 100%;
  max-width: 100vw;
}

.page-section--hero {
  position: relative;
  height: var(--first-section-height);
  min-height: var(--first-section-height);
  background: url(<%= image_path "first_bkg.jpg" %>) no-repeat top center #000;
  background-size: 100% auto;
}

.hero-overlays {
  position: absolute;
  inset: 0;
  pointer-events: none;
  transform: translateY(-8vh);
  max-width: 100vw;
  overflow: hidden;
}

.hero-title {
  position: absolute;
  left: 50%;
  top: clamp(-12vh, -16vh, -10vh);
  transform: translateX(-50%) rotate(3deg);
  max-width: min(90vw, 520px);
  width: clamp(280px, 42vw, 520px);
  height: auto;
  filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.5)) drop-shadow(0 8px 18px rgba(255, 180, 80, 0.35));
  animation: title-flicker 4.5s infinite steps(1, end);
}

.hero-title::after {
  content: "";
  position: absolute;
  inset: -8px;
  pointer-events: none;
  background: linear-gradient(75deg, rgba(255, 240, 180, 0) 0%, rgba(255, 240, 180, 0) 35%, rgba(255, 240, 180, 0.45) 50%, rgba(255, 240, 180, 0) 65%, rgba(255, 240, 180, 0) 100%);
  mix-blend-mode: screen;
  transform: translateX(-160%);
  animation: title-sheen 5.75s infinite;
}

.hero-center {
  position: absolute;
  left: 50%;
  top: clamp(12vh, 16vh, 20vh);
  transform: translateX(-50%);
  max-width: min(85vw, 720px);
  width: clamp(280px, 85vw, 720px);
  height: auto;
  filter:
    drop-shadow(0 0 18px rgba(255, 230, 170, 0.35))
    drop-shadow(0 0 48px rgba(255, 170, 60, 0.22));
  animation: center-glow 2.8s ease-in-out infinite;
}

.hero-logo-link {
  position: absolute;
  top: clamp(8px, 10vh, 12vh);
  left: max(8px, env(safe-area-inset-left));
  pointer-events: auto;
  display: block;
  line-height: 0;
}

.hero-logo {
  width: clamp(100px, 22vw, 180px);
  height: auto;
  display: block;
}

.ext-content {
  width: 100%;
  max-width: 100vw;
  margin: 0;
  padding: 0;
  min-height: calc(500vw - var(--first-section-height));
  display: block;
  background-color: #1a0d0b;
}

.ext-section {
  position: relative;
  width: 100%;
  margin: 0;
  padding: 0;
  overflow: hidden;
}

.ext-section__bkg {
  display: block;
  width: 100%;
  height: auto;
  margin: 0;
  padding: 0;
  vertical-align: bottom;
  pointer-events: none;
}

.ext-section__lighty-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 3px;
  margin: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 120, 60, 0.3) 15%,
    rgba(255, 140, 70, 0.9) 50%,
    rgba(255, 120, 60, 0.3) 85%,
    transparent 100%
  );
  box-shadow:
    0 0 12px rgba(255, 100, 50, 0.6),
    0 0 24px rgba(255, 80, 40, 0.4);
  pointer-events: none;
}

.ext-content__lighty-line--top {
  display: block;
  width: 100%;
  height: 3px;
  margin: 0;
  padding: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 120, 60, 0.3) 15%,
    rgba(255, 140, 70, 0.9) 50%,
    rgba(255, 120, 60, 0.3) 85%,
    transparent 100%
  );
  box-shadow:
    0 0 12px rgba(255, 100, 50, 0.6),
    0 0 24px rgba(255, 80, 40, 0.4);
}

.ext-section__lighty-line--top {
  margin-bottom: clamp(32px, 4vw, 56px);
}

.ext-section__inner {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: var(--content-width);
  max-width: 92vw;
  height: 100%;
  z-index: 1;
  padding: clamp(48px, 6vw, 88px) 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  overflow-y: auto;
}

/* Section 1: How does it work */
.section-title--center {
  text-align: center;
  margin-bottom: clamp(20px, 3vw, 36px);
}

.section-1__panel {
  position: relative;
  width: 100%;
  max-width: min(92%, 680px);
  margin: 0 auto clamp(24px, 3vw, 36px);
}

.section-1__panel-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
}

.section-1__panel-content {
  position: relative;
  padding: clamp(20px, 4vw, 36px);
  display: flex;
  flex-direction: column;
  gap: clamp(12px, 1.5vw, 18px);
}

.section-1__step {
  display: flex;
  align-items: flex-start;
  gap: clamp(12px, 1.5vw, 20px);
}

.section-1__step-icon {
  flex-shrink: 0;
  width: clamp(32px, 5vw, 48px);
  height: auto;
}

.section-1__step-text {
  margin: 0;
  color: var(--cream-soft);
  font-family: "Georgia", serif;
  font-size: clamp(0.9rem, 1.4vw, 1.1rem);
  line-height: 1.45;
}

.section-1__join-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  margin-bottom: clamp(8px, 1vw, 16px);
}

.section-1__join-link {
  display: inline-block;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 0;
}

.section-1__join-link button,
.section-1__join-link input[type="submit"] {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  cursor: pointer;
  line-height: 0;
}

.section-1__join-btn {
  width: clamp(140px, 22vw, 280px);
  height: auto;
  display: block;
}

.section-1__poker-chip {
  position: absolute;
  width: clamp(36px, 6vw, 72px);
  height: auto;
  top: -8%;
  right: calc(50% - clamp(70px, 11vw, 140px));
  transform: translateX(50%);
}

.section-1__tagline {
  margin: 0 0 clamp(20px, 2.5vw, 32px);
  text-align: center;
  color: rgba(255, 248, 236, 0.9);
  font-family: "Katibeh", serif;
  font-size: clamp(1rem, 1.5vw, 1.25rem);
}

.section-1__carousel {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: clamp(8px, 1.5vw, 16px);
  flex-wrap: wrap;
}

.section-1__carousel-item {
  width: clamp(48px, 8vw, 80px);
  height: auto;
  object-fit: contain;
}

/* Section 2: About Hack Club / Jackpot Trailer */
.section-2__about {
  margin-bottom: clamp(32px, 4vw, 48px);
}

.section-2__hackclub-box {
  display: block;
  width: 100%;
  max-width: min(100%, 720px);
  height: auto;
}

.section-2__trailer {
  margin-top: clamp(24px, 3vw, 40px);
}

.section-2__trailer-box {
  display: block;
  width: 100%;
  max-width: min(100%, 720px);
  height: auto;
  margin: 0 auto;
}

/* Section 3: You can create EVERYTHING! */
.section-3__header {
  display: flex;
  align-items: flex-start;
  gap: clamp(12px, 1.5vw, 20px);
  margin-bottom: clamp(20px, 2.5vw, 32px);
}

.section-3__card-icon {
  width: clamp(40px, 6vw, 64px);
  height: auto;
  flex-shrink: 0;
}

.section-3__title {
  margin: 0;
}

.section-3__title-accent {
  color: #e87d3a;
  text-decoration: underline;
  text-underline-offset: 4px;
}

.section-3__cards {
  display: flex;
  justify-content: center;
  gap: clamp(12px, 2vw, 24px);
  flex-wrap: wrap;
  margin-bottom: clamp(20px, 2.5vw, 32px);
}

.section-3__prj-card {
  width: clamp(140px, 22vw, 280px);
  height: auto;
  object-fit: contain;
}

.section-3__see-more-link {
  display: flex;
  justify-content: center;
}

.section-3__see-more {
  width: clamp(180px, 28vw, 320px);
  height: auto;
}

/* Section 4: Don't know where to start? */
.section-4__content {
  position: relative;
  display: flex;
  justify-content: center;
}

.section-4__box {
  width: 100%;
  max-width: min(92%, 680px);
  height: auto;
}

.section-4__poker-chip {
  position: absolute;
  width: clamp(40px, 6vw, 80px);
  height: auto;
  bottom: 5%;
  right: 10%;
}

/* Section 5: Past Events */
.section-5__subtitle {
  margin: 0 0 clamp(20px, 2.5vw, 32px);
  text-align: center;
  color: rgba(255, 248, 236, 0.85);
  font-size: clamp(0.95rem, 1.3vw, 1.1rem);
}

.section-5__emma-box {
  width: 100%;
  max-width: min(100%, 720px);
  height: auto;
  margin: 0 auto clamp(24px, 3vw, 36px);
  display: block;
}

.section-5__events {
  display: flex;
  flex-direction: column;
  gap: clamp(24px, 3vw, 40px);
  margin-bottom: clamp(24px, 3vw, 36px);
}

.section-5__event {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(16px, 2vw, 28px);
  flex-wrap: wrap;
}

.section-5__event-img {
  width: clamp(180px, 35vw, 400px);
  height: auto;
  object-fit: contain;
}

.section-5__event-txt {
  width: clamp(140px, 25vw, 280px);
  height: auto;
  object-fit: contain;
}

.section-5__see-more-link {
  display: flex;
  justify-content: center;
}

.section-5__see-more {
  width: clamp(200px, 30vw, 360px);
  height: auto;
}

/* Section 6: Info / Footer */
.section-6__subtitle {
  margin: 0 0 clamp(20px, 2.5vw, 28px);
  text-align: center;
  color: rgba(255, 248, 236, 0.9);
  font-size: clamp(1rem, 1.4vw, 1.2rem);
}

.section-6__comm-box {
  width: 100%;
  max-width: min(100%, 900px);
  height: auto;
  margin: 0 auto clamp(24px, 3vw, 36px);
  display: block;
}

.section-6__questions {
  margin-bottom: clamp(28px, 4vw, 44px);
}

.section-6__questions-box {
  width: 100%;
  max-width: min(100%, 640px);
  height: auto;
  margin: 0 auto;
  display: block;
}

.section-6__footer {
  text-align: center;
}

.section-6__footer-links {
  display: flex;
  justify-content: center;
  gap: clamp(24px, 4vw, 48px);
  flex-wrap: wrap;
  margin-bottom: clamp(12px, 1.5vw, 20px);
}

.section-6__footer-col {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
}

.section-6__footer-col a {
  color: var(--cream-soft);
  font-size: clamp(0.8rem, 1.1vw, 0.95rem);
  text-decoration: none;
