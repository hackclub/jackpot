<% content_for :title, "FAQ — Jackpot" %>

<div class="faq-page">
  <div class="faq-floating-icons" aria-hidden="true">
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--1", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--2", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--3", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--4", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--5", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--6", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--7", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--8", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--9", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--10", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--11", alt: "" %>
    <%= image_tag "icons/cards.png", class: "faq-icon faq-icon--12", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--13", alt: "" %>
    <%= image_tag "icons/cherry.png", class: "faq-icon faq-icon--14", alt: "" %>
    <%= image_tag "icons/chip.png", class: "faq-icon faq-icon--15", alt: "" %>
    <%= image_tag "icons/diamond.png", class: "faq-icon faq-icon--16", alt: "" %>
  </div>
  <div class="faq-content">
  <%= link_to root_path, class: "faq-back-btn" do %>
  <%= image_tag "back_button.png", alt: "Back", class: "faq-back-btn-img" %>
<% end %>

  <%= image_tag "faq_title.png", alt: "FAQ", class: "faq-title" %>
  <p class="faq-disclaimer"><strong>NOTE:</strong> Day-of logistics (schedules, venue) may change. We'll share details closer to the event.</p>

  <section class="faq-section">
    <h2 class="faq-section-heading">— General</h2>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-1" id="faq-q-1">
        <span class="faq-q-text">What if I can't (or don't wanna) attend Jackpot in Las Vegas?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-1" role="region" aria-labelledby="faq-q-1" aria-hidden="true">
        <p class="faq-a">You will be able to redeem the hours you spent making projects in a shop for fun, neat prizes!</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-2" id="faq-q-2">
        <span class="faq-q-text">How Do I Register?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-2" role="region" aria-labelledby="faq-q-2" aria-hidden="true">
        <p class="faq-a">Signup <a href="#" class="faq-link">here</a>!</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-3" id="faq-q-3">
        <span class="faq-q-text">Can I start?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-3" role="region" aria-labelledby="faq-q-3" aria-hidden="true">
        <p class="faq-a">Yes, track your hours with Hackatime or use the journaling system.</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-4" id="faq-q-4">
        <span class="faq-q-text">Can I collab with my friends and make a single project?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-4" role="region" aria-labelledby="faq-q-4" aria-hidden="true">
        <p class="faq-a">Yes BUT:</p>
        <ul class="faq-list">
          <li>You can work on the same repo but in different forks</li>
          <li>Your hours will be obviously counted separately</li>
        </ul>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-5" id="faq-q-5">
        <span class="faq-q-text">Can I ship a private (or partially private) project?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-5" role="region" aria-labelledby="faq-q-5" aria-hidden="true">
        <p class="faq-a">No, your project MUST be open source, otherwise hours will not be counted.</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-6" id="faq-q-6">
        <span class="faq-q-text">Can I work in already started projects?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-6" role="region" aria-labelledby="faq-q-6" aria-hidden="true">
        <p class="faq-a">As long it's not part of other HC programs, yes you can! We HIGHLY suggest to create a new Github repository — it's not mandatory, but it will increase your chances of being approved, and will make the process much faster.</p>
      </div>
    </article>
  </section>

  <section class="faq-section">
    <h2 class="faq-section-heading">— In-Person Event</h2>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-7" id="faq-q-7">
        <span class="faq-q-text">How do I get invited?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-7" role="region" aria-labelledby="faq-q-7" aria-hidden="true">
        <p class="faq-a">Log your hours, work on your project for 65 hours and ship it on Launchpad.</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-8" id="faq-q-8">
        <span class="faq-q-text">Who Can Participate?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-8" role="region" aria-labelledby="faq-q-8" aria-hidden="true">
        <p class="faq-a">Anyone between the ages of 13 and 18 (included) can participate in Jackpot!</p>
      </div>
    </article>

    <article class="faq-item">
      <button type="button" class="faq-q" aria-expanded="false" aria-controls="faq-answer-9" id="faq-q-9">
        <span class="faq-q-text">Is it free?</span>
        <span class="faq-q-icon" aria-hidden="true"></span>
      </button>
      <div class="faq-answer" id="faq-answer-9" role="region" aria-labelledby="faq-q-9" aria-hidden="true">
        <p class="faq-a">Yes! Participation is entirely free once you're invited!</p>
      </div>
    </article>
  </section>

  <section class="faq-section faq-section--cta">
    <a href="https://hackclub.enterprise.slack.com/archives/C0AEQ8ZJ7EU" target="_blank" rel="noopener noreferrer" class="faq-cta-card-link">
      <%= image_tag "Card_1.png", alt: "Ask a question in #jackpot-help", class: "faq-cta-card" %>
    </a>
  </section>
  </div>
</div>

<style>
