.faq-content {
  position: relative;
  z-index: 1;
  padding-top: 5.25rem;
}

.faq-back-btn {
  position: absolute;
  top: 0.5rem;
  left: -0.75rem;
  display: inline-block;
  line-height: 0;
  text-decoration: none;
  transition: transform 0.2s ease, filter 0.2s ease;
}

.faq-back-btn:hover {
  transform: scale(1.05);
  filter: drop-shadow(0 4px 12px rgba(255, 180, 80, 0.3));
}

.faq-back-btn-img {
  display: block;
  height: auto;
  max-height: 96px;
  width: auto;
  object-fit: contain;
}

.faq-disclaimer {
  margin: 0 auto 2rem;
  max-width: 520px;
  padding: 0.75rem 1rem;
  font-size: 1.15rem;
  line-height: 1.45;
  font-style: italic;
  color: rgba(255, 255, 255, 0.88);
  text-align: center;
  animation: faq-disclaimer-in 0.6s ease-out, faq-disclaimer-pulse 3s ease-in-out 0.6s infinite;
}

.faq-disclaimer strong {
  font-style: normal;
  color: rgba(255, 220, 140, 0.95);
}

@keyframes faq-disclaimer-in {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes faq-disclaimer-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.9; }
}

.faq-title {
  display: block;
  max-width: 100%;
  width: clamp(280px, 50vw, 420px);
  height: auto;
  margin: 0 auto 2.5rem;
  object-fit: contain;
}

.faq-section {
  margin-bottom: 2.5rem;
}

.faq-section-heading {
  font-size: 1.45rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 200, 100, 0.95);
  margin: 0 0 1.25rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(255, 200, 100, 0.25);
}

.faq-item {
  margin-bottom: 0.75rem;
  border: 1px solid rgba(255, 200, 100, 0.25);
  border-radius: 10px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.25);
}

.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  width: 100%;
  padding: 1rem 1.25rem;
  font-family: inherit;
  font-size: 1.6rem;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
  text-align: left;
  cursor: pointer;
  border: none;
  background: transparent;
  transition: background 0.2s ease;
}

.faq-q:hover {
  background: rgba(255, 200, 100, 0.08);
}

.faq-q-text {
  flex: 1;
}

.faq-q-icon {
  flex-shrink: 0;
  width: 1.25rem;
  height: 1.25rem;
  border-right: 2px solid rgba(255, 200, 100, 0.9);
  border-bottom: 2px solid rgba(255, 200, 100, 0.9);
  transform: rotate(45deg) translateY(-2px);
  transition: transform 0.35s ease;
}

.faq-item.is-open .faq-q-icon {
  transform: rotate(-135deg) translateY(2px);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease-out;
}

.faq-item.is-open .faq-answer {
  max-height: 800px;
  padding: 0 1.25rem 1.25rem;
}

.faq-item.is-open .faq-answer .faq-a:first-child {
