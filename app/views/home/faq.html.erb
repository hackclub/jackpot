}

.faq-a {
  margin: 0;
  font-size: 1.45rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.85);
}

.faq-list {
  margin: 0.5rem 0 0 1.5rem;
  padding: 0;
  font-size: 1.45rem;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.faq-link {
  color: rgba(255, 200, 100, 0.95);
  text-decoration: none;
  font-weight: 500;
  border-bottom: 1px solid rgba(255, 200, 100, 0.4);
  transition: color 0.2s, border-color 0.2s;
}

.faq-link:hover {
  color: #ffc864;
  border-bottom-color: rgba(255, 200, 100, 0.8);
}

.faq-link--channel {
  font-family: ui-monospace, monospace;
  font-size: 0.98em;
}

.faq-section--cta {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
}

.faq-cta-card-link {
  display: inline-block;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease;
}

.faq-cta-card-link:hover {
  transform: scale(1.05);
  filter: drop-shadow(0 8px 20px rgba(255, 180, 80, 0.35));
}

.faq-cta-card {
  display: block;
  max-width: 320px;
  width: 100%;
  height: auto;
  object-fit: contain;
}

@media (min-width: 900px) {
  .faq-page {
    max-width: 1200px;
    padding: 3rem 4rem 5rem;
  }

  .faq-content {
    padding-top: 6.25rem;
  }

  .faq-back-btn {
    top: 0.75rem;
    left: -15rem;
  }

  .faq-back-btn-img {
    max-height: 112px;
  }

  .faq-disclaimer {
    max-width: 580px;
    margin-bottom: 2.5rem;
    font-size: 1.25rem;
    padding: 0.85rem 1.25rem;
  }

  .faq-title {
    width: clamp(320px, 45vw, 520px);
    margin-bottom: 3rem;
  }

  .faq-section-heading {
    font-size: 1.65rem;
    margin-bottom: 1.5rem;
  }

  .faq-q {
    font-size: 1.85rem;
    padding: 1.15rem 1.5rem;
  }

  .faq-a {
    font-size: 1.65rem;
    line-height: 1.65;
  }

  .faq-list {
    font-size: 1.65rem;
    line-height: 1.65;
    margin-left: 1.75rem;
  }

  .faq-cta-card {
    max-width: 380px;
  }

  .faq-link--channel {
    font-size: 1.05em;
  }

  .faq-section {
    margin-bottom: 3rem;
  }

  .faq-item {
    margin-bottom: 1rem;
  }

  .faq-item.is-open .faq-answer {
    padding: 0 1.5rem 1.5rem;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll(".faq-item .faq-q").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var item = this.closest(".faq-item");
      var answer = document.getElementById(this.getAttribute("aria-controls"));
      var isOpen = item.classList.toggle("is-open");
      this.setAttribute("aria-expanded", isOpen);
      if (answer) answer.setAttribute("aria-hidden", !isOpen);
    });
  });
});
</script>
