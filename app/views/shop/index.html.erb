<% content_for(:title) { "Shop" } %>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.0/dist/confetti.browser.min.js" crossorigin="anonymous"></script>

<div id="purchaseNotification" class="purchase-notification" aria-hidden="true">
  <div class="purchase-notification-content">
    <div class="purchase-notification-icon">✓</div>
    <div class="purchase-notification-text">
      <div class="purchase-notification-title">Purchase Successful!</div>
      <div class="purchase-notification-message" id="purchaseNotificationMessage"></div>
    </div>
  </div>
</div>

<div class="shop-page" data-shop-purchases-locked="<%= @shop_purchases_locked ? 'true' : 'false' %>">
  <button type="button" class="shop-rules-btn shop-addprize-btn shop-rules-btn--cube" id="addPrizeBtn" aria-label="Add Prize">
    <span class="shop-rules-btn-sr">Add Prize</span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/add_prize_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/add_prize_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/add_prize_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/add_prize_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
  </button>
  <button type="button" class="shop-rules-btn shop-rules-btn--cube" id="shopRulesBtn" aria-label="Shop Rules">
    <span class="shop-rules-btn-sr">Shop Rules</span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/shop_rules_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/shop_rules_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/shop_rules_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
    <span class="shop-rules-btn-face" aria-hidden="true"><%= image_tag "buttons/shop_rules_btn.png", alt: "", class: "shop-rules-btn-face-img" %></span>
  </button>
  <div class="shop-container">
    <div class="shop-layout">
      <div class="shop-left" aria-hidden="true">
        <div class="shop-character">
          <%= image_tag "dude.png", alt: "", class: "shop-dude" %>
          <%= image_tag "dialogue.png", alt: "", class: "shop-dialogue" %>
        </div>
      </div>
      <div class="shop-right">
        <div class="shop-top-bar">
          <div class="shop-upgrade-countdown" aria-live="polite">
            Next shop upgrade: <span id="shopUpgradeCountdown">--:--:--</span>
          </div>
          <% if admin? %>
            <label class="shop-reorder-toggle" for="shopReorderItems">
              <input type="checkbox" id="shopReorderItems" style="accent-color: #d4a017;">
              <span>Reorder items</span>
            </label>
          <% end %>
        </div>
        <div class="shop-category-selector" id="shopCategorySelector" aria-label="Shop categories">
          <% if @pinned_item.present? %>
            <div class="shop-card shop-card--pinned" data-item-id="<%= @pinned_item.id %>" data-item-price="<%= @pinned_item.price.to_f %>" style="justify-self: center;">
              <div class="shop-card-inner" style="padding: 0;">
                <div
                  class="shop-card-image"
                  style="
                    height: 100%;
                    background-image: url('<%= image_path("ticket Background Removed.png") %>');
                    background-size: contain;
                    background-position: center;
                    background-repeat: no-repeat;
                    border-radius: 10px;
                  "
                ></div>

                <% pinned_qty = @purchased_qty_by_item_id[@pinned_item.id].to_i %>
                <% pinned_limit_reached = @pinned_item.max_per_person.present? && pinned_qty >= @pinned_item.max_per_person.to_i %>
                <div class="shop-card-actions" style="position: absolute; left: 0; right: 0; bottom: 6px; z-index: 3; padding: 0;">
                  <button
                    type="button"
                    class="shop-buy-btn"
                    data-action="open-item-modal"
                    data-item-id="<%= @pinned_item.id %>"
                    data-item-name="<%= @pinned_item.name %>"
                    data-item-desc="<%= @pinned_item.description.to_s %>"
                    data-item-link="<%= @pinned_item.item_link.to_s %>"
                    data-item-price="<%= @pinned_item.price.to_f %>"
                    data-item-price-usd="<%= @pinned_item.price_usd.to_f if @pinned_item.price_usd.present? %>"
                    data-item-dollar-per-hour="<%= @pinned_item.dollar_per_hour.to_f if @pinned_item.dollar_per_hour.present? %>"
                    data-item-image="<%= image_path("ticket Background Removed.png") %>"
                    data-item-max-per-person="<%= @pinned_item.max_per_person.to_i if @pinned_item.max_per_person.present? %>"
                    data-item-purchased-qty="<%= pinned_qty %>"
                    <%= "disabled" if pinned_limit_reached %>
                  >Buy</button>
                </div>
                <div class="shop-price-badge" aria-hidden="true" style="z-index: 3;">
                  <%= image_tag "chips_price.png", alt: "", class: "shop-price-badge-img" %>
                  <span class="shop-price-badge-amount"><%= @pinned_item.display_price %></span>
                </div>
              </div>
            </div>
          <% end %>

          <% @shop_categories.each do |entry| %>
            <% cat = entry[:category] %>
            <button type="button" class="<%= class_names("shop-category-tile", "shop-category-tile--spotlight": ShopItem.spotlight_label?(cat.name) || ShopItem.spotlight_label?(cat.key)) %>" data-shop-category="<%= cat.key %>">
              <span class="shop-tile-title"><%= cat.name %></span>
              <% if cat.logo_url.present? %>
                <img class="shop-tile-logo" src="<%= cat.logo_url %>" alt="" loading="lazy">
              <% end %>
            </button>
          <% end %>
        </div>

        <div class="shop-category-view" id="shopCategoryView" hidden aria-hidden="true">
          <div class="shop-category-view-header">
            <button type="button" class="shop-category-back" id="shopCategoryBack">← Categories</button>
            <div class="shop-breadcrumb" aria-label="Current path">
              <button type="button" class="shop-breadcrumb-seg" id="shopBreadcrumbCategory"></button>
              <span class="shop-breadcrumb-sep" id="shopBreadcrumbSep" aria-hidden="true">/</span>
              <span class="shop-breadcrumb-current" id="shopBreadcrumbGrant"></span>
            </div>
          </div>

          <% @shop_categories.each do |entry| %>
            <% cat = entry[:category] %>
            <% grant_types = entry[:grant_types] %>
            <div class="shop-category-panel" data-shop-category-panel="<%= cat.key %>" hidden>
              <% vegas_category = ShopItem.spotlight_label?(cat.name) || ShopItem.spotlight_label?(cat.key) %>
              <% if vegas_category %>
                <div class="shop-grant-stage shop-grant-stage--vegas" data-shop-grant-selector>
                  <div class="shop-grant-selector">
                    <% grant_types.each do |gt_entry| %>
                      <% gt = gt_entry[:grant_type] %>
                      <button type="button" class="<%= class_names("shop-grant-tile", "shop-grant-tile--spotlight": ShopItem.spotlight_label?(gt.name) || ShopItem.spotlight_label?(gt.key)) %>" data-shop-grant-type="<%= gt.key %>">
                        <span class="shop-tile-title"><%= gt.name %></span>
                        <% if gt.logo_url.present? %>
                          <img class="shop-tile-logo" src="<%= gt.logo_url %>" alt="" loading="lazy">
                        <% end %>
                      </button>
                    <% end %>
                  </div>
                  <aside class="shop-grant-cta-column" aria-label="Las Vegas Hackathon signup">
                    <div class="shop-grant-cta-column-inner">
                      <span class="shop-grant-cta-kicker">Free signup</span>
                      <h3 class="shop-grant-cta-title">Las Vegas Hackathon</h3>
                      <p class="shop-grant-cta-text">Wanna join for <strong>FREE</strong>? Grab your spot.</p>
                      <%= link_to "https://jackpot.hackclub.com/hackathon_info", class: "rsvp-button" do %>
                        <span class="rsvp-button__label">Signup</span>
                      <% end %>
                    </div>
                  </aside>
                </div>
              <% else %>
                <div class="shop-grant-selector" data-shop-grant-selector>
                  <% grant_types.each do |gt_entry| %>
                    <% gt = gt_entry[:grant_type] %>
                    <button type="button" class="<%= class_names("shop-grant-tile", "shop-grant-tile--spotlight": ShopItem.spotlight_label?(gt.name) || ShopItem.spotlight_label?(gt.key)) %>" data-shop-grant-type="<%= gt.key %>">
                      <span class="shop-tile-title"><%= gt.name %></span>
                      <% if gt.logo_url.present? %>
                        <img class="shop-tile-logo" src="<%= gt.logo_url %>" alt="" loading="lazy">
                      <% end %>
                    </button>
                  <% end %>
                </div>
              <% end %>

              <div class="shop-grant-view" data-shop-grant-view hidden aria-hidden="true">
                <% grant_types.each do |gt_entry| %>
                  <% gt = gt_entry[:grant_type] %>
                  <% items = gt_entry[:items] %>
                  <div class="shop-grant-panel" data-shop-grant-panel="<%= gt.key %>" data-shop-grant-type-id="<%= gt.id %>" hidden>
                    <div class="shop-cards-pan" role="group" aria-label="<%= cat.name %> <%= gt.name %> items">
                      <div class="shop-grid">
                        <% items.each do |item| %>
                          <% purchased_qty = @purchased_qty_by_item_id[item.id].to_i %>
                          <% limit_reached = item.max_per_person.present? && purchased_qty >= item.max_per_person.to_i %>
                          <div class="<%= class_names("shop-card", "shop-card--spotlight": item.spotlight_shop_card?) %>" data-item-id="<%= item.id %>" data-item-price="<%= item.price.to_f %>">
                            <div class="shop-card-inner">
                              <% if item.image_url.present? %>
                                <div class="shop-card-image" style="background-image: url('<%= item.image_url %>');"></div>
                              <% else %>
                                <div class="shop-card-image shop-card-image-default"></div>
                              <% end %>
                              <div class="shop-card-body">
                                <h3 class="shop-card-name"><%= item.name %></h3>
                                <% if item.description.present? %>
                                  <p class="shop-card-desc"><%= item.description %></p>
                                <% end %>
                              </div>
                              <div class="shop-card-actions">
                                <button
                                  type="button"
                                  class="shop-buy-btn"
                                  data-action="open-item-modal"
                                  data-item-id="<%= item.id %>"
                                  data-item-name="<%= item.name %>"
                                  data-item-desc="<%= item.description.to_s %>"
                                  data-item-link="<%= item.item_link.to_s %>"
                                  data-item-price="<%= item.price.to_f %>"
                                  data-item-price-usd="<%= item.price_usd.to_f if item.price_usd.present? %>"
                                  data-item-dollar-per-hour="<%= item.dollar_per_hour.to_f if item.dollar_per_hour.present? %>"
                                  data-item-image="<%= item.image_url.to_s %>"
                                  data-item-max-per-person="<%= item.max_per_person.to_i if item.max_per_person.present? %>"
                                  data-item-purchased-qty="<%= purchased_qty %>"
                                  <%= "disabled" if limit_reached %>
                                >Buy</button>
                              </div>
                              <% if limit_reached %>
                                <div class="shop-limit-warning">Limit reached</div>
                              <% end %>
                              <div class="shop-price-badge" aria-hidden="true">
                                <%= image_tag "chips_price.png", alt: "", class: "shop-price-badge-img" %>
                                <span class="shop-price-badge-amount"><%= item.display_price %></span>
                              </div>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add prize modal -->
<div class="modal-overlay" id="addPrizeModal" aria-hidden="true">
  <div class="modal-content shop-rules-modal-content" role="dialog" aria-modal="true" aria-labelledby="addPrizeModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="addPrizeModalTitle">Add Prize</h3>
      <button type="button" class="modal-close" id="addPrizeModalClose" aria-label="Close">&times;</button>
    </div>
    <div class="shop-rules-modal-body">
      <p class="shop-rules-intro"><strong>HOW DOES THE DYNAMIC SHOP WORK?</strong></p>
      <p class="shop-rules-intro" style="margin-top: 10px;">
        Welcome! Did you know that all the rewards you see are dynamic, and new ones are added every week based on your requests? Here’s how it works!
      </p>
      <p class="shop-rules-intro" style="margin-top: 10px;">
        Submit your request in this document
        <a href="<%= req_item_path %>"><strong>HERE</strong></a>.
      </p>
      <p class="shop-rules-intro" style="margin-top: 10px;">
        <strong>NOTE:</strong> Choose carefully! You can request only one item every two weeks...but in return, we’ll make sure to add it ;)
      </p>
    </div>
  </div>
</div>

<!-- Shop rules modal (placeholder) -->
<div class="modal-overlay" id="shopRulesModal" aria-hidden="true">
  <div class="modal-content shop-rules-modal-content" role="dialog" aria-modal="true" aria-labelledby="shopRulesModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="shopRulesModalTitle">Shop Rules</h3>
      <button type="button" class="modal-close" id="shopRulesModalClose" aria-label="Close">&times;</button>
    </div>
    <div class="shop-rules-modal-body">
      <p class="shop-rules-intro">
        To make the in-person event possible, we’ll try to save on shipping costs. For this reason, the shop will be organized as follows:
      </p>

      <ul class="shop-rules-list">
        <li>
          All items listed are chosen by you, and their price will be based on the <strong>current US price at the time they are added</strong>.
        </li>
        <li>
          Fulfillment will be provided as an <strong>HCB grant (virtual card)</strong>, which <strong>you</strong> will use to order your prize from the most appropriate platform in your country (Amazon, Ikea, Temu, etc.).
          <br>
          <strong>NOTE:</strong> To avoid long fulfillment queues, <strong>reimbursements will not be accepted</strong>, only grants.
          <strong>DO NOT purchase the prize with your personal money!!</strong>
        </li>
        <li>
          All prizes in the shop will be priced at <strong>[50 Chips = $6]</strong>
          <strong>THIS IS THE CURRENCY THAT WILL BE GIVEN IN THE FINAL GRANT!!!</strong>
        </li>
        <li>
          If you need a top-up for shipping/customs/taxes, or if you simply need a higher amount to purchase the item in your country, you can request an additional amount using the <strong>“Shipping/Tax $ (Optional)”</strong> field at checkout (amounts are in US dollars).
        </li>
      </ul>
    </div>
  </div>
</div>

<!-- Item modal (same template as /deck modals) -->
<div class="modal-overlay" id="shopItemModal" aria-hidden="true">
  <div class="modal-content shop-item-modal-content" role="dialog" aria-modal="true" aria-labelledby="shopItemModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="shopItemModalTitle">Item</h3>
      <button type="button" class="modal-close" id="shopItemModalClose" aria-label="Close">&times;</button>
    </div>

    <div class="shop-item-modal-body">
      <div class="shop-item-hero">
        <div class="shop-item-hero-frame">
          <img id="shopItemModalImage" src="<%= image_path("coming_soon.png") %>" alt="" class="shop-item-hero-img">
        </div>
      </div>

      <div class="shop-item-modal-scroll">
        <p class="shop-item-modal-desc" id="shopItemModalDesc"></p>

        <div class="shop-item-modal-bottom">
          <div class="shop-item-form">
            <div class="shop-item-form-row">
              <label class="shop-item-label shop-item-label--qty" for="shopItemModalQty">
                <span>Quantity</span>
                <span class="shop-item-limit" id="shopItemModalLimit" hidden></span>
              </label>
              <input class="shop-item-input" id="shopItemModalQty" type="number" min="1" value="1">
            </div>

            <div class="shop-item-divider"></div>

            <div class="shop-item-form-row shop-item-form-row--shipping">
              <label class="shop-item-label shop-item-label--stacked" for="shopItemModalShippingUsd">
                <span>Shipping/Tax $</span>
                <span class="shop-item-label-sub">(Optional, USD)</span>
              </label>
              <div class="shop-item-shipping">
                <span class="shop-item-currency">$</span>
                <input class="shop-item-input shop-item-input--shipping" id="shopItemModalShippingUsd" type="number" min="0" step="0.01" value="0" inputmode="decimal">
                <span class="shop-item-hint" id="shopItemModalShippingMaxHint"></span>
              </div>
            </div>
          </div>

          <div class="shop-item-price-row">
            <div class="shop-item-price-pill" aria-hidden="true">
              <span class="shop-item-price-amount" id="shopItemModalTotal">0</span>
              <%= image_tag "chips_price.png", alt: "", class: "shop-item-price-chip" %>
            </div>
          </div>

          <div class="shop-item-error" id="shopItemModalError" hidden></div>

          <button type="button" class="shop-item-purchase-btn" id="shopItemModalPurchase">Purchase</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Shop rules acceptance popup (before purchase) -->
<div class="shop-modal-overlay" id="shopRulesAcceptOverlay" aria-hidden="true">
  <div class="shop-modal">
    <div class="shop-modal-header">
      <h3 class="shop-modal-title">Shop Rules</h3>
      <button type="button" class="shop-modal-close" id="shopRulesAcceptClose" aria-label="Close">&times;</button>
    </div>
    <div class="shop-modal-body">
      <p>Have you read the Shop Rules and do you understand and accept the conditions provided?</p>
      <label class="shop-rules-accept-label" style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; margin-top: 14px;">
        <input type="checkbox" id="shopRulesAcceptCheckbox" style="accent-color: #d4a017; margin-top: 3px;">
        <span>I have read the Shop Rules and understand and accept the conditions.</span>
      </label>
    </div>
    <div class="shop-modal-actions">
      <button type="button" class="shop-modal-cancel" id="shopRulesAcceptCancel">Cancel</button>
      <button type="button" class="shop-buy-btn shop-buy-confirm" id="shopRulesAcceptConfirm" disabled>Continue</button>
    </div>
  </div>
</div>

<!-- Maintenance popup (when purchases are locked) -->
<div class="shop-modal-overlay" id="shopMaintenanceOverlay" aria-hidden="true">
  <div class="shop-modal">
    <div class="shop-modal-header">
      <h3 class="shop-modal-title">Under maintenance</h3>
      <button type="button" class="shop-modal-close" id="shopMaintenanceClose" aria-label="Close">&times;</button>
    </div>
    <div class="shop-modal-body">
      <p>Hey! It looks like you're trying to purchase something, well... this function is now under maintenance. It will be available again soon!</p>
    </div>
    <div class="shop-modal-actions">
      <button type="button" class="shop-buy-btn shop-buy-confirm" id="shopMaintenanceOk">OK</button>
    </div>
  </div>
</div>

<!-- Purchase confirmation modal -->
<div class="shop-modal-overlay" id="shopBuyModal" aria-hidden="true">
  <div class="shop-modal">
    <div class="shop-modal-header">
      <h3 class="shop-modal-title">Confirm Purchase</h3>
      <button type="button" class="shop-modal-close" id="shopModalClose">&times;</button>
    </div>
    <div class="shop-modal-body">
      <p>Are you sure you want to buy <strong id="shopModalItemName"></strong>?</p>
      <div class="shop-modal-cost">
        <div class="shop-price-chip shop-price-chip-lg">
          <div class="shop-chip-avatar shop-chip-avatar-lg">
            <%= image_tag(
                  current_user.profile_photo_url || "https://avatars.githubusercontent.com/u/0",
                  alt: "chip",
                  class: "shop-chip-img",
                  loading: "eager"
                ) %>
            <div class="shop-chip-frame"></div>
          </div>
          <span class="shop-price-amount shop-price-amount-lg" id="shopModalPrice"></span>
        </div>
      </div>
      <p class="shop-modal-balance">Your balance: <strong id="shopModalBalance"><%= current_user.chip_am.to_f %></strong> chips</p>
    </div>
    <div class="shop-modal-actions">
      <button type="button" class="shop-modal-cancel" id="shopModalCancel">Cancel</button>
      <button type="button" class="shop-buy-btn shop-buy-confirm" id="shopModalConfirm">Confirm Purchase</button>
    </div>
  </div>
</div>

<script>
(function() {
  // This page is visited via Turbo; bind to turbo:load so it works after navigating away/back.
  // Also ensure we only register the turbo:load listener once per browser session.
  if (window.__shopTurboLoadListenerBound) return;
  window.__shopTurboLoadListenerBound = true;

  document.addEventListener('turbo:load', function() {
  if (!document.querySelector('.shop-page')) return;
  var shopPageEl = document.querySelector('.shop-page');
  var shopPurchasesLocked = shopPageEl && shopPageEl.getAttribute('data-shop-purchases-locked') === 'true';

  var shopMaintenanceOverlay = document.getElementById('shopMaintenanceOverlay');
  var shopMaintenanceClose = document.getElementById('shopMaintenanceClose');
  var shopMaintenanceOk = document.getElementById('shopMaintenanceOk');

  function openShopMaintenance() {
    if (!shopMaintenanceOverlay) return;
    shopMaintenanceOverlay.classList.add('active');
    shopMaintenanceOverlay.setAttribute('aria-hidden', 'false');
  }

  function closeShopMaintenance() {
    if (!shopMaintenanceOverlay) return;
    shopMaintenanceOverlay.classList.remove('active');
    shopMaintenanceOverlay.setAttribute('aria-hidden', 'true');
  }

  if (shopMaintenanceClose) shopMaintenanceClose.addEventListener('click', closeShopMaintenance);
  if (shopMaintenanceOk) shopMaintenanceOk.addEventListener('click', closeShopMaintenance);
  if (shopMaintenanceOverlay) {
    shopMaintenanceOverlay.addEventListener('click', function(e) {
      if (e.target === shopMaintenanceOverlay) closeShopMaintenance();
    });
  }

  var categorySelector = document.getElementById('shopCategorySelector');
  var categoryView = document.getElementById('shopCategoryView');
  var categoryBack = document.getElementById('shopCategoryBack');
  var breadcrumbCategory = document.getElementById('shopBreadcrumbCategory');
  var breadcrumbSep = document.getElementById('shopBreadcrumbSep');
  var breadcrumbGrant = document.getElementById('shopBreadcrumbGrant');
  var categoryPanels = document.querySelectorAll('[data-shop-category-panel]');
  var addPrizeBtn = document.getElementById('addPrizeBtn');
  var addPrizeModal = document.getElementById('addPrizeModal');
  var addPrizeModalClose = document.getElementById('addPrizeModalClose');
  var shopRulesBtn = document.getElementById('shopRulesBtn');
  var shopRulesModal = document.getElementById('shopRulesModal');
  var shopRulesModalClose = document.getElementById('shopRulesModalClose');
  var shopUpgradeCountdown = document.getElementById('shopUpgradeCountdown');
  var modal = document.getElementById('shopBuyModal');
  var modalClose = document.getElementById('shopModalClose');
  var modalCancel = document.getElementById('shopModalCancel');
  var modalConfirm = document.getElementById('shopModalConfirm');
  var modalItemName = document.getElementById('shopModalItemName');
  var modalPrice = document.getElementById('shopModalPrice');
  var modalBalance = document.getElementById('shopModalBalance');
  var notification = document.getElementById('purchaseNotification');
  var notificationMessage = document.getElementById('purchaseNotificationMessage');
  var currentItemId = null;
  var currentItemName = null;

  function openModal(itemId, itemName, price) {
    currentItemId = itemId;
    currentItemName = itemName;
    modalItemName.textContent = itemName;
    modalPrice.textContent = price;
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    currentItemId = null;
  }

  function openAddPrizeModal() {
    if (!addPrizeModal) return;
    addPrizeModal.classList.add('active');
    addPrizeModal.setAttribute('aria-hidden', 'false');
  }

