<% content_for(:title) { "Shop" } %>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.0/dist/confetti.browser.min.js" crossorigin="anonymous"></script>

<div id="purchaseNotification" class="purchase-notification" aria-hidden="true">
  <div class="purchase-notification-content">
    <div class="purchase-notification-icon">✓</div>
    <div class="purchase-notification-text">
      <div class="purchase-notification-title">Purchase Successful!</div>
      <div class="purchase-notification-message" id="purchaseNotificationMessage"></div>
    </div>
  </div>
</div>

<div class="shop-page">
  <button type="button" class="shop-rules-btn shop-rules-btn--cube" id="shopRulesBtn" aria-label="Shop Rules">
    <span class="shop-rules-btn-sr">Shop Rules</span>
    <span class="shop-rules-btn-face" aria-hidden="true">Shop Rules</span>
    <span class="shop-rules-btn-face" aria-hidden="true">Shop Rules</span>
    <span class="shop-rules-btn-face" aria-hidden="true">Shop Rules</span>
    <span class="shop-rules-btn-face" aria-hidden="true">Shop Rules</span>
  </button>
  <div class="shop-container">
    <div class="shop-layout">
      <div class="shop-left" aria-hidden="true">
        <div class="shop-character">
          <%= image_tag "dude.png", alt: "", class: "shop-dude" %>
          <%= image_tag "dialogue.png", alt: "", class: "shop-dialogue" %>
        </div>
      </div>
      <div class="shop-right">
        <div class="shop-category-selector" id="shopCategorySelector" aria-label="Shop categories">
          <% @shop_categories.each do |entry| %>
            <% cat = entry[:category] %>
            <button type="button" class="shop-category-tile" data-shop-category="<%= cat.key %>">
              <span class="shop-tile-title"><%= cat.name %></span>
              <% if cat.logo_url.present? %>
                <img class="shop-tile-logo" src="<%= cat.logo_url %>" alt="" loading="lazy">
              <% end %>
            </button>
          <% end %>
        </div>

        <div class="shop-category-view" id="shopCategoryView" hidden aria-hidden="true">
          <div class="shop-category-view-header">
            <button type="button" class="shop-category-back" id="shopCategoryBack">← Categories</button>
            <div class="shop-breadcrumb" aria-label="Current path">
              <button type="button" class="shop-breadcrumb-seg" id="shopBreadcrumbCategory"></button>
              <span class="shop-breadcrumb-sep" id="shopBreadcrumbSep" aria-hidden="true">/</span>
              <span class="shop-breadcrumb-current" id="shopBreadcrumbGrant"></span>
            </div>
          </div>

          <% @shop_categories.each do |entry| %>
            <% cat = entry[:category] %>
            <% grant_types = entry[:grant_types] %>
            <div class="shop-category-panel" data-shop-category-panel="<%= cat.key %>" hidden>
              <div class="shop-grant-selector" data-shop-grant-selector>
                <% grant_types.each do |gt_entry| %>
                  <% gt = gt_entry[:grant_type] %>
                  <button type="button" class="shop-grant-tile" data-shop-grant-type="<%= gt.key %>">
                    <span class="shop-tile-title"><%= gt.name %></span>
                    <% if gt.logo_url.present? %>
                      <img class="shop-tile-logo" src="<%= gt.logo_url %>" alt="" loading="lazy">
                    <% end %>
                  </button>
                <% end %>
              </div>

              <div class="shop-grant-view" data-shop-grant-view hidden aria-hidden="true">
                <% grant_types.each do |gt_entry| %>
                  <% gt = gt_entry[:grant_type] %>
                  <% items = gt_entry[:items] %>
                  <div class="shop-grant-panel" data-shop-grant-panel="<%= gt.key %>" hidden>
                    <div class="shop-cards-pan" role="group" aria-label="<%= cat.name %> <%= gt.name %> items">
                      <div class="shop-grid">
                        <% items.each do |item| %>
                          <div class="shop-card" data-item-id="<%= item.id %>" data-item-price="<%= item.price.to_f %>">
                            <div class="shop-card-inner">
                              <% if item.image_url.present? %>
                                <div class="shop-card-image" style="background-image: url('<%= item.image_url %>');"></div>
                              <% else %>
                                <div class="shop-card-image shop-card-image-default"></div>
                              <% end %>
                              <div class="shop-card-body">
                                <h3 class="shop-card-name"><%= item.name %></h3>
                                <% if item.description.present? %>
                                  <p class="shop-card-desc"><%= item.description %></p>
                                <% end %>
                              </div>
                              <div class="shop-card-actions">
                                <button
                                  type="button"
                                  class="shop-buy-btn"
                                  data-action="open-item-modal"
                                  data-item-id="<%= item.id %>"
                                  data-item-name="<%= item.name %>"
                                  data-item-desc="<%= item.description.to_s %>"
                                  data-item-link="<%= item.item_link.to_s %>"
                                  data-item-price="<%= item.price.to_f %>"
                                  data-item-image="<%= item.image_url.to_s %>"
                                >Buy</button>
                              </div>
                              <div class="shop-price-badge" aria-hidden="true">
                                <%= image_tag "chips_price.png", alt: "", class: "shop-price-badge-img" %>
                                <span class="shop-price-badge-amount"><%= item.price.to_f %></span>
                              </div>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Shop rules modal (placeholder) -->
<div class="modal-overlay" id="shopRulesModal" aria-hidden="true">
  <div class="modal-content shop-rules-modal-content" role="dialog" aria-modal="true" aria-labelledby="shopRulesModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="shopRulesModalTitle">Shop Rules</h3>
      <button type="button" class="modal-close" id="shopRulesModalClose" aria-label="Close">&times;</button>
    </div>
    <div class="shop-rules-modal-body">
      <p class="shop-rules-intro">
        To make the in-person event possible, we’ll try to save on shipping costs. For this reason, the shop will be organized as follows:
      </p>

      <ul class="shop-rules-list">
        <li>
          All items listed are chosen by you, and their price will be based on the <strong>current US price at the time they are added</strong>.
        </li>
        <li>
          Fulfillment will be provided as an <strong>HCB grant (virtual card)</strong>, which <strong>you</strong> will use to order your prize from the most appropriate platform in your country (Amazon, Ikea, Temu, etc.).
          <br>
          <strong>NOTE:</strong> To avoid long fulfillment queues, <strong>reimbursements will not be accepted</strong>, only grants.
          <strong>DO NOT purchase the prize with your personal money!!</strong> (except for flight stipends/VISA once you are invited to the Las Vegas event).
        </li>
        <li>
          All prizes in the shop will be priced at <strong>[50 Chips = $4]</strong>, except for items related to the in-person event (e.g. flight stipend or VISA), which will have a higher rate (likely around <strong>$8.5</strong>).
          <strong>THIS IS THE CURRENCY THAT WILL BE GIVEN IN THE FINAL GRANT!!!</strong>
        </li>
        <li>
          If you need a top-up for shipping/customs/taxes, or if you simply need a higher amount to purchase the item in your country, you can request an additional amount using the <strong>“Shipping/Tax (Optional)”</strong> field at checkout.
        </li>
      </ul>
    </div>
  </div>
</div>

<!-- Item modal (same template as /deck modals) -->
<div class="modal-overlay" id="shopItemModal" aria-hidden="true">
  <div class="modal-content shop-item-modal-content" role="dialog" aria-modal="true" aria-labelledby="shopItemModalTitle">
    <div class="modal-header">
      <h3 class="modal-title" id="shopItemModalTitle">Item</h3>
      <button type="button" class="modal-close" id="shopItemModalClose" aria-label="Close">&times;</button>
    </div>

    <div class="shop-item-modal-body">
      <div class="shop-item-hero">
        <div class="shop-item-hero-frame">
          <img id="shopItemModalImage" src="<%= image_path("coming_soon.png") %>" alt="" class="shop-item-hero-img">
        </div>
      </div>

      <div class="shop-item-modal-scroll">
        <p class="shop-item-modal-desc" id="shopItemModalDesc"></p>

        <div class="shop-item-modal-bottom">
          <div class="shop-item-form">
            <div class="shop-item-form-row">
              <label class="shop-item-label" for="shopItemModalQty">Quantity</label>
              <input class="shop-item-input" id="shopItemModalQty" type="number" min="1" value="1">
            </div>

            <div class="shop-item-divider"></div>

            <div class="shop-item-form-row shop-item-form-row--shipping">
              <label class="shop-item-label shop-item-label--stacked" for="shopItemModalShipping">
                <span>Shipping/Tax</span>
                <span class="shop-item-label-sub">(Optional)</span>
              </label>
              <div class="shop-item-shipping">
                <span class="shop-item-currency">+</span>
                <input class="shop-item-input shop-item-input--shipping" id="shopItemModalShipping" type="number" min="0" value="0">
                <span class="shop-item-hint">(50 Chips = $4.5)</span>
              </div>
            </div>
          </div>

          <div class="shop-item-price-row">
            <div class="shop-item-price-pill" aria-hidden="true">
              <span class="shop-item-price-amount" id="shopItemModalTotal">0</span>
              <%= image_tag "chips_price.png", alt: "", class: "shop-item-price-chip" %>
            </div>
          </div>

          <div class="shop-item-error" id="shopItemModalError" hidden></div>

          <button type="button" class="shop-item-purchase-btn" id="shopItemModalPurchase">Purchase</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Purchase confirmation modal -->
<div class="shop-modal-overlay" id="shopBuyModal" aria-hidden="true">
  <div class="shop-modal">
    <div class="shop-modal-header">
      <h3 class="shop-modal-title">Confirm Purchase</h3>
      <button type="button" class="shop-modal-close" id="shopModalClose">&times;</button>
    </div>
    <div class="shop-modal-body">
      <p>Are you sure you want to buy <strong id="shopModalItemName"></strong>?</p>
      <div class="shop-modal-cost">
        <div class="shop-price-chip shop-price-chip-lg">
          <div class="shop-chip-avatar shop-chip-avatar-lg">
            <%= image_tag(
                  current_user.profile_photo_url || "https://avatars.githubusercontent.com/u/0",
                  alt: "chip",
                  class: "shop-chip-img",
                  loading: "eager"
                ) %>
            <div class="shop-chip-frame"></div>
          </div>
          <span class="shop-price-amount shop-price-amount-lg" id="shopModalPrice"></span>
        </div>
      </div>
      <p class="shop-modal-balance">Your balance: <strong id="shopModalBalance"><%= current_user.chip_am.to_f %></strong> chips</p>
    </div>
    <div class="shop-modal-actions">
      <button type="button" class="shop-modal-cancel" id="shopModalCancel">Cancel</button>
      <button type="button" class="shop-buy-btn shop-buy-confirm" id="shopModalConfirm">Confirm Purchase</button>
    </div>
  </div>
</div>

<script>
(function() {
  // This page is visited via Turbo; bind to turbo:load so it works after navigating away/back.
  // Also ensure we only register the turbo:load listener once per browser session.
  if (window.__shopTurboLoadListenerBound) return;
  window.__shopTurboLoadListenerBound = true;

  document.addEventListener('turbo:load', function() {
  if (!document.querySelector('.shop-page')) return;
  var categorySelector = document.getElementById('shopCategorySelector');
  var categoryView = document.getElementById('shopCategoryView');
  var categoryBack = document.getElementById('shopCategoryBack');
  var breadcrumbCategory = document.getElementById('shopBreadcrumbCategory');
  var breadcrumbSep = document.getElementById('shopBreadcrumbSep');
  var breadcrumbGrant = document.getElementById('shopBreadcrumbGrant');
  var categoryPanels = document.querySelectorAll('[data-shop-category-panel]');
  var shopRulesBtn = document.getElementById('shopRulesBtn');
  var shopRulesModal = document.getElementById('shopRulesModal');
  var shopRulesModalClose = document.getElementById('shopRulesModalClose');
  var modal = document.getElementById('shopBuyModal');
  var modalClose = document.getElementById('shopModalClose');
  var modalCancel = document.getElementById('shopModalCancel');
  var modalConfirm = document.getElementById('shopModalConfirm');
  var modalItemName = document.getElementById('shopModalItemName');
  var modalPrice = document.getElementById('shopModalPrice');
  var modalBalance = document.getElementById('shopModalBalance');
  var notification = document.getElementById('purchaseNotification');
  var notificationMessage = document.getElementById('purchaseNotificationMessage');
  var currentItemId = null;
  var currentItemName = null;

  function openModal(itemId, itemName, price) {
    currentItemId = itemId;
    currentItemName = itemName;
    modalItemName.textContent = itemName;
    modalPrice.textContent = price;
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    currentItemId = null;
  }

  function openShopRulesModal() {
    if (!shopRulesModal) return;
    shopRulesModal.classList.add('active');
    shopRulesModal.setAttribute('aria-hidden', 'false');
  }

  function closeShopRulesModal() {
    if (!shopRulesModal) return;
    shopRulesModal.classList.remove('active');
    shopRulesModal.setAttribute('aria-hidden', 'true');
  }

  function setHidden(el, isHidden) {
    if (!el) return;
    el.hidden = !!isHidden;
    el.setAttribute('aria-hidden', isHidden ? 'true' : 'false');
    // Extra hardening: if some CSS overrides [hidden], enforce display.
    el.style.display = isHidden ? 'none' : '';
  }

  function showCategorySelector() {
    setHidden(categorySelector, false);
    setHidden(categoryView, true);
    categoryPanels.forEach(function(p) { setHidden(p, true); });
    if (breadcrumbCategory) breadcrumbCategory.textContent = '';
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
  }

  function showCategory(categoryKey, label) {
    setHidden(categorySelector, true);
    setHidden(categoryView, false);
    if (breadcrumbCategory) breadcrumbCategory.textContent = label || 'Category';
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
    categoryPanels.forEach(function(p) {
      setHidden(p, p.getAttribute('data-shop-category-panel') !== categoryKey);
    });

    // Reset 2nd layer (Grant Type) when entering a category.
    var activePanel = Array.prototype.find.call(categoryPanels, function(p) {
      return p.getAttribute('data-shop-category-panel') === categoryKey;
    });
    if (activePanel) {
      var grantSelector = activePanel.querySelector('[data-shop-grant-selector]');
      var grantView = activePanel.querySelector('[data-shop-grant-view]');
      var grantPanels = activePanel.querySelectorAll('[data-shop-grant-panel]');
      setHidden(grantSelector, false);
      setHidden(grantView, true);
      grantPanels.forEach(function(gp) { setHidden(gp, true); });
    }
  }

  function showGrantType(categoryPanel, grantKey, label) {
    if (!categoryPanel) return;
    var grantSelector = categoryPanel.querySelector('[data-shop-grant-selector]');
    var grantView = categoryPanel.querySelector('[data-shop-grant-view]');
    var grantPanels = categoryPanel.querySelectorAll('[data-shop-grant-panel]');
    setHidden(grantSelector, true);
    setHidden(grantView, false);
    if (breadcrumbSep) setHidden(breadcrumbSep, false);
    if (breadcrumbGrant) {
      breadcrumbGrant.textContent = label || 'Grant Type';
      setHidden(breadcrumbGrant, false);
    }
    grantPanels.forEach(function(gp) {
      setHidden(gp, gp.getAttribute('data-shop-grant-panel') !== grantKey);
    });

    // If the selected grant type has a draggable pan grid, initialize it.
    setTimeout(initVisiblePan, 0);
  }

  function showGrantTypeSelector(categoryPanel) {
    if (!categoryPanel) return;
    var grantSelector = categoryPanel.querySelector('[data-shop-grant-selector]');
    var grantView = categoryPanel.querySelector('[data-shop-grant-view]');
    var grantPanels = categoryPanel.querySelectorAll('[data-shop-grant-panel]');
    setHidden(grantSelector, false);
    setHidden(grantView, true);
    grantPanels.forEach(function(gp) { setHidden(gp, true); });
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
  }

  var itemModal = document.getElementById('shopItemModal');
  var itemModalClose = document.getElementById('shopItemModalClose');
  var itemModalTitle = document.getElementById('shopItemModalTitle');
  var itemModalDesc = document.getElementById('shopItemModalDesc');
  var itemModalQty = document.getElementById('shopItemModalQty');
  var itemModalShipping = document.getElementById('shopItemModalShipping');
  var itemModalTotal = document.getElementById('shopItemModalTotal');
  var itemModalError = document.getElementById('shopItemModalError');
  var itemModalPurchase = document.getElementById('shopItemModalPurchase');

  var itemModalCurrent = { id: null, name: null, link: null, basePrice: 0 };

  function toNumber(v) {
    var n = parseFloat(String(v || '').replace(/,/g, ''));
    return Number.isFinite(n) ? n : 0;
  }

  function updateItemModalTotals() {
    if (!itemModalTotal) return;
    var qty = Math.max(1, parseInt(itemModalQty && itemModalQty.value, 10) || 1);
    if (itemModalQty) itemModalQty.value = String(qty);
    var shipping = Math.max(0, toNumber(itemModalShipping && itemModalShipping.value));
    if (itemModalShipping) itemModalShipping.value = String(shipping);
    var total = (itemModalCurrent.basePrice * qty) + shipping;
    itemModalTotal.textContent = (total % 1 === 0) ? String(Math.round(total)) : String(total.toFixed(1));
  }

  function openItemModal(data) {
     if (!itemModal) return;
     itemModalTitle.textContent = data.name || 'Item';
     itemModalDesc.textContent = data.desc || '';
     itemModalCurrent.id = data.id || null;
     itemModalCurrent.name = data.name || '';
     itemModalCurrent.link = data.link || '';
     itemModalCurrent.basePrice = toNumber(data.price);

     var imgEl = document.getElementById('shopItemModalImage');
     if (imgEl && data.image) {
       imgEl.src = data.image;
     }

     if (itemModalQty) itemModalQty.value = '1';
     if (itemModalShipping) itemModalShipping.value = '0';
     if (itemModalError) itemModalError.hidden = true;
     updateItemModalTotals();

     if (itemModalPurchase) itemModalPurchase.disabled = !data.id;

     itemModal.classList.add('active');
     itemModal.setAttribute('aria-hidden', 'false');
   }

  function closeItemModal() {
    if (!itemModal) return;
    itemModal.classList.remove('active');
    itemModal.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll('[data-action="open-item-modal"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.disabled) return;
      openItemModal({
        id: btn.dataset.itemId,
        name: btn.dataset.itemName,
        desc: btn.dataset.itemDesc,
        link: btn.dataset.itemLink,
        price: btn.dataset.itemPrice || '0',
        image: btn.dataset.itemImage
      });
    });
  });

  if (shopRulesBtn) shopRulesBtn.onclick = openShopRulesModal;
  if (shopRulesModalClose) shopRulesModalClose.onclick = closeShopRulesModal;
  if (shopRulesModal) {
    shopRulesModal.addEventListener('click', function(e) {
      if (e.target === shopRulesModal) closeShopRulesModal();
    });
  }

  // Category picker → show cards for that category
  if (categorySelector) {
    categorySelector.onclick = function(e) {
      var btn = e.target && e.target.closest && e.target.closest('[data-shop-category]');
      if (!btn) return;
      showCategory(btn.getAttribute('data-shop-category'), (btn.textContent || '').trim());
    };
  }
  if (categoryBack) categoryBack.onclick = showCategorySelector;

  // Grant type picker (inside a category) → show models for that grant type
  if (categoryView) {
    categoryView.onclick = function(e) {
      var grantTile = e.target && e.target.closest && e.target.closest('[data-shop-grant-type]');
      if (grantTile) {
        var catPanel = grantTile.closest('[data-shop-category-panel]');
        showGrantType(catPanel, grantTile.getAttribute('data-shop-grant-type'), (grantTile.textContent || '').trim());
        return;
      }
    };
  }

  // Breadcrumb: clicking the category part returns to Grant Types (inside the current category).
  if (breadcrumbCategory) {
    breadcrumbCategory.onclick = function() {
      if (!categoryView || categoryView.hidden) return;
      var activeCategoryPanel = Array.prototype.find.call(categoryPanels, function(p) { return !p.hidden; });
      if (!activeCategoryPanel) return;
      showGrantTypeSelector(activeCategoryPanel);
    };
  }

  // Default state: show only categories until one is chosen.
  showCategorySelector();

  if (itemModalQty) itemModalQty.addEventListener('input', updateItemModalTotals);
  if (itemModalShipping) itemModalShipping.addEventListener('input', updateItemModalTotals);

  if (itemModalPurchase) {
    itemModalPurchase.addEventListener('click', function() {
      if (!itemModalCurrent.id) return;
      var qty = Math.max(1, parseInt(itemModalQty && itemModalQty.value, 10) || 1);
      itemModalPurchase.disabled = true;
      itemModalPurchase.textContent = 'Processing...';
      if (itemModalError) itemModalError.hidden = true;

      fetch('<%= buy_shop_item_path(":id") %>'.replace('%3Aid', itemModalCurrent.id).replace(':id', itemModalCurrent.id), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ quantity: qty })
      })
      .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
      .then(function(result) {
        if (result.ok && result.data.success) {
          confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
          closeItemModal();
          notificationMessage.textContent = 'Your purchase for ' + (itemModalCurrent.name || 'item') + ' is successful!';
          notification.classList.add('show');
          notification.setAttribute('aria-hidden', 'false');
          var tokenEl = document.querySelector('.token-count');
          if (tokenEl) tokenEl.textContent = result.data.new_balance;
          modalBalance.textContent = result.data.new_balance;
          setTimeout(function() {
            notification.classList.remove('show');
            notification.setAttribute('aria-hidden', 'true');
            setTimeout(function() { location.reload(); }, 300);
          }, 3000);
        } else {
          if (itemModalError) {
            itemModalError.textContent = result.data.error || 'Purchase failed.';
            itemModalError.hidden = false;
          } else {
            alert(result.data.error || 'Purchase failed.');
          }
        }
      })
      .catch(function(e) {
        console.error('Purchase error:', e);
        if (itemModalError) {
          itemModalError.textContent = 'Something went wrong. Please try again.';
          itemModalError.hidden = false;
        } else {
          alert('Something went wrong. Please try again.');
        }
      })
      .finally(function() {
        itemModalPurchase.disabled = !itemModalCurrent.id;
        itemModalPurchase.textContent = 'Purchase';
      });
    });
  }

  if (itemModalClose) itemModalClose.addEventListener('click', closeItemModal);
  if (itemModal) {
    itemModal.addEventListener('click', function(e) {
      if (e.target === itemModal) closeItemModal();
    });
  }

  if (modalClose) modalClose.addEventListener('click', closeModal);
  if (modalCancel) modalCancel.addEventListener('click', closeModal);
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
  }

  if (modalConfirm) {
    modalConfirm.addEventListener('click', function() {
      if (!currentItemId) return;
      modalConfirm.disabled = true;
      modalConfirm.textContent = 'Processing...';

      fetch('<%= buy_shop_item_path(":id") %>'.replace('%3Aid', currentItemId).replace(':id', currentItemId), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ quantity: 1 })
      })
      .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
      .then(function(result) {
        if (result.ok && result.data.success) {
          // Trigger confetti
          confetti({
            particleCount: 100,
            spread: 70,
            origin: { y: 0.6 }
          });
          
          closeModal();
          
          // Show notification
          notificationMessage.textContent = 'Your purchase for ' + currentItemName + ' is successful!';
          notification.classList.add('show');
          notification.setAttribute('aria-hidden', 'false');
          
          // Update balance in toolbar
          var tokenEl = document.querySelector('.token-count');
          if (tokenEl) tokenEl.textContent = result.data.new_balance;
          modalBalance.textContent = result.data.new_balance;
          
          // Hide notification and reload after 3 seconds
          setTimeout(function() {
            notification.classList.remove('show');
            notification.setAttribute('aria-hidden', 'true');
            setTimeout(function() {
              location.reload();
            }, 300);
          }, 3000);
        } else {
          alert(result.data.error || 'Purchase failed.');
          modalConfirm.disabled = false;
          modalConfirm.textContent = 'Confirm Purchase';
        }
      })
      .catch(function(e) {
        console.error('Purchase error:', e);
        alert('Something went wrong. Please try again.');
        modalConfirm.disabled = false;
        modalConfirm.textContent = 'Confirm Purchase';
      });
    });
  }

  // Avoid accumulating Escape handlers across multiple Shop visits.
  if (window.__shopKeydownHandler) {
    document.removeEventListener('keydown', window.__shopKeydownHandler);
  }
  window.__shopKeydownHandler = function(e) {
    if (e.key === 'Escape') {
      closeItemModal();
      closeShopRulesModal();
      closeModal();
    }
  };
  document.addEventListener('keydown', window.__shopKeydownHandler);

  // Draggable pan: move all cards together (drag threshold so Buy button clicks still work)
  function initPan(pan) {
    if (!pan || pan.dataset.shopPanBound === '1') return;
    pan.dataset.shopPanBound = '1';

    var panStartX, panStartY, panTranslateX = 0, panTranslateY = 0, panDragging = false, panHasMoved = false, panDidDrag = false;
    var DRAG_THRESHOLD = 5;

    function isInteractiveTarget(target) {
      var el = (target && target.nodeType === 1) ? target : (target && target.parentElement);
      return !!(el && (el.closest('button') || el.closest('a')));
    }

    function getClientXY(e) {
      if (e.touches && e.touches.length) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
      return { x: e.clientX, y: e.clientY };
    }

    function onPanPointerDown(e) {
      if (isInteractiveTarget(e.target)) return;
      var p = getClientXY(e);
      panStartX = p.x; panStartY = p.y;
      panDragging = false; panHasMoved = false; panDidDrag = false;
      pan.classList.add('shop-cards-pan--grabbing');
      document.addEventListener('mousemove', onPanPointerMove);
      document.addEventListener('mouseup', onPanPointerUp);
      if (e.type === 'touchstart') {
        document.addEventListener('touchmove', onPanPointerMove, { passive: false });
        document.addEventListener('touchend', onPanPointerUp);
      }
    }

    function onPanPointerMove(e) {
      var p = getClientXY(e);
      var dx = p.x - panStartX, dy = p.y - panStartY;
      if (!panHasMoved && (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD)) {
        panHasMoved = true;
        panDragging = true;
      }
      if (panDragging) {
        e.preventDefault();
        panDidDrag = true;
        panTranslateX += dx; panTranslateY += dy;
        panStartX = p.x; panStartY = p.y;
        pan.style.transform = 'translate(' + panTranslateX + 'px, ' + panTranslateY + 'px)';
      }
    }

    function onPanPointerUp() {
      pan.classList.remove('shop-cards-pan--grabbing');
      document.removeEventListener('mousemove', onPanPointerMove);
      document.removeEventListener('mouseup', onPanPointerUp);
      document.removeEventListener('touchmove', onPanPointerMove);
      document.removeEventListener('touchend', onPanPointerUp);
      panDragging = false;
    }

    pan.addEventListener('click', function(e) {
      // Never block real button/link clicks.
      if (isInteractiveTarget(e.target)) {
        panDidDrag = false;
        return;
      }
      // Only suppress clicks that were actually a drag.
      if (panDidDrag) {
        e.preventDefault();
        e.stopPropagation();
        panDidDrag = false;
      }
    }, true);

    pan.addEventListener('mousedown', onPanPointerDown);
    pan.addEventListener('touchstart', onPanPointerDown, { passive: true });
  }

  function initVisiblePan() {
    var visiblePan = document.querySelector(
      '.shop-category-view:not([hidden]) .shop-category-panel:not([hidden]) .shop-grant-view:not([hidden]) .shop-grant-panel:not([hidden]) .shop-cards-pan'
    );
    initPan(visiblePan);
  }
  });
})();
</script>
