  // Countdown to next Friday 00:00 in America/New_York (EST/EDT), loops weekly.
  function tzParts(date, timeZone) {
    var dtf = new Intl.DateTimeFormat('en-US', {
      timeZone: timeZone,
      hour12: false,
      weekday: 'short',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    });
    var parts = dtf.formatToParts(date);
    var out = {};
    parts.forEach(function(p) { if (p.type !== 'literal') out[p.type] = p.value; });
    return out;
  }

  function tzOffsetMs(date, timeZone) {
    var p = tzParts(date, timeZone);
    var asUtc = Date.UTC(
      parseInt(p.year, 10),
      parseInt(p.month, 10) - 1,
      parseInt(p.day, 10),
      parseInt(p.hour, 10),
      parseInt(p.minute, 10),
      parseInt(p.second, 10)
    );
    return asUtc - date.getTime();
  }

  function zonedTimeToUtcMs(ymdhms, timeZone) {
    var utcGuess = Date.UTC(ymdhms.year, ymdhms.month - 1, ymdhms.day, ymdhms.hour, ymdhms.minute, ymdhms.second);
    var d1 = new Date(utcGuess);
    var off1 = tzOffsetMs(d1, timeZone);
    var utc1 = utcGuess - off1;
    var d2 = new Date(utc1);
    var off2 = tzOffsetMs(d2, timeZone);
    return utcGuess - off2;
  }

  function nextFridayMidnightUtcMs(now) {
    var tz = 'America/New_York';
    var p = tzParts(now, tz);
    var weekdayMap = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
    var dow = weekdayMap[p.weekday] == null ? 0 : weekdayMap[p.weekday];
    var hour = parseInt(p.hour, 10);
    var minute = parseInt(p.minute, 10);
    var second = parseInt(p.second, 10);

    var days = (5 - dow + 7) % 7; // 5 = Friday
    if (days === 0 && (hour > 0 || minute > 0 || second > 0)) days = 7;

    // Use "today at noon" in NY to safely add days across months/DST.
    var baseNoonUtc = zonedTimeToUtcMs({
      year: parseInt(p.year, 10),
      month: parseInt(p.month, 10),
      day: parseInt(p.day, 10),
      hour: 12, minute: 0, second: 0
    }, tz);
    var fridayNoonUtc = baseNoonUtc + (days * 86400000);
    var fri = tzParts(new Date(fridayNoonUtc), tz);

    return zonedTimeToUtcMs({
      year: parseInt(fri.year, 10),
      month: parseInt(fri.month, 10),
      day: parseInt(fri.day, 10),
      hour: 0, minute: 0, second: 0
    }, tz);
  }

  function pad2(n) { return String(n).padStart(2, '0'); }
  function renderCountdown() {
    if (!shopUpgradeCountdown) return;
    var now = new Date();
    var target = nextFridayMidnightUtcMs(now);
    var ms = target - now.getTime();
    if (ms < 0) ms = 0;

    var totalSeconds = Math.floor(ms / 1000);
    var days = Math.floor(totalSeconds / 86400);
    var hours = Math.floor((totalSeconds % 86400) / 3600);
    var minutes = Math.floor((totalSeconds % 3600) / 60);
    var seconds = totalSeconds % 60;
    shopUpgradeCountdown.textContent = pad2(days) + ':' + pad2(hours) + ':' + pad2(minutes) + ':' + pad2(seconds);
  }

  if (window.__shopUpgradeCountdownInterval) {
    clearInterval(window.__shopUpgradeCountdownInterval);
    window.__shopUpgradeCountdownInterval = null;
  }
  renderCountdown();
  window.__shopUpgradeCountdownInterval = setInterval(renderCountdown, 1000);

  function setHidden(el, isHidden) {
    if (!el) return;
    el.hidden = !!isHidden;
    el.setAttribute('aria-hidden', isHidden ? 'true' : 'false');
    // Extra hardening: if some CSS overrides [hidden], enforce display.
    el.style.display = isHidden ? 'none' : '';
  }

  function showCategorySelector() {
    setHidden(categorySelector, false);
    setHidden(categoryView, true);
    categoryPanels.forEach(function(p) { setHidden(p, true); });
    if (breadcrumbCategory) breadcrumbCategory.textContent = '';
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
  }

  function showCategory(categoryKey, label) {
    setHidden(categorySelector, true);
    setHidden(categoryView, false);
    if (breadcrumbCategory) breadcrumbCategory.textContent = label || 'Category';
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
    categoryPanels.forEach(function(p) {
      setHidden(p, p.getAttribute('data-shop-category-panel') !== categoryKey);
    });

    // Reset 2nd layer (Grant Type) when entering a category.
    var activePanel = Array.prototype.find.call(categoryPanels, function(p) {
      return p.getAttribute('data-shop-category-panel') === categoryKey;
    });
    if (activePanel) {
      var grantSelector = activePanel.querySelector('[data-shop-grant-selector]');
      var grantView = activePanel.querySelector('[data-shop-grant-view]');
      var grantPanels = activePanel.querySelectorAll('[data-shop-grant-panel]');
      setHidden(grantSelector, false);
      setHidden(grantView, true);
      grantPanels.forEach(function(gp) { setHidden(gp, true); });
    }
  }

  function showGrantType(categoryPanel, grantKey, label) {
    if (!categoryPanel) return;
    var grantSelector = categoryPanel.querySelector('[data-shop-grant-selector]');
    var grantView = categoryPanel.querySelector('[data-shop-grant-view]');
    var grantPanels = categoryPanel.querySelectorAll('[data-shop-grant-panel]');
    setHidden(grantSelector, true);
    setHidden(grantView, false);
    if (breadcrumbSep) setHidden(breadcrumbSep, false);
    if (breadcrumbGrant) {
      breadcrumbGrant.textContent = label || 'Grant Type';
      setHidden(breadcrumbGrant, false);
    }
    grantPanels.forEach(function(gp) {
      setHidden(gp, gp.getAttribute('data-shop-grant-panel') !== grantKey);
    });

    // If the selected grant type has a draggable pan grid, initialize it.
    setTimeout(initVisiblePan, 0);
  }

  function showGrantTypeSelector(categoryPanel) {
    if (!categoryPanel) return;
    var grantSelector = categoryPanel.querySelector('[data-shop-grant-selector]');
    var grantView = categoryPanel.querySelector('[data-shop-grant-view]');
    var grantPanels = categoryPanel.querySelectorAll('[data-shop-grant-panel]');
    setHidden(grantSelector, false);
    setHidden(grantView, true);
    grantPanels.forEach(function(gp) { setHidden(gp, true); });
    if (breadcrumbSep) setHidden(breadcrumbSep, true);
    if (breadcrumbGrant) setHidden(breadcrumbGrant, true);
  }

  var itemModal = document.getElementById('shopItemModal');
  var itemModalClose = document.getElementById('shopItemModalClose');
  var itemModalTitle = document.getElementById('shopItemModalTitle');
  var itemModalDesc = document.getElementById('shopItemModalDesc');
  var itemModalQty = document.getElementById('shopItemModalQty');
  var itemModalLimit = document.getElementById('shopItemModalLimit');
  var itemModalShippingUsd = document.getElementById('shopItemModalShippingUsd');
  var itemModalTotal = document.getElementById('shopItemModalTotal');
  var itemModalError = document.getElementById('shopItemModalError');
  var itemModalPurchase = document.getElementById('shopItemModalPurchase');

  var itemModalCurrent = { id: null, name: null, link: null, basePrice: 0, priceUsd: 0, dollarPerHour: 0 };
  var itemModalShippingMaxHint = document.getElementById('shopItemModalShippingMaxHint');

  function toNumber(v) {
    var n = parseFloat(String(v || '').replace(/,/g, ''));
    return Number.isFinite(n) ? n : 0;
  }

  function roundUsd2(n) {
    return Math.round(Math.max(0, n) * 100) / 100;
  }

  function maxShippingUsdForItemModal() {
    var qty = Math.max(1, parseInt(itemModalQty && itemModalQty.value, 10) || 1);
    var itemsUsd = toNumber(itemModalCurrent.priceUsd) * qty;
    return roundUsd2(itemsUsd * 0.6);
  }

  function shippingChipsFromUsd(usd) {
    var dph = toNumber(itemModalCurrent.dollarPerHour);
    if (usd <= 0 || dph <= 0) return 0;
    return Math.ceil((usd / dph) * 50);
  }

  function updateItemModalTotals() {
    if (!itemModalTotal) return;
    var qty = Math.max(1, parseInt(itemModalQty && itemModalQty.value, 10) || 1);
    if (itemModalQty) itemModalQty.value = String(qty);
    var maxUsd = maxShippingUsdForItemModal();
    if (itemModalShippingMaxHint) {
      itemModalShippingMaxHint.textContent = 'Max $' + maxUsd.toFixed(2) + ' (60% of item value for this quantity). Total below is chips (items + shipping).';
    }
    var rawUsd = Math.max(0, toNumber(itemModalShippingUsd && itemModalShippingUsd.value));
    var usd = Math.min(rawUsd, maxUsd);
    if (rawUsd > maxUsd + 1e-6) {
      alert('Shipping/tax cannot be more than 60% of the dollar value of the items in this order (maximum $' + maxUsd.toFixed(2) + ' for this quantity).');
      usd = maxUsd;
      if (itemModalShippingUsd) itemModalShippingUsd.value = maxUsd.toFixed(2);
    }
    var shipChips = shippingChipsFromUsd(usd);
    if (shipChips > 500000) shipChips = 500000;
    var total = (itemModalCurrent.basePrice * qty) + shipChips;
    total = Math.ceil(total);
    itemModalTotal.textContent = String(total);
  }

  function openItemModal(data) {
     if (!itemModal) return;
     itemModalTitle.textContent = data.name || 'Item';
     itemModalDesc.textContent = data.desc || '';
     itemModalCurrent.id = data.id || null;
     itemModalCurrent.name = data.name || '';
     itemModalCurrent.link = data.link || '';
     itemModalCurrent.basePrice = Math.ceil(toNumber(data.price));
     itemModalCurrent.priceUsd = toNumber(data.priceUsd);
     itemModalCurrent.dollarPerHour = toNumber(data.dollarPerHour);

     if (itemModalLimit) {
       var maxPerPerson = parseInt(data.maxPerPerson || "", 10);
       var purchasedQty = parseInt(data.purchasedQty || "0", 10);
       if (Number.isFinite(maxPerPerson) && maxPerPerson > 0) {
         var msg = 'Limit: ' + maxPerPerson + '/person';
         if (Number.isFinite(purchasedQty) && purchasedQty > 0) msg += ' (' + purchasedQty + ' bought)';
         itemModalLimit.textContent = msg;
         itemModalLimit.hidden = false;
       } else {
         itemModalLimit.textContent = '';
         itemModalLimit.hidden = true;
       }
     }

     var imgEl = document.getElementById('shopItemModalImage');
     if (imgEl && data.image) {
       imgEl.src = data.image;
     }

     if (itemModalQty) itemModalQty.value = '1';
     if (itemModalShippingUsd) itemModalShippingUsd.value = '0';
     if (itemModalError) itemModalError.hidden = true;
     updateItemModalTotals();

     if (itemModalPurchase) itemModalPurchase.disabled = !data.id;

     itemModal.classList.add('active');
     itemModal.setAttribute('aria-hidden', 'false');
   }

  function closeItemModal() {
    if (!itemModal) return;
    itemModal.classList.remove('active');
    itemModal.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll('[data-action="open-item-modal"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.disabled) return;
      openItemModal({
        id: btn.dataset.itemId,
        name: btn.dataset.itemName,
        desc: btn.dataset.itemDesc,
        link: btn.dataset.itemLink,
        price: btn.dataset.itemPrice || '0',
        priceUsd: btn.dataset.itemPriceUsd || '0',
        dollarPerHour: btn.dataset.itemDollarPerHour || '0',
        image: btn.dataset.itemImage,
        maxPerPerson: btn.dataset.itemMaxPerPerson,
        purchasedQty: btn.dataset.itemPurchasedQty
      });
    });
  });

  if (addPrizeBtn) addPrizeBtn.onclick = openAddPrizeModal;
  if (addPrizeModalClose) addPrizeModalClose.onclick = closeAddPrizeModal;
  if (addPrizeModal) {
    addPrizeModal.addEventListener('click', function(e) {
      if (e.target === addPrizeModal) closeAddPrizeModal();
    });
  }
  if (shopRulesBtn) shopRulesBtn.onclick = openShopRulesModal;
  if (shopRulesModalClose) shopRulesModalClose.onclick = closeShopRulesModal;
  if (shopRulesModal) {
    shopRulesModal.addEventListener('click', function(e) {
      if (e.target === shopRulesModal) closeShopRulesModal();
    });
  }

  // Category picker → show cards for that category
  if (categorySelector) {
    categorySelector.onclick = function(e) {
      var btn = e.target && e.target.closest && e.target.closest('[data-shop-category]');
      if (!btn) return;
      showCategory(btn.getAttribute('data-shop-category'), (btn.textContent || '').trim());
    };
  }
  if (categoryBack) categoryBack.onclick = showCategorySelector;

  // Grant type picker (inside a category) → show models for that grant type
  if (categoryView) {
    categoryView.onclick = function(e) {
      var grantTile = e.target && e.target.closest && e.target.closest('[data-shop-grant-type]');
      if (grantTile) {
        var catPanel = grantTile.closest('[data-shop-category-panel]');
        showGrantType(catPanel, grantTile.getAttribute('data-shop-grant-type'), (grantTile.textContent || '').trim());
        return;
      }
    };
  }

  // Breadcrumb: clicking the category part returns to Grant Types (inside the current category).
  if (breadcrumbCategory) {
    breadcrumbCategory.onclick = function() {
      if (!categoryView || categoryView.hidden) return;
      var activeCategoryPanel = Array.prototype.find.call(categoryPanels, function(p) { return !p.hidden; });
      if (!activeCategoryPanel) return;
      showGrantTypeSelector(activeCategoryPanel);
    };
  }

  // Default state: show only categories until one is chosen.
  showCategorySelector();

  // Reorder items (admin only): toggle and drag-and-drop
  var shopReorderCheckbox = document.getElementById('shopReorderItems');
  var shopReorderDraggedCard = null;

  function getVisibleGridAndPanel() {
    var categoryView = document.getElementById('shopCategoryView');
    if (!categoryView || categoryView.hidden) return null;
    var panels = categoryView.querySelectorAll('.shop-grant-panel');
    for (var i = 0; i < panels.length; i++) {
      if (!panels[i].hidden) {
        var grid = panels[i].querySelector('.shop-grid');
        if (grid) return { grid: grid, panel: panels[i] };
        return null;
      }
    }
    return null;
  }

  function applyReorderModeToPanel(panel) {
    if (!panel) return;
    var grid = panel.querySelector('.shop-grid');
    if (!grid) return;
    var pan = panel.querySelector('.shop-cards-pan');
    if (pan) pan.classList.add('shop-cards-pan--reorder');
    var cards = grid.querySelectorAll('.shop-card[data-item-id]');
    cards.forEach(function(card) {
      card.draggable = true;
      card.setAttribute('draggable', 'true');
    });
  }

  function removeReorderMode() {
    document.querySelectorAll('.shop-cards-pan--reorder').forEach(function(pan) {
      pan.classList.remove('shop-cards-pan--reorder');
    });
    document.querySelectorAll('.shop-cards-pan--no-pan').forEach(function(pan) {
      pan.classList.remove('shop-cards-pan--no-pan');
    });
    document.querySelectorAll('.shop-category-view .shop-grid .shop-card[data-item-id]').forEach(function(card) {
      card.draggable = false;
      card.removeAttribute('draggable');
    });
  }

  function applyNoPanToVisiblePanel() {
    var v = getVisibleGridAndPanel();
    if (!v || !v.panel) return;
    var pan = v.panel.querySelector('.shop-cards-pan');
    if (pan) pan.classList.add('shop-cards-pan--no-pan');
  }

  function setupReorderDragDrop(grid, panel) {
    var grantTypeId = panel.getAttribute('data-shop-grant-type-id');
    if (!grantTypeId) return;

    function handleDragStart(e) {
      shopReorderDraggedCard = e.currentTarget;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', shopReorderDraggedCard.getAttribute('data-item-id'));
      e.dataTransfer.setData('application/json', JSON.stringify({ id: shopReorderDraggedCard.getAttribute('data-item-id') }));
      shopReorderDraggedCard.classList.add('shop-card--dragging');
      if (e.dataTransfer.setDragImage) {
        e.dataTransfer.setDragImage(shopReorderDraggedCard, 0, 0);
      }
    }

    function handleDragEnd(e) {
      if (shopReorderDraggedCard) shopReorderDraggedCard.classList.remove('shop-card--dragging');
      shopReorderDraggedCard = null;
    }

    function handleDragOver(e) {
      e.preventDefault();
      e.stopPropagation();
      e.dataTransfer.dropEffect = 'move';
    }

    function handleDrop(e) {
      e.preventDefault();
      e.stopPropagation();
      var card = e.target.closest('.shop-card[data-item-id]');
      var gridEl = e.target.closest('.shop-grid');
      if (!shopReorderDraggedCard || !gridEl || gridEl !== grid) return;
      var after = card || null;
      if (after === shopReorderDraggedCard) return;
      if (after) {
        if (after.nextSibling === shopReorderDraggedCard) return;
        grid.insertBefore(shopReorderDraggedCard, after);
      } else {
        grid.appendChild(shopReorderDraggedCard);
      }
      var itemIds = Array.prototype.slice.call(grid.querySelectorAll('.shop-card[data-item-id]')).map(function(c) { return c.getAttribute('data-item-id'); });
      fetch('<%= admin_shop_reorder_items_path %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ grant_type_id: grantTypeId, item_ids: itemIds })
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (!data.success) alert(data.error || 'Failed to save order');
      }).catch(function(err) { console.error(err); alert('Failed to save order'); });
    }

    var cards = grid.querySelectorAll('.shop-card[data-item-id]');
    cards.forEach(function(card) {
      card.addEventListener('dragstart', handleDragStart);
      card.addEventListener('dragend', handleDragEnd);
    });
    grid.addEventListener('dragover', handleDragOver);
    grid.addEventListener('drop', handleDrop);
    grid.addEventListener('dragenter', function(e) { e.preventDefault(); });
  }

  function initReorderMode(visiblePanel) {
    removeReorderMode();
    if (!shopReorderCheckbox || !shopReorderCheckbox.checked) return;
    var v = visiblePanel ? { panel: visiblePanel, grid: visiblePanel.querySelector('.shop-grid') } : getVisibleGridAndPanel();
    if (!v || !v.grid || !v.panel) return;
    applyReorderModeToPanel(v.panel);
    if (!v.grid.dataset.shopReorderBound) {
      setupReorderDragDrop(v.grid, v.panel);
      v.grid.dataset.shopReorderBound = '1';
    }
  }

  if (shopReorderCheckbox) {
    shopReorderCheckbox.addEventListener('change', function() {
      if (shopReorderCheckbox.checked) {
        initReorderMode();
      } else {
        removeReorderMode();
        applyNoPanToVisiblePanel();
      }
    });
  }

  var origShowGrantType = showGrantType;
  showGrantType = function(categoryPanel, grantKey, label) {
    origShowGrantType(categoryPanel, grantKey, label);
    setTimeout(function() {
      var grantPanels = categoryPanel.querySelectorAll('[data-shop-grant-panel]');
      var visiblePanel = null;
      for (var i = 0; i < grantPanels.length; i++) {
        if (grantPanels[i].getAttribute('data-shop-grant-panel') === grantKey) {
          visiblePanel = grantPanels[i];
          break;
        }
      }
      if (shopReorderCheckbox && shopReorderCheckbox.checked) {
        initReorderMode(visiblePanel);
      } else if (shopReorderCheckbox) {
        applyNoPanToVisiblePanel();
      }
    }, 50);
  };

  if (itemModalQty) itemModalQty.addEventListener('input', updateItemModalTotals);
  if (itemModalShippingUsd) itemModalShippingUsd.addEventListener('input', updateItemModalTotals);

  var shopRulesAcceptOverlay = document.getElementById('shopRulesAcceptOverlay');
  var shopRulesAcceptCheckbox = document.getElementById('shopRulesAcceptCheckbox');
  var shopRulesAcceptConfirm = document.getElementById('shopRulesAcceptConfirm');
  var shopRulesAcceptCancel = document.getElementById('shopRulesAcceptCancel');
  var shopRulesAcceptClose = document.getElementById('shopRulesAcceptClose');

  function openShopRulesAccept() {
    if (!shopRulesAcceptOverlay) return;
    if (shopRulesAcceptCheckbox) shopRulesAcceptCheckbox.checked = false;
    if (shopRulesAcceptConfirm) shopRulesAcceptConfirm.disabled = true;
    shopRulesAcceptOverlay.classList.add('active');
    shopRulesAcceptOverlay.setAttribute('aria-hidden', 'false');
  }

  function closeShopRulesAccept() {
    if (!shopRulesAcceptOverlay) return;
    shopRulesAcceptOverlay.classList.remove('active');
    shopRulesAcceptOverlay.setAttribute('aria-hidden', 'true');
  }

  if (shopRulesAcceptCheckbox) {
    shopRulesAcceptCheckbox.addEventListener('change', function() {
      if (shopRulesAcceptConfirm) shopRulesAcceptConfirm.disabled = !shopRulesAcceptCheckbox.checked;
    });
  }
  if (shopRulesAcceptCancel) shopRulesAcceptCancel.addEventListener('click', closeShopRulesAccept);
  if (shopRulesAcceptClose) shopRulesAcceptClose.addEventListener('click', closeShopRulesAccept);
  if (shopRulesAcceptOverlay) {
    shopRulesAcceptOverlay.addEventListener('click', function(e) {
      if (e.target === shopRulesAcceptOverlay) closeShopRulesAccept();
    });
  }

  function doItemModalPurchase() {
    if (!itemModalCurrent.id) return;
    var qty = Math.max(1, parseInt(itemModalQty && itemModalQty.value, 10) || 1);
    var maxUsd = maxShippingUsdForItemModal();
    var shipUsd = roundUsd2(toNumber(itemModalShippingUsd && itemModalShippingUsd.value));
    if (shipUsd > maxUsd + 1e-6) {
      alert('Shipping/tax cannot be more than 60% of the dollar value of the items in this order (maximum $' + maxUsd.toFixed(2) + ' for this quantity).');
      if (itemModalShippingUsd) itemModalShippingUsd.value = maxUsd.toFixed(2);
      updateItemModalTotals();
      return;
    }

    itemModalPurchase.disabled = true;
    itemModalPurchase.textContent = 'Processing...';
    if (itemModalError) itemModalError.hidden = true;

    fetch('<%= buy_shop_item_path(":id") %>'.replace('%3Aid', itemModalCurrent.id).replace(':id', itemModalCurrent.id), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ quantity: qty, shipping_usd: shipUsd })
    })
    .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
    .then(function(result) {
      if (result.ok && result.data.success) {
        confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
        closeItemModal();
        closeShopRulesAccept();
        notificationMessage.textContent = 'Your purchase for ' + (itemModalCurrent.name || 'item') + ' is successful!';
        notification.classList.add('show');
        notification.setAttribute('aria-hidden', 'false');
        var tokenEl = document.querySelector('.token-count');
        if (tokenEl) tokenEl.textContent = result.data.new_balance;
        modalBalance.textContent = result.data.new_balance;
        setTimeout(function() {
          notification.classList.remove('show');
          notification.setAttribute('aria-hidden', 'true');
          setTimeout(function() { location.reload(); }, 300);
        }, 3000);
      } else {
        if (itemModalError) {
          itemModalError.textContent = result.data.error || 'Purchase failed.';
          itemModalError.hidden = false;
        } else {
          alert(result.data.error || 'Purchase failed.');
        }
      }
    })
    .catch(function(e) {
      console.error('Purchase error:', e);
      if (itemModalError) {
        itemModalError.textContent = 'Something went wrong. Please try again.';
        itemModalError.hidden = false;
      } else {
        alert('Something went wrong. Please try again.');
      }
    })
    .finally(function() {
      itemModalPurchase.disabled = !itemModalCurrent.id;
      itemModalPurchase.textContent = 'Purchase';
    });
  }

  if (itemModalPurchase) {
    itemModalPurchase.addEventListener('click', function() {
      if (!itemModalCurrent.id) return;
      if (shopPurchasesLocked) {
        openShopMaintenance();
        return;
      }
      openShopRulesAccept();
    });
  }

  if (shopRulesAcceptConfirm) {
    shopRulesAcceptConfirm.addEventListener('click', function() {
      if (!shopRulesAcceptCheckbox || !shopRulesAcceptCheckbox.checked) return;
      closeShopRulesAccept();
      doItemModalPurchase();
    });
  }

  if (itemModalClose) itemModalClose.addEventListener('click', closeItemModal);
  if (itemModal) {
    itemModal.addEventListener('click', function(e) {
      if (e.target === itemModal) closeItemModal();
    });
  }

  if (modalClose) modalClose.addEventListener('click', closeModal);
  if (modalCancel) modalCancel.addEventListener('click', closeModal);
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
  }

  if (modalConfirm) {
    modalConfirm.addEventListener('click', function() {
      if (!currentItemId) return;
      modalConfirm.disabled = true;
      modalConfirm.textContent = 'Processing...';

      fetch('<%= buy_shop_item_path(":id") %>'.replace('%3Aid', currentItemId).replace(':id', currentItemId), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ quantity: 1, shipping_usd: 0 })
      })
      .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
      .then(function(result) {
        if (result.ok && result.data.success) {
          // Trigger confetti
          confetti({
            particleCount: 100,
            spread: 70,
            origin: { y: 0.6 }
          });
          
          closeModal();
          
          // Show notification
          notificationMessage.textContent = 'Your purchase for ' + currentItemName + ' is successful!';
          notification.classList.add('show');
          notification.setAttribute('aria-hidden', 'false');
          
          // Update balance in toolbar
          var tokenEl = document.querySelector('.token-count');
          if (tokenEl) tokenEl.textContent = result.data.new_balance;
          modalBalance.textContent = result.data.new_balance;
          
          // Hide notification and reload after 3 seconds
          setTimeout(function() {
            notification.classList.remove('show');
            notification.setAttribute('aria-hidden', 'true');
            setTimeout(function() {
              location.reload();
            }, 300);
          }, 3000);
        } else {
          alert(result.data.error || 'Purchase failed.');
          modalConfirm.disabled = false;
          modalConfirm.textContent = 'Confirm Purchase';
        }
      })
      .catch(function(e) {
        console.error('Purchase error:', e);
        alert('Something went wrong. Please try again.');
        modalConfirm.disabled = false;
        modalConfirm.textContent = 'Confirm Purchase';
      });
    });
  }

  // Avoid accumulating Escape handlers across multiple Shop visits.
  if (window.__shopKeydownHandler) {
    document.removeEventListener('keydown', window.__shopKeydownHandler);
  }
  window.__shopKeydownHandler = function(e) {
    if (e.key === 'Escape') {
      if (shopMaintenanceOverlay && shopMaintenanceOverlay.classList.contains('active')) {
        closeShopMaintenance();
        return;
      }
      if (shopRulesAcceptOverlay && shopRulesAcceptOverlay.classList.contains('active')) {
        closeShopRulesAccept();
        return;
      }
      closeItemModal();
      closeAddPrizeModal();
      closeShopRulesModal();
      closeModal();
    }
  };
  document.addEventListener('keydown', window.__shopKeydownHandler);

  // Draggable pan: move all cards together (drag threshold so Buy button clicks still work)
  function initPan(pan) {
    if (!pan || pan.dataset.shopPanBound === '1') return;
    pan.dataset.shopPanBound = '1';

    var panStartX, panStartY, panTranslateX = 0, panTranslateY = 0, panDragging = false, panHasMoved = false, panDidDrag = false;
    var DRAG_THRESHOLD = 5;

    function isInteractiveTarget(target) {
      var el = (target && target.nodeType === 1) ? target : (target && target.parentElement);
      return !!(el && (el.closest('button') || el.closest('a')));
    }

    function getClientXY(e) {
      if (e.touches && e.touches.length) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
      return { x: e.clientX, y: e.clientY };
    }

    function onPanPointerDown(e) {
      if (pan.classList.contains('shop-cards-pan--reorder') || pan.classList.contains('shop-cards-pan--no-pan')) return;
      if (isInteractiveTarget(e.target)) return;
      var p = getClientXY(e);
      panStartX = p.x; panStartY = p.y;
      panDragging = false; panHasMoved = false; panDidDrag = false;
      pan.classList.add('shop-cards-pan--grabbing');
      document.addEventListener('mousemove', onPanPointerMove);
      document.addEventListener('mouseup', onPanPointerUp);
      if (e.type === 'touchstart') {
        document.addEventListener('touchmove', onPanPointerMove, { passive: false });
        document.addEventListener('touchend', onPanPointerUp);
      }
    }

    function onPanPointerMove(e) {
      var p = getClientXY(e);
      var dx = p.x - panStartX, dy = p.y - panStartY;
      if (!panHasMoved && (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD)) {
        panHasMoved = true;
        panDragging = true;
      }
      if (panDragging) {
        e.preventDefault();
        panDidDrag = true;
        panTranslateX += dx; panTranslateY += dy;
        panStartX = p.x; panStartY = p.y;
        pan.style.transform = 'translate(' + panTranslateX + 'px, ' + panTranslateY + 'px)';
      }
    }

    function onPanPointerUp() {
      pan.classList.remove('shop-cards-pan--grabbing');
      document.removeEventListener('mousemove', onPanPointerMove);
      document.removeEventListener('mouseup', onPanPointerUp);
      document.removeEventListener('touchmove', onPanPointerMove);
      document.removeEventListener('touchend', onPanPointerUp);
      panDragging = false;
    }

    pan.addEventListener('click', function(e) {
      // Never block real button/link clicks.
      if (isInteractiveTarget(e.target)) {
        panDidDrag = false;
        return;
      }
      // Only suppress clicks that were actually a drag.
      if (panDidDrag) {
        e.preventDefault();
        e.stopPropagation();
        panDidDrag = false;
      }
    }, true);

    pan.addEventListener('mousedown', onPanPointerDown);
    pan.addEventListener('touchstart', onPanPointerDown, { passive: true });
  }

  function initVisiblePan() {
    var visiblePan = document.querySelector(
      '.shop-category-view:not([hidden]) .shop-category-panel:not([hidden]) .shop-grant-view:not([hidden]) .shop-grant-panel:not([hidden]) .shop-cards-pan'
    );
    initPan(visiblePan);
  }
  });
})();
</script>
