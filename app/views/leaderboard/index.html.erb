<% content_for(:title) { "Leaderboard" } %>

<div class="leaderboard-page">
  <div class="leaderboard-container">
    <h1 class="leaderboard-title">Leaderboard</h1>
    <div class="leaderboard-sort" aria-label="Sort by">
      <%= link_to "Chips", leaderboard_path(sort: "chips"), class: "leaderboard-sort-link #{'leaderboard-sort-link--active' if @sort == 'chips'}" %>
      <span class="leaderboard-sort-sep">·</span>
      <%= link_to "Hours", leaderboard_path(sort: "hours"), class: "leaderboard-sort-link #{'leaderboard-sort-link--active' if @sort == 'hours'}" %>
    </div>

    <% if @users.any? %>
      <table class="leaderboard-table" id="leaderboardTable">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th class="col-player">User</th>
            <th class="col-hours">Hours logged</th>
            <th class="col-approved-hours">Approved hours</th>
            <th class="col-current-chips">Current chips</th>
            <th class="col-total-chips">Total chips</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each_with_index do |user, i| %>
            <% rank = (@page - 1) * LeaderboardController::PER_PAGE + i + 1 %>
            <tr class="<%= 'highlight-row' if user.id == current_user.id %> <%= 'top-3' if rank <= 3 %>">
              <td class="col-rank">
                <% if rank == 1 %>
                  <span class="rank-medal">🥇</span>
                <% elsif rank == 2 %>
                  <span class="rank-medal">🥈</span>
                <% elsif rank == 3 %>
                  <span class="rank-medal">🥉</span>
                <% else %>
                  <span class="rank-number"><%= rank %></span>
                <% end %>
              </td>
              <td class="col-player">
                <div class="player-info">
                  <%= image_tag(user.profile_photo_url || "https://avatars.githubusercontent.com/u/0", class: "player-avatar", alt: user.leaderboard_name) %>
                  <span class="player-name"><%= user.leaderboard_name %></span>
                  <% if user.id == current_user.id %>
                    <span class="you-badge">YOU</span>
                  <% end %>
                </div>
              </td>
              <td class="col-hours">
                <span class="hours-count"><%= number_with_precision(user.total_logged_hours, precision: 1) %></span>
              </td>
              <td class="col-approved-hours">
                <span class="approved-hours-count"><%= number_with_precision(user.total_approved_hours, precision: 2) %></span>
              </td>
              <td class="col-current-chips">
                <span class="chip-count chip-count--current"><%= number_with_precision(user.current_chips, precision: 0, strip_insignificant_zeros: true) %></span>
              </td>
              <td class="col-total-chips">
                <span class="chip-count chip-count--total"><%= number_with_precision(user.total_chips, precision: 0, strip_insignificant_zeros: true) %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if @total_pages > 1 %>
        <div class="pagination">
          <% if @page > 1 %>
            <%= link_to "← Prev", leaderboard_path(page: @page - 1, sort: @sort), class: "page-link" %>
          <% end %>

          <span class="page-info">Page <%= @page %> of <%= @total_pages %></span>

          <% if @page < @total_pages %>
            <%= link_to "Next →", leaderboard_path(page: @page + 1, sort: @sort), class: "page-link" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <p>No players yet. Be the first!</p>
      </div>
    <% end %>
  </div>
</div>

<% if params[:welcome] == "1" %>
<div id="lbTutorialSpotlight" style="position:fixed; z-index:3001; border-radius:12px; background:transparent; box-shadow:0 0 0 9999px rgba(0,0,0,0.6); transition:all 0.3s ease; pointer-events:none;"></div>
<div id="lbTutorialTooltip" style="position:fixed; z-index:3002; text-align:center; pointer-events:auto;">
  <p class="lb-tutorial-text">Here you can see all the other Hack Clubbers participating in Jackpot, and how many Poker Chips they have!</p>
  <button id="lbTutorialContinue" class="lb-tutorial-btn">Continue</button>
  <div class="lb-tutorial-arrow"></div>
</div>

<div id="hackatimeFraudOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:4000; justify-content:center; align-items:center;">
  <div class="hf-modal">
    <h2 class="hf-title">Hackatime Fraud</h2>
    <p class="hf-body">The use of scripts/macros to artificially inflate your time in Hackatime is strictly prohibited, and will result in a Hack Club wide ban.</p>
    <button id="hackatimeAgreeBtn" class="hf-agree-btn">Agree, Continue</button>
  </div>
</div>

<script>
(function() {
  var spotlight  = document.getElementById('lbTutorialSpotlight');
  var tooltip    = document.getElementById('lbTutorialTooltip');
  var continueBtn = document.getElementById('lbTutorialContinue');
  var fraudOverlay = document.getElementById('hackatimeFraudOverlay');
  var agreeBtn   = document.getElementById('hackatimeAgreeBtn');
  var table      = document.getElementById('leaderboardTable');

  function positionSpotlight() {
    if (!table || !spotlight || !tooltip) return;
    var rect = table.getBoundingClientRect();
    var pad = 14;
    spotlight.style.left   = (rect.left - pad) + 'px';
    spotlight.style.top    = (rect.top  - pad) + 'px';
    spotlight.style.width  = (rect.width  + pad * 2) + 'px';
    spotlight.style.height = (rect.height + pad * 2) + 'px';

    var tipX = rect.left + rect.width / 2;
    var tipY = rect.top - pad - 8;
    var tooltipH = tooltip.offsetHeight || 80;

    tooltip.classList.remove('lb-bounce-up', 'lb-bounce-down');
    if (tipY >= tooltipH) {
      tooltip.classList.add('lb-bounce-up');
      tooltip.style.top = tipY + 'px';
    } else {
      tooltip.classList.add('lb-bounce-down');
      tooltip.style.top = (rect.bottom + pad + 8) + 'px';
    }
    tooltip.style.left = tipX + 'px';
  }

  positionSpotlight();
  window.addEventListener('resize', positionSpotlight);

  if (continueBtn) {
    continueBtn.addEventListener('click', function() {
      spotlight.style.display = 'none';
      tooltip.style.display   = 'none';
      window.removeEventListener('resize', positionSpotlight);
      fraudOverlay.style.display = 'flex';
    });
  }

  if (agreeBtn) {
    agreeBtn.addEventListener('click', function() {
      fraudOverlay.style.display = 'none';
    });
  }
})();
</script>
<% end %>
