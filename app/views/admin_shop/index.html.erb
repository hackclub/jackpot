<% content_for(:title) { "Admin - Shop" } %>

<div style="padding: 2rem; max-width: 1200px; margin: 0 auto; padding-top: 90px; font-family: 'Georgia', serif; color: #f0e6d2;">

  <h1 style="color: #d4a017; margin-bottom: 2rem;">Shop Admin</h1>

  <div style="background: rgba(30, 20, 10, 0.8); border: 2px solid #8b6914; border-radius: 12px; padding: 16px 24px; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
    <div style="display: flex; align-items: center; gap: 10px;">
      <label class="admin-shop-lock-toggle-label" for="adminShopPurchasesLockToggle" style="color: #c4b89a; font-weight: 700; cursor: pointer;">Lock purchases</label>
      <input type="checkbox" id="adminShopPurchasesLockToggle" <%= @shop_purchases_locked ? 'checked' : '' %> aria-describedby="adminShopPurchasesLockHint" style="accent-color: #d4a017; width: 20px; height: 20px; cursor: pointer;">
    </div>
    <span id="adminShopPurchasesLockHint" style="color: #a89878; font-size: 0.9rem;">When locked, users see a maintenance message when they try to purchase.</span>
  </div>

  <div style="background: rgba(30, 20, 10, 0.8); border: 2px solid #8b6914; border-radius: 12px; padding: 24px; margin-bottom: 2rem;">
    <h2 style="color: #d4a017; margin: 0 0 16px;">Add New Item</h2>
    <form id="addItemForm" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Name *</label>
        <input type="text" name="name" required style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">$ price *</label>
        <input type="number" name="price_usd" id="adminShopPriceUsd" step="0.01" min="0" required placeholder="e.g. 50" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">$/h *</label>
        <input type="number" name="dollar_per_hour" id="adminShopDollarPerHour" step="0.01" min="0.01" required value="4" placeholder="e.g. 4" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Chips (calculated)</label>
        <div id="adminShopChipsCalculated" style="padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(139,105,20,0.5); background: rgba(15,15,15,0.5); color: #a89878; font-family: Georgia, serif;">—</div>
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Max purchases per person (optional)</label>
        <input type="number" name="max_per_person" min="1" placeholder="e.g. 1" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Category *</label>
        <div style="display: flex; gap: 8px; align-items: center;">
          <select id="adminShopCategorySelect" name="shop_category_id" style="flex: 1; width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
            <% @categories.each do |cat| %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% end %>
          </select>
          <button type="button" id="adminShopAddCategoryBtn" style="white-space: nowrap; background: none; border: 1px solid #8b6914; color: #d4a017; padding: 8px 10px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">+ New</button>
        </div>
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Grant Type</label>
        <div style="display: flex; gap: 8px; align-items: center;">
          <select id="adminShopGrantTypeSelect" name="shop_grant_type_id" style="flex: 1; width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
            <option value="" disabled selected>Select…</option>
          </select>
          <button type="button" id="adminShopAddGrantTypeBtn" style="white-space: nowrap; background: none; border: 1px solid #8b6914; color: #d4a017; padding: 8px 10px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">+ New</button>
        </div>
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Item Link</label>
        <input type="url" name="item_link" placeholder="https://..." style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Image URL</label>
        <input type="url" name="image_url" placeholder="https://..." style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
      </div>
      <div style="grid-column: span 2;">
        <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Description</label>
        <textarea name="description" id="adminShopDescription" rows="2" placeholder="Leave empty for default: By purchasing this, you will receive a $X HCB grant." style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif; resize: vertical;"></textarea>
      </div>
      <div style="grid-column: span 2;">
        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
          <button type="submit" style="background: linear-gradient(135deg, #d4a017, #8b6914); color: #fff; border: none; padding: 10px 28px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700; font-size: 1rem;">Add Item</button>
          <button type="button" id="adminShopManageGroupsBtn" style="background: none; border: 1px solid rgba(240,230,210,0.35); color: rgba(240,230,210,0.95); padding: 10px 18px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">Manage Groups</button>
        </div>
      </div>
    </form>
  </div>

  <!-- Manage groups modal -->
  <div id="adminManageGroupsOverlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: none; align-items: center; justify-content: center; z-index: 5200; padding: 24px;">
    <div style="width: 100%; max-width: 980px; background: rgba(30, 20, 10, 0.95); border: 2px solid #8b6914; border-radius: 12px; padding: 18px;">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px;">
        <h2 style="color: #d4a017; margin: 0;">Manage Groups</h2>
        <button type="button" id="adminManageGroupsClose" style="background: none; border: 1px solid rgba(240,230,210,0.35); color: rgba(240,230,210,0.95); padding: 6px 10px; border-radius: 8px; cursor: pointer; font-family: Georgia, serif;">✕</button>
      </div>

      <div style="display: grid; grid-template-columns: 280px 1fr; gap: 16px;">
        <div style="border: 1px solid rgba(139,105,20,0.5); border-radius: 10px; padding: 12px; background: rgba(15,15,15,0.45);">
          <div style="display:flex; align-items:center; justify-content: space-between; gap: 10px; margin-bottom: 10px;">
            <div style="color:#c4b89a; font-weight: 700;">Categories</div>
            <button type="button" id="adminManageAddCategory" style="background: none; border: 1px solid #8b6914; color: #d4a017; padding: 4px 8px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">+ New</button>
          </div>
          <div id="adminManageCategoryList" style="display:flex; flex-direction: column; gap: 6px; max-height: 55vh; overflow:auto;"></div>
        </div>

        <div style="border: 1px solid rgba(139,105,20,0.5); border-radius: 10px; padding: 12px; background: rgba(15,15,15,0.35);">
          <div style="display:flex; align-items:center; justify-content: space-between; gap: 10px; margin-bottom: 10px;">
            <div style="color:#c4b89a; font-weight: 700;">Details</div>
          </div>

          <div id="adminManageCategoryDetails" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px;">
            <input type="hidden" id="adminManageCategoryId">
            <div style="grid-column: span 2;">
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Category name</label>
              <input type="text" id="adminManageCategoryName" style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
            </div>
            <div>
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Category key</label>
              <input type="text" id="adminManageCategoryKey" placeholder="generic" style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
            </div>
            <div>
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Logo URL</label>
              <input type="url" id="adminManageCategoryLogo" placeholder="https://..." style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
              <img id="adminManageCategoryLogoPreview" alt="" style="display:none; margin-top: 10px; width: 190px; height: 120px; object-fit: contain; background: transparent; border-radius: 10px; border: 0; box-shadow: 0 14px 22px rgba(0,0,0,0.45);">
            </div>
            <div style="grid-column: span 2; display:flex; gap: 10px; align-items:center;">
              <button type="button" id="adminManageSaveCategory" style="background: linear-gradient(135deg, #d4a017, #8b6914); color: #fff; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">Save Category</button>
              <span id="adminManageCategoryStatus" style="color:#a89878; font-size: 0.85rem;"></span>
            </div>
          </div>

          <div style="display:flex; align-items:center; justify-content: space-between; gap: 10px; margin: 12px 0 8px;">
            <div style="color:#c4b89a; font-weight: 700;">Grant Types</div>
            <button type="button" id="adminManageAddGrantType" style="background: none; border: 1px solid #8b6914; color: #d4a017; padding: 4px 8px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">+ New</button>
          </div>
          <div id="adminManageGrantTypeList" style="display:flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px;"></div>

          <div id="adminManageGrantTypeDetails" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <input type="hidden" id="adminManageGrantTypeId">
            <div style="grid-column: span 2;">
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Grant type name</label>
              <input type="text" id="adminManageGrantTypeName" style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
            </div>
            <div>
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Grant type key</label>
              <input type="text" id="adminManageGrantTypeKey" placeholder="ipad_tablet" style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
            </div>
            <div>
              <label style="display:block; margin-bottom: 4px; color:#c4b89a; font-size: 0.85rem;">Logo URL</label>
              <input type="url" id="adminManageGrantTypeLogo" placeholder="https://..." style="width:100%; box-sizing:border-box; padding:8px 12px; border-radius:6px; border:1px solid #8b6914; background: rgba(15,15,15,0.75); color:#fff; font-family: Georgia, serif;">
              <img id="adminManageGrantTypeLogoPreview" alt="" style="display:none; margin-top: 10px; width: 190px; height: 120px; object-fit: contain; background: transparent; border-radius: 10px; border: 0; box-shadow: 0 14px 22px rgba(0,0,0,0.45);">
            </div>
            <div style="grid-column: span 2; display:flex; gap: 10px; align-items:center;">
              <button type="button" id="adminManageSaveGrantType" style="background: linear-gradient(135deg, #d4a017, #8b6914); color: #fff; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">Save Grant Type</button>
              <span id="adminManageGrantTypeStatus" style="color:#a89878; font-size: 0.85rem;"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="background: rgba(30, 20, 10, 0.8); border: 2px solid #8b6914; border-radius: 12px; padding: 24px; margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
      <h2 style="color: #d4a017; margin: 0;">Shop Items (<span id="adminShopItemsCount"><%= @items.count %></span>)</h2>
      <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
        <input type="text" id="adminShopItemsSearch" placeholder="Search items…" style="width: 220px; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif; font-size: 0.9rem;">
        <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: #c4b89a; font-size: 0.9rem;">
          <input type="checkbox" id="adminShopShowDeactivated" style="accent-color: #d4a017;">
          <span>Show deactivated items</span>
        </label>
      </div>
    </div>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;" id="adminShopItemsTable">
        <thead>
          <tr style="border-bottom: 2px solid #8b6914;">
            <th class="admin-shop-sortable-th" data-sort-key="id" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">ID <span class="admin-shop-sort-arrow"></span></th>
            <th class="admin-shop-sortable-th" data-sort-key="name" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Name <span class="admin-shop-sort-arrow"></span></th>
            <th class="admin-shop-sortable-th" data-sort-key="category" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Category <span class="admin-shop-sort-arrow"></span></th>
            <th class="admin-shop-sortable-th" data-sort-key="grant_type" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Grant Type <span class="admin-shop-sort-arrow"></span></th>
            <th class="admin-shop-sortable-th" data-sort-key="max_per_person" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Max / person <span class="admin-shop-sort-arrow"></span></th>
            <th class="admin-shop-sortable-th" data-sort-key="price" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Price <span class="admin-shop-sort-arrow"></span></th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">$ price</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">$/h</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Hours req.</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Link</th>
            <th class="admin-shop-sortable-th" data-sort-key="active" style="text-align: left; padding: 8px; color: #c4b89a; cursor: pointer; user-select: none; white-space: nowrap;">Active <span class="admin-shop-sort-arrow"></span></th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Actions</th>
          </tr>
        </thead>
        <tbody id="adminShopItemsTbody">
          <% @items.each do |item| %>
            <tr
              class="admin-shop-item-row"
              style="border-bottom: 1px solid rgba(139,105,20,0.3);"
              id="item-row-<%= item.id %>"
              data-item-id="<%= item.id %>"
              data-item-name="<%= h(item.name.to_s) %>"
              data-item-price="<%= item.price.to_f %>"
              data-item-link="<%= h(item.item_link.to_s) %>"
              data-item-image-url="<%= h(item.image_url.to_s) %>"
              data-item-description="<%= h(item.description.to_s) %>"
              data-item-active="<%= item.active? ? 1 : 0 %>"
              data-item-category-id="<%= item.shop_category&.id %>"
              data-item-category-name="<%= h((item.shop_category&.name || '').to_s) %>"
              data-item-grant-type-id="<%= item.shop_grant_type_id %>"
              data-item-grant-type-name="<%= h((item.shop_grant_type&.name || '').to_s) %>"
              data-item-max-per-person="<%= item.max_per_person.present? ? item.max_per_person.to_i : '' %>"
              data-item-max-num="<%= item.max_per_person.present? ? item.max_per_person.to_i : -1 %>"
              data-item-price-usd="<%= item.price_usd.to_f if item.price_usd.present? %>"
              data-item-dollar-per-hour="<%= item.dollar_per_hour.to_f if item.dollar_per_hour.present? %>"
              data-item-hours="<%= item.hours_needed if item.hours_needed.present? %>"
            >
              <td style="padding: 8px;"><%= item.id %></td>
              <td style="padding: 8px;"><%= item.name %></td>
              <td style="padding: 8px;"><%= item.shop_category&.name || "—" %></td>
              <td style="padding: 8px;"><%= item.shop_grant_type&.name || "—" %></td>
              <td style="padding: 8px;"><%= item.max_per_person.present? ? item.max_per_person.to_i : "None" %></td>
              <td style="padding: 8px;"><%= item.price.to_f %></td>
              <td style="padding: 8px;"><%= item.price_usd.present? ? item.price_usd.to_f : "—" %></td>
              <td style="padding: 8px;"><%= item.dollar_per_hour.present? ? item.dollar_per_hour.to_f : "—" %></td>
              <td style="padding: 8px;"><%= item.hours_needed.present? ? item.hours_needed : "—" %></td>
              <td style="padding: 8px;">
                <% if item.item_link.present? %>
                  <a href="<%= item.item_link.to_s.match?(/\Ahttps?:\/\//i) ? item.item_link : '#' %>" target="_blank" rel="noopener noreferrer" style="color: #d4a017;">View</a>
                <% else %>
                  —
                <% end %>
              </td>
              <td style="padding: 8px;">
                <span style="color: <%= item.active? ? '#4caf50' : '#ef5350' %>;"><%= item.active? ? "Yes" : "No" %></span>
              </td>
              <td style="padding: 8px;">
                <button type="button" class="adminShopModifyBtn" data-item-id="<%= item.id %>" style="background: none; border: 1px solid #8b6914; color: #d4a017; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-family: Georgia, serif; margin-right: 4px;">
                  Modify
                </button>
                <button onclick="toggleItem(<%= item.id %>, <%= !item.active? %>)" style="background: none; border: 1px solid #8b6914; color: #d4a017; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-family: Georgia, serif; margin-right: 4px;">
                  <%= item.active? ? "Deactivate" : "Activate" %>
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modify item modal -->
  <div id="adminEditItemOverlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: none; align-items: center; justify-content: center; z-index: 5000; padding: 24px;">
    <div style="width: 100%; max-width: 820px; background: rgba(30, 20, 10, 0.95); border: 2px solid #8b6914; border-radius: 12px; padding: 18px;">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px;">
        <h2 style="color: #d4a017; margin: 0;">Modify Item</h2>
        <button type="button" id="adminEditItemClose" style="background: none; border: 1px solid rgba(240,230,210,0.35); color: rgba(240,230,210,0.95); padding: 6px 10px; border-radius: 8px; cursor: pointer; font-family: Georgia, serif;">✕</button>
      </div>

      <form id="adminEditItemForm" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <input type="hidden" name="id" id="adminEditItemId">
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Name *</label>
          <input type="text" name="name" id="adminEditItemName" required style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">$ price</label>
          <input type="number" name="price_usd" id="adminEditItemPriceUsd" step="0.01" min="0" placeholder="e.g. 50" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">$/h</label>
          <input type="number" name="dollar_per_hour" id="adminEditItemDollarPerHour" step="0.01" min="0.01" placeholder="e.g. 4" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Chips (calculated)</label>
          <div id="adminEditItemChipsCalculated" style="padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(139,105,20,0.5); background: rgba(15,15,15,0.5); color: #a89878; font-family: Georgia, serif;">—</div>
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Max purchases per person (optional)</label>
          <input type="number" name="max_per_person" id="adminEditItemMaxPerPerson" min="1" placeholder="e.g. 1" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Category *</label>
          <select id="adminEditCategorySelect" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
            <% @categories.each do |cat| %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Grant Type</label>
          <select id="adminEditGrantTypeSelect" name="shop_grant_type_id" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
            <option value="" disabled selected>Select…</option>
          </select>
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Item Link</label>
          <input type="url" name="item_link" id="adminEditItemLink" placeholder="https://..." style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Image URL</label>
          <input type="url" name="image_url" id="adminEditItemImageUrl" placeholder="https://..." style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif;">
        </div>
        <div style="grid-column: span 2;">
          <label style="display: block; margin-bottom: 4px; color: #c4b89a; font-size: 0.85rem;">Description</label>
          <textarea name="description" id="adminEditItemDescription" rows="3" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border-radius: 6px; border: 1px solid #8b6914; background: rgba(15,15,15,0.75); color: #fff; font-family: Georgia, serif; resize: vertical;"></textarea>
        </div>
        <div style="grid-column: span 2; display: flex; align-items: center; gap: 10px;">
          <input type="checkbox" id="adminEditItemActive" style="accent-color: #d4a017;">
          <label for="adminEditItemActive" style="color: #c4b89a; font-size: 0.9rem;">Active</label>
        </div>
        <div style="grid-column: span 2; display: flex; gap: 10px;">
          <button type="button" id="adminEditItemCancel" style="background: none; border: 1px solid rgba(240,230,210,0.35); color: rgba(240,230,210,0.95); padding: 10px 18px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700;">Cancel</button>
          <button type="submit" id="adminEditItemSave" style="background: linear-gradient(135deg, #d4a017, #8b6914); color: #fff; border: none; padding: 10px 28px; border-radius: 6px; cursor: pointer; font-family: Georgia, serif; font-weight: 700; font-size: 1rem;">Save changes</button>
        </div>
      </form>
    </div>
  </div>

  <div style="background: rgba(30, 20, 10, 0.8); border: 2px solid #8b6914; border-radius: 12px; padding: 24px;">
    <h2 style="color: #d4a017; margin: 0 0 16px;">Recent Orders (<%= @orders.count %>)</h2>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
        <thead>
          <tr style="border-bottom: 2px solid #8b6914;">
            <th style="text-align: left; padding: 8px; color: #c4b89a;">ID</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">User</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Email</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Slack ID</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Item</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Qty</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Price</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Status</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Date</th>
            <th style="text-align: left; padding: 8px; color: #c4b89a;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr style="border-bottom: 1px solid rgba(139,105,20,0.3);" id="order-row-<%= order.id %>">
              <td style="padding: 8px;"><%= order.id %></td>
              <td style="padding: 8px;"><%= order.user&.leaderboard_name || "Unknown" %></td>
              <td style="padding: 8px;"><%= order.user_email %></td>
              <td style="padding: 8px;"><%= order.slack_id %></td>
              <td style="padding: 8px;"><%= order.item_name %></td>
              <td style="padding: 8px;"><%= order.quantity %></td>
              <td style="padding: 8px;"><%= order.price.to_f %></td>
              <td style="padding: 8px;" id="order-status-<%= order.id %>">
                <span style="padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 700;
                  background: <%= case order.status; when 'pending' then 'rgba(255,193,7,0.2)'; when 'sent' then 'rgba(76,175,80,0.2)'; when 'refunded' then 'rgba(239,83,80,0.2)'; end %>;
                  color: <%= case order.status; when 'pending' then '#ffc107'; when 'sent' then '#4caf50'; when 'refunded' then '#ef5350'; end %>;">
                  <%= order.status.capitalize %>
                </span>
              </td>
              <td style="padding: 8px;"><%= order.created_at.strftime("%b %d, %H:%M") %></td>
              <td style="padding: 8px; white-space: nowrap;">
                <% %w[pending sent refunded].each do |st| %>
                  <% next if order.status == st %>
                  <button onclick="updateOrderStatus(<%= order.id %>, '<%= st %>')" style="background: none; border: 1px solid #8b6914; color: #d4a017; padding: 2px 8px; border-radius: 4px; cursor: pointer; font-family: Georgia, serif; font-size: 0.75rem; margin-right: 2px;">
                    <%= st.capitalize %>
                  </button>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @orders.empty? %>
            <tr><td colspan="10" style="padding: 16px; text-align: center; color: #a89878;">No orders yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
// Turbo-safe binding (prevents duplicate submissions creating duplicate items)
(function() {
  if (window.__adminShopInitBound) return;
  window.__adminShopInitBound = true;

  var SHOP_CATEGORIES = <%= raw(
    @categories.map { |c|
      {
        id: c.id,
        name: c.name,
        key: c.key,
        logo_url: c.logo_url,
        grant_types: c.shop_grant_types.joins(:shop_items).distinct.order(:name).map { |gt| { id: gt.id, name: gt.name, key: gt.key, logo_url: gt.logo_url } }
      }
    }.to_json
  ) %>;

  var PINNED_ITEM_NAME = <%= ShopItem::PINNED_INVITATION_NAME.to_json.html_safe %>;
  function isPinnedItemName(name) {
    return String(name || '').trim().toLowerCase() === String(PINNED_ITEM_NAME || '').trim().toLowerCase();
  }

  function renderGrantTypeOptions(categoryId, selectedGrantTypeId) {
    var grantSelect = document.getElementById('adminShopGrantTypeSelect');
    if (!grantSelect) return;
    var cat = SHOP_CATEGORIES.find(function(c) { return String(c.id) === String(categoryId); });

    grantSelect.innerHTML = "";
    var placeholder = document.createElement('option');
    placeholder.value = "";
    placeholder.textContent = "Select…";
    placeholder.disabled = true;
    placeholder.selected = !selectedGrantTypeId;
    grantSelect.appendChild(placeholder);

    ((cat && cat.grant_types) ? cat.grant_types : []).forEach(function(o) {
      var opt = document.createElement('option');
      opt.value = String(o.id);
      opt.textContent = o.name;
      if (selectedGrantTypeId && String(o.id) === String(selectedGrantTypeId)) opt.selected = true;
      grantSelect.appendChild(opt);
    });
  }

  function renderGrantTypeOptionsInto(categoryId, grantSelect, selectedGrantTypeId) {
    if (!grantSelect) return;
    var cat = SHOP_CATEGORIES.find(function(c) { return String(c.id) === String(categoryId); });

    grantSelect.innerHTML = "";
    var placeholder = document.createElement('option');
    placeholder.value = "";
    placeholder.textContent = "Select…";
    placeholder.disabled = true;
    placeholder.selected = !selectedGrantTypeId;
    grantSelect.appendChild(placeholder);

    ((cat && cat.grant_types) ? cat.grant_types : []).forEach(function(o) {
      var opt = document.createElement('option');
      opt.value = String(o.id);
      opt.textContent = o.name;
      if (selectedGrantTypeId && String(o.id) === String(selectedGrantTypeId)) opt.selected = true;
      grantSelect.appendChild(opt);
    });
  }

  document.addEventListener('turbo:load', function() {
    var form = document.getElementById('addItemForm');
    if (!form) return; // not on this page

    var lockToggle = document.getElementById('adminShopPurchasesLockToggle');
    if (lockToggle) {
      lockToggle.addEventListener('change', function() {
        var locked = lockToggle.checked;
        lockToggle.disabled = true;
        fetch('<%= admin_shop_purchases_lock_path %>', {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken,
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ locked: locked })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) lockToggle.checked = data.locked;
        })
        .catch(function() { lockToggle.checked = !locked; })
        .finally(function() { lockToggle.disabled = false; });
      });
    }

    var categorySelectEl = document.getElementById('adminShopCategorySelect');
    var addCategoryBtn = document.getElementById('adminShopAddCategoryBtn');
    var addGrantTypeBtn = document.getElementById('adminShopAddGrantTypeBtn');

    // Manage groups modal
    var manageBtn = document.getElementById('adminShopManageGroupsBtn');
    var manageOverlay = document.getElementById('adminManageGroupsOverlay');
    var manageClose = document.getElementById('adminManageGroupsClose');
    var manageAddCategory = document.getElementById('adminManageAddCategory');
    var manageCategoryList = document.getElementById('adminManageCategoryList');
    var manageCategoryId = document.getElementById('adminManageCategoryId');
    var manageCategoryName = document.getElementById('adminManageCategoryName');
    var manageCategoryKey = document.getElementById('adminManageCategoryKey');
    var manageCategoryLogo = document.getElementById('adminManageCategoryLogo');
    var manageCategoryLogoPreview = document.getElementById('adminManageCategoryLogoPreview');
    var manageCategorySave = document.getElementById('adminManageSaveCategory');
    var manageCategoryStatus = document.getElementById('adminManageCategoryStatus');

    var manageAddGrantType = document.getElementById('adminManageAddGrantType');
    var manageGrantTypeList = document.getElementById('adminManageGrantTypeList');
    var manageGrantTypeId = document.getElementById('adminManageGrantTypeId');
    var manageGrantTypeName = document.getElementById('adminManageGrantTypeName');
    var manageGrantTypeKey = document.getElementById('adminManageGrantTypeKey');
    var manageGrantTypeLogo = document.getElementById('adminManageGrantTypeLogo');
    var manageGrantTypeLogoPreview = document.getElementById('adminManageGrantTypeLogoPreview');
    var manageGrantTypeSave = document.getElementById('adminManageSaveGrantType');
    var manageGrantTypeStatus = document.getElementById('adminManageGrantTypeStatus');

    var selectedCategoryId = null;
    var selectedGrantTypeId = null;

    function findCategoryById(id) {
      return SHOP_CATEGORIES.find(function(c) { return String(c.id) === String(id); });
    }

    function findGrantTypeById(cat, id) {
      if (!cat) return null;
      return (cat.grant_types || []).find(function(gt) { return String(gt.id) === String(id); });
    }

    function setStatus(el, msg, isError) {
      if (!el) return;
      el.textContent = msg || '';
      el.style.color = isError ? '#ef5350' : '#a89878';
    }

    function setLogoPreview(imgEl, url) {
      if (!imgEl) return;
      var u = (url || '').trim();
      if (!u) {
        imgEl.style.display = 'none';
        imgEl.removeAttribute('src');
        return;
      }
      imgEl.style.display = 'block';
      imgEl.src = u;
    }

    function renderCategoryList(activeId) {
      if (!manageCategoryList) return;
      manageCategoryList.innerHTML = '';
      SHOP_CATEGORIES.slice().sort(function(a, b) {
        return (a.name || '').localeCompare((b.name || ''));
      }).forEach(function(cat) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = cat.name;
        btn.style.cssText = 'text-align:left; width:100%; background:' + (String(cat.id) === String(activeId) ? 'rgba(212,160,23,0.18)' : 'rgba(20,16,12,0.25)') + '; border: 1px solid rgba(139,105,20,0.45); color: #f0e6d2; padding: 8px 10px; border-radius: 8px; cursor:pointer; font-family: Georgia, serif;';
        btn.onclick = function() { selectCategory(cat.id); };
        manageCategoryList.appendChild(btn);
      });
    }

    function renderGrantTypeList(cat, activeId) {
      if (!manageGrantTypeList) return;
      manageGrantTypeList.innerHTML = '';
      (cat && cat.grant_types ? cat.grant_types.slice().sort(function(a, b) { return (a.name || '').localeCompare((b.name || '')); }) : []).forEach(function(gt) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = gt.name;
        btn.style.cssText = 'background:' + (String(gt.id) === String(activeId) ? 'rgba(212,160,23,0.18)' : 'rgba(20,16,12,0.25)') + '; border: 1px solid rgba(139,105,20,0.45); color: #f0e6d2; padding: 6px 10px; border-radius: 999px; cursor:pointer; font-family: Georgia, serif;';
        btn.onclick = function() { selectGrantType(gt.id); };
        manageGrantTypeList.appendChild(btn);
      });
    }

    function selectCategory(id) {
      selectedCategoryId = id;
      selectedGrantTypeId = null;
      var cat = findCategoryById(id);
      if (!cat) return;
      if (manageCategoryId) manageCategoryId.value = String(cat.id);
      if (manageCategoryName) manageCategoryName.value = cat.name || '';
      if (manageCategoryKey) manageCategoryKey.value = cat.key || '';
      if (manageCategoryLogo) manageCategoryLogo.value = cat.logo_url || '';
      setLogoPreview(manageCategoryLogoPreview, cat.logo_url);
      if (manageGrantTypeId) manageGrantTypeId.value = '';
      if (manageGrantTypeName) manageGrantTypeName.value = '';
      if (manageGrantTypeKey) manageGrantTypeKey.value = '';
      if (manageGrantTypeLogo) manageGrantTypeLogo.value = '';
      setLogoPreview(manageGrantTypeLogoPreview, '');
      setStatus(manageCategoryStatus, '');
      setStatus(manageGrantTypeStatus, '');
      renderCategoryList(id);
      renderGrantTypeList(cat, null);
    }

    function selectGrantType(id) {
      selectedGrantTypeId = id;
      var cat = findCategoryById(selectedCategoryId);
      var gt = findGrantTypeById(cat, id);
      if (!gt) return;
      if (manageGrantTypeId) manageGrantTypeId.value = String(gt.id);
      if (manageGrantTypeName) manageGrantTypeName.value = gt.name || '';
      if (manageGrantTypeKey) manageGrantTypeKey.value = gt.key || '';
      if (manageGrantTypeLogo) manageGrantTypeLogo.value = gt.logo_url || '';
      setLogoPreview(manageGrantTypeLogoPreview, gt.logo_url);
      setStatus(manageGrantTypeStatus, '');
      renderGrantTypeList(cat, id);
    }

    function openManageGroups() {
      if (!manageOverlay) return;
      manageOverlay.style.display = 'flex';
      if (!selectedCategoryId && SHOP_CATEGORIES.length) selectCategory(SHOP_CATEGORIES[0].id);
      renderCategoryList(selectedCategoryId);
    }

    function closeManageGroups() {
      if (!manageOverlay) return;
      manageOverlay.style.display = 'none';
    }

    if (manageBtn) manageBtn.onclick = openManageGroups;
    if (manageClose) manageClose.onclick = closeManageGroups;
    if (manageOverlay) {
      manageOverlay.onclick = function(e) {
        if (e.target === manageOverlay) closeManageGroups();
      };
    }

    if (manageCategoryLogo) {
      manageCategoryLogo.oninput = function() {
        setLogoPreview(manageCategoryLogoPreview, manageCategoryLogo.value);
      };
    }
    if (manageGrantTypeLogo) {
      manageGrantTypeLogo.oninput = function() {
        setLogoPreview(manageGrantTypeLogoPreview, manageGrantTypeLogo.value);
      };
    }

    if (manageAddCategory) {
      manageAddCategory.onclick = function() {
        var name = prompt("New category name:");
        if (!name) return;
        fetch('<%= admin_shop_create_category_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ name: name })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) return alert(result.data.error || "Failed to create category.");
          var cat = result.data.category;
          if (!SHOP_CATEGORIES.some(function(c) { return String(c.id) === String(cat.id); })) {
            SHOP_CATEGORIES.push({ id: cat.id, name: cat.name, key: cat.key, logo_url: cat.logo_url, grant_types: [] });
          }
          selectCategory(cat.id);
        })
        .catch(function(err) { alert("Error creating category."); console.error(err); });
      };
    }

    if (manageCategorySave) {
      manageCategorySave.onclick = function() {
        if (!selectedCategoryId) return;
        setStatus(manageCategoryStatus, 'Saving...');
        fetch('<%= admin_shop_update_category_path(":id") %>'.replace('%3Aid', selectedCategoryId).replace(':id', selectedCategoryId), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({
            name: manageCategoryName ? manageCategoryName.value : '',
            key: manageCategoryKey ? manageCategoryKey.value : '',
            logo_url: manageCategoryLogo ? manageCategoryLogo.value : ''
          })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) {
            setStatus(manageCategoryStatus, (result.data && result.data.error) || 'Failed.', true);
            return;
          }
          var updated = result.data.category;
          var cat = findCategoryById(updated.id);
          if (cat) {
            cat.name = updated.name;
            cat.key = updated.key;
            cat.logo_url = updated.logo_url;
          }
          setStatus(manageCategoryStatus, 'Saved.');
          setLogoPreview(manageCategoryLogoPreview, updated.logo_url);
          renderCategoryList(selectedCategoryId);
          // Keep dropdown in sync on next reload
        })
        .catch(function(err) {
          setStatus(manageCategoryStatus, 'Error.', true);
          console.error(err);
        });
      };
    }

    if (manageAddGrantType) {
      manageAddGrantType.onclick = function() {
        if (!selectedCategoryId) return alert("Pick a category first.");
        var name = prompt("New grant type name:");
        if (!name) return;
        fetch('<%= admin_shop_create_grant_type_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ shop_category_id: selectedCategoryId, name: name })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) return alert(result.data.error || "Failed to create grant type.");
          var gt = result.data.grant_type;
          var cat = findCategoryById(gt.shop_category_id);
          if (cat && !(cat.grant_types || []).some(function(x) { return String(x.id) === String(gt.id); })) {
            cat.grant_types.push({ id: gt.id, name: gt.name, key: gt.key, logo_url: gt.logo_url });
          }
          renderGrantTypeList(cat, gt.id);
          selectGrantType(gt.id);
        })
        .catch(function(err) { alert("Error creating grant type."); console.error(err); });
      };
    }

    if (manageGrantTypeSave) {
      manageGrantTypeSave.onclick = function() {
        if (!selectedCategoryId || !selectedGrantTypeId) return;
        setStatus(manageGrantTypeStatus, 'Saving...');
        fetch('<%= admin_shop_update_grant_type_path(":id") %>'.replace('%3Aid', selectedGrantTypeId).replace(':id', selectedGrantTypeId), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({
            shop_category_id: selectedCategoryId,
            name: manageGrantTypeName ? manageGrantTypeName.value : '',
            key: manageGrantTypeKey ? manageGrantTypeKey.value : '',
            logo_url: manageGrantTypeLogo ? manageGrantTypeLogo.value : ''
          })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) {
            setStatus(manageGrantTypeStatus, (result.data && result.data.error) || 'Failed.', true);
            return;
          }
          var updated = result.data.grant_type;
          var cat = findCategoryById(updated.shop_category_id);
          var gt = findGrantTypeById(cat, updated.id);
          if (gt) {
            gt.name = updated.name;
            gt.key = updated.key;
            gt.logo_url = updated.logo_url;
          }
          setStatus(manageGrantTypeStatus, 'Saved.');
          setLogoPreview(manageGrantTypeLogoPreview, updated.logo_url);
          renderGrantTypeList(cat, selectedGrantTypeId);
        })
        .catch(function(err) {
          setStatus(manageGrantTypeStatus, 'Error.', true);
          console.error(err);
        });
      };
    }

    var editOverlay = document.getElementById('adminEditItemOverlay');
    var editClose = document.getElementById('adminEditItemClose');
    var editCancel = document.getElementById('adminEditItemCancel');
    var editForm = document.getElementById('adminEditItemForm');
    var editId = document.getElementById('adminEditItemId');
    var editName = document.getElementById('adminEditItemName');
    var editPriceUsd = document.getElementById('adminEditItemPriceUsd');
    var editDollarPerHour = document.getElementById('adminEditItemDollarPerHour');
    var editChipsCalculated = document.getElementById('adminEditItemChipsCalculated');
    var editMaxPerPerson = document.getElementById('adminEditItemMaxPerPerson');
    var editCategory = document.getElementById('adminEditCategorySelect');
    var editGrantType = document.getElementById('adminEditGrantTypeSelect');
    var editLink = document.getElementById('adminEditItemLink');
    var editImageUrl = document.getElementById('adminEditItemImageUrl');
    var editDescription = document.getElementById('adminEditItemDescription');
    var editActive = document.getElementById('adminEditItemActive');

    function chipsFromUsd(priceUsd, dollarPerHour) {
      var usd = parseFloat(priceUsd, 10);
      var dph = parseFloat(dollarPerHour, 10);
      if (!Number.isFinite(usd) || !Number.isFinite(dph) || dph <= 0) return null;
      return Math.ceil((usd / dph) * 50);
    }

    function updateAddFormChips() {
      var el = document.getElementById('adminShopChipsCalculated');
      if (!el) return;
      var usd = document.getElementById('adminShopPriceUsd') && document.getElementById('adminShopPriceUsd').value;
      var dph = document.getElementById('adminShopDollarPerHour') && document.getElementById('adminShopDollarPerHour').value;
      var chips = chipsFromUsd(usd, dph);
      el.textContent = chips != null ? chips : '—';
    }

    function updateEditFormChips() {
      if (!editChipsCalculated) return;
      var usd = editPriceUsd && editPriceUsd.value;
      var dph = editDollarPerHour && editDollarPerHour.value;
      var chips = chipsFromUsd(usd, dph);
      editChipsCalculated.textContent = chips != null ? chips : '—';
    }

    function openEditFromRow(row) {
      if (!row || !editOverlay) return;

      var itemId = row.dataset.itemId;
      var name = row.dataset.itemName || "";
      var priceUsd = row.dataset.itemPriceUsd || "";
      var dollarPerHour = row.dataset.itemDollarPerHour || "";
      var maxPerPerson = row.dataset.itemMaxPerPerson || "";
      var link = row.dataset.itemLink || "";
      var imageUrl = row.dataset.itemImageUrl || "";
      var description = row.dataset.itemDescription || "";
      var active = row.dataset.itemActive === "1";
      var categoryId = row.dataset.itemCategoryId || "";
      var grantTypeId = row.dataset.itemGrantTypeId || "";

      if (editId) editId.value = itemId;
      if (editName) editName.value = name;
      if (editPriceUsd) editPriceUsd.value = priceUsd;
      if (editDollarPerHour) editDollarPerHour.value = dollarPerHour;
      if (editMaxPerPerson) editMaxPerPerson.value = maxPerPerson;
      if (editLink) editLink.value = link;
      if (editImageUrl) editImageUrl.value = imageUrl;
      if (editDescription) editDescription.value = description;
      if (editActive) editActive.checked = active;

      if (editCategory && categoryId) editCategory.value = categoryId;
      renderGrantTypeOptionsInto((editCategory && editCategory.value) || categoryId, editGrantType, grantTypeId);

      updateEditFormChips();
      editOverlay.style.display = "flex";
    }

    function closeEditModal() {
      if (!editOverlay) return;
      editOverlay.style.display = "none";
    }

    if (categorySelectEl) {
      renderGrantTypeOptions(categorySelectEl.value);
      categorySelectEl.onchange = function() {
        renderGrantTypeOptions(categorySelectEl.value);
      };
    }

    var addPriceUsd = document.getElementById('adminShopPriceUsd');
    var addDollarPerHour = document.getElementById('adminShopDollarPerHour');
    if (addPriceUsd) addPriceUsd.addEventListener('input', updateAddFormChips);
    if (addDollarPerHour) addDollarPerHour.addEventListener('input', updateAddFormChips);

    if (editPriceUsd) editPriceUsd.addEventListener('input', updateEditFormChips);
    if (editDollarPerHour) editDollarPerHour.addEventListener('input', updateEditFormChips);

    form.onsubmit = function(e) {
      e.preventDefault();
      var formData = new FormData(form);
      var data = {};
      formData.forEach(function(v, k) { data[k] = v; });
      delete data.shop_category_id;

      // Require grant type for all items EXCEPT the pinned invitation.
      if (!isPinnedItemName(data.name) && (!data.shop_grant_type_id || String(data.shop_grant_type_id).trim() === "")) {
        return alert("Pick a grant type (unless this is the pinned invitation item).");
      }

      fetch('<%= admin_shop_create_item_path %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) { location.reload(); }
        else { alert(d.error || 'Failed to create item.'); }
      })
      .catch(function(err) { alert('Error creating item.'); console.error(err); });
    };

    if (editCategory) {
      editCategory.onchange = function() {
        renderGrantTypeOptionsInto(editCategory.value, editGrantType);
      };
    }

    if (editClose) editClose.onclick = closeEditModal;
    if (editCancel) editCancel.onclick = closeEditModal;
    if (editOverlay) {
      editOverlay.onclick = function(e) {
        if (e.target === editOverlay) closeEditModal();
      };
    }

    if (editForm) {
      editForm.onsubmit = function(e) {
        e.preventDefault();
        if (!editId || !editId.value) return;
        var id = editId.value;

        var payload = {
          name: editName ? editName.value : "",
          price_usd: editPriceUsd ? editPriceUsd.value : "",
          dollar_per_hour: editDollarPerHour ? editDollarPerHour.value : "",
          max_per_person: editMaxPerPerson ? editMaxPerPerson.value : "",
          item_link: editLink ? editLink.value : "",
          image_url: editImageUrl ? editImageUrl.value : "",
          description: editDescription ? editDescription.value : "",
          active: !!(editActive && editActive.checked),
          shop_grant_type_id: editGrantType ? editGrantType.value : ""
        };

        if (!isPinnedItemName(payload.name) && (!payload.shop_grant_type_id || String(payload.shop_grant_type_id).trim() === "")) {
          return alert("Pick a grant type (unless this is the pinned invitation item).");
        }

        var saveBtn = document.getElementById('adminEditItemSave');
        if (saveBtn) {
          saveBtn.disabled = true;
          saveBtn.textContent = "Saving...";
        }

        fetch('<%= admin_shop_update_item_path(":id") %>'.replace('%3Aid', id).replace(':id', id), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (result.ok && result.data.success) {
            closeEditModal();
            location.reload();
          } else {
            alert((result.data && result.data.error) || "Failed to update item.");
          }
        })
        .catch(function(err) {
          alert("Error updating item.");
          console.error(err);
        })
        .finally(function() {
          if (saveBtn) {
            saveBtn.disabled = false;
            saveBtn.textContent = "Save changes";
          }
        });
      };
    }

    document.querySelectorAll('.adminShopModifyBtn').forEach(function(btn) {
      btn.onclick = function() {
        var id = btn.getAttribute('data-item-id');
        var row = document.getElementById('item-row-' + id);
        openEditFromRow(row);
      };
    });

    if (addCategoryBtn) {
      addCategoryBtn.onclick = function() {
        var name = prompt("New category name:");
        if (!name) return;
        fetch('<%= admin_shop_create_category_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ name: name })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) return alert(result.data.error || "Failed to create category.");
          var cat = result.data.category;
          if (!SHOP_CATEGORIES.some(function(c) { return String(c.id) === String(cat.id); })) {
            SHOP_CATEGORIES.push({ id: cat.id, name: cat.name, key: cat.key, logo_url: cat.logo_url, grant_types: [] });
          }
          if (categorySelectEl) {
            var opt = document.createElement('option');
            opt.value = String(cat.id);
            opt.textContent = cat.name;
            categorySelectEl.appendChild(opt);
            categorySelectEl.value = String(cat.id);
            renderGrantTypeOptions(categorySelectEl.value);
          } else {
            location.reload();
          }
        })
        .catch(function(err) { alert("Error creating category."); console.error(err); });
      };
    }

    if (addGrantTypeBtn) {
      addGrantTypeBtn.onclick = function() {
        if (!categorySelectEl || !categorySelectEl.value) return alert("Pick a category first.");
        var name = prompt("New grant type name:");
        if (!name) return;
        fetch('<%= admin_shop_create_grant_type_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ shop_category_id: categorySelectEl.value, name: name })
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) return alert(result.data.error || "Failed to create grant type.");
          var gt = result.data.grant_type;
          var cat = SHOP_CATEGORIES.find(function(c) { return String(c.id) === String(gt.shop_category_id); });
          if (cat && !(cat.grant_types || []).some(function(x) { return String(x.id) === String(gt.id); })) {
            cat.grant_types.push({ id: gt.id, name: gt.name, key: gt.key, logo_url: gt.logo_url });
          }
          renderGrantTypeOptions(categorySelectEl.value, gt.id);
        })
        .catch(function(err) { alert("Error creating grant type."); console.error(err); });
      };
    }

    // Items table: show/hide deactivated + sorting
    var itemsTbody = document.getElementById('adminShopItemsTbody');
    var showDeactivatedCheckbox = document.getElementById('adminShopShowDeactivated');
    var itemsSearchInput = document.getElementById('adminShopItemsSearch');
    var itemsCountEl = document.getElementById('adminShopItemsCount');
    var itemSortKey = 'id';
    var itemSortDir = 'desc';
    var numericKeys = { id: true, price: true, max_per_person: true, active: true };

    function getItemSortValue(row, key) {
      var val;
      if (key === 'max_per_person') val = row.getAttribute('data-item-max-num');
      else val = row.getAttribute('data-item-' + key);
      if (numericKeys[key]) {
        var n = parseFloat(val, 10);
        return Number.isFinite(n) ? n : (key === 'id' ? 0 : -1);
      }
      return (val || '').toString().toLowerCase();
    }

    function applyItemsSort() {
      if (!itemsTbody) return;
      var rows = Array.prototype.slice.call(itemsTbody.querySelectorAll('tr.admin-shop-item-row'));
      var isNum = numericKeys[itemSortKey];
      rows.sort(function(a, b) {
        var va = getItemSortValue(a, itemSortKey);
        var vb = getItemSortValue(b, itemSortKey);
        var cmp = 0;
        if (isNum) cmp = va < vb ? -1 : (va > vb ? 1 : 0);
        else cmp = (va || '').localeCompare(vb || '');
        return itemSortDir === 'asc' ? cmp : -cmp;
      });
      rows.forEach(function(r) { itemsTbody.appendChild(r); });
      document.querySelectorAll('#adminShopItemsTable .admin-shop-sort-arrow').forEach(function(span) { span.textContent = ''; });
      var activeTh = document.querySelector('#adminShopItemsTable .admin-shop-sortable-th[data-sort-key="' + itemSortKey + '"]');
      if (activeTh) {
        var arrow = activeTh.querySelector('.admin-shop-sort-arrow');
        if (arrow) arrow.textContent = itemSortDir === 'asc' ? ' ▲' : ' ▼';
      }
    }

    function rowMatchesSearch(row, q) {
      if (!q || (q = q.trim().toLowerCase()) === '') return true;
      var name = (row.getAttribute('data-item-name') || '').toLowerCase();
      var category = (row.getAttribute('data-item-category-name') || '').toLowerCase();
      var grantType = (row.getAttribute('data-item-grant-type-name') || '').toLowerCase();
      var description = (row.getAttribute('data-item-description') || '').toLowerCase();
      var id = (row.getAttribute('data-item-id') || '').toString();
      return name.indexOf(q) !== -1 || category.indexOf(q) !== -1 || grantType.indexOf(q) !== -1 || description.indexOf(q) !== -1 || id.indexOf(q) !== -1;
    }

    function applyItemsFilters() {
      if (!itemsTbody || !showDeactivatedCheckbox) return;
      var showDeactivated = showDeactivatedCheckbox.checked;
      var searchQ = itemsSearchInput ? itemsSearchInput.value : '';
      var visible = 0;
      itemsTbody.querySelectorAll('tr.admin-shop-item-row').forEach(function(row) {
        var active = row.getAttribute('data-item-active') === '1';
        var matchesSearch = rowMatchesSearch(row, searchQ);
        var hideByDeactivated = !active && !showDeactivated;
        if (!matchesSearch || hideByDeactivated) {
          row.style.display = 'none';
        } else {
          row.style.display = '';
          visible++;
        }
      });
      if (itemsCountEl) itemsCountEl.textContent = visible;
    }

    if (showDeactivatedCheckbox) {
      showDeactivatedCheckbox.addEventListener('change', applyItemsFilters);
    }
    if (itemsSearchInput) {
      itemsSearchInput.addEventListener('input', applyItemsFilters);
    }
    applyItemsFilters();

    document.querySelectorAll('#adminShopItemsTable .admin-shop-sortable-th').forEach(function(th) {
      th.addEventListener('click', function() {
        var key = th.getAttribute('data-sort-key');
        if (!key) return;
        if (itemSortKey === key) itemSortDir = itemSortDir === 'asc' ? 'desc' : 'asc';
        else { itemSortKey = key; itemSortDir = 'asc'; }
        applyItemsSort();
      });
    });
    applyItemsSort();
  });
})();

function toggleItem(id, active) {
  fetch('<%= admin_shop_update_item_path(":id") %>'.replace('%3Aid', id).replace(':id', id), {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
    body: JSON.stringify({ active: active })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) { if (d.success) location.reload(); else alert(d.error); })
  .catch(function(e) { alert('Error.'); console.error(e); });
}

function updateOrderStatus(id, status) {
  fetch('<%= admin_shop_update_order_path(":id") %>'.replace('%3Aid', id).replace(':id', id), {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
    body: JSON.stringify({ status: status })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) { if (d.success) location.reload(); else alert(d.error); })
  .catch(function(e) { alert('Error.'); console.error(e); });
}
</script>
