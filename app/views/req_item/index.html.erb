<% content_for(:title) { "Request Item" } %>

<div class="req-item-page" role="main" aria-label="Request Item">
  <% if @show_req_item_form %>
  <div class="req-item-content">
    <header class="req-item-header">
      <%= image_tag "req_items/title.png", alt: "Jackpot Exchange Desk", class: "req-item-title-img" %>
    </header>

    <div class="req-item-three-col">
      <!-- Left: steps_block.png asset -->
      <section class="req-item-how-section" aria-label="How it works">
        <%= image_tag "req_items/steps_block.png", alt: "Step up and talk to our dealer. Here's how it works: 1. Check the current request list →. 2. Fill out the form. 3. Wait for the shop refresh. 4. Earn your prize. Attention: one item every 2 weeks.", class: "req-item-steps-block-img" %>
      </section>

      <!-- Center: This week's requests (small boxes with name + price) -->
      <section class="req-item-week-section req-item-week-panel" aria-label="This week's requests">
        <h2 class="req-item-week-heading">This week's requests:</h2>
        <div class="req-item-week-content">
          <% if @this_week_requests.any? %>
            <ul class="req-item-week-list">
              <% @this_week_requests.each do |request| %>
                <li class="req-item-week-item">
                  <span class="req-item-week-item-name"><%= request.item_name %></span>
                  <span class="req-item-week-item-price"><%= number_to_currency(request.price, precision: 2) %></span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="req-item-week-empty">No requests this week yet.</p>
          <% end %>
        </div>
      </section>

      <!-- Right: countdown + cards.png form block -->
      <div class="req-item-form-column">
        <% if flash[:notice].present? %>
          <div class="req-item-flash req-item-flash--success" role="alert"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="req-item-flash req-item-flash--error" role="alert"><%= flash[:alert] %></div>
        <% end %>

        <div class="req-item-upgrade-countdown" aria-live="polite">
          Next shop upgrade: <span id="reqItemUpgradeCountdown">--:--:--</span>
        </div>

        <div class="req-item-form-on-cards">
          <%= image_tag "req_items/cards.png", alt: "", class: "req-item-form-cards-bg" %>
          <div class="req-item-form-overlay">
            <div class="req-item-form-clock">
              <%= image_tag "req_items/clockIMG.png", alt: "", class: "req-item-clock-img" %>
            </div>
            <% if @can_submit %>
              <%= form_with model: @shop_item_request, url: req_item_path, method: :post, local: true, class: "req-item-form" do |f| %>
                <% if @shop_item_request.errors.any? %>
                  <div class="req-item-errors" role="alert">
                    <ul>
                      <% @shop_item_request.errors.full_messages.each do |msg| %>
                        <li><%= msg %></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <div class="req-item-field">
                  <%= f.label :item_name, "Item name:" %>
                  <%= f.text_field :item_name, class: "req-item-input", placeholder: "Eg. Arduino Uno R4", required: true, autocomplete: "off" %>
                </div>

                <div class="req-item-field">
                  <%= f.label :price, "Item price (USD):" %>
                  <div class="req-item-price-wrap">
                    <span class="req-item-price-prefix">$</span>
                    <%= f.number_field :price, class: "req-item-input req-item-input-price", placeholder: "Eg. 20.99", min: 0, step: 0.01, required: true %>
                  </div>
                </div>

                <div class="req-item-field">
                  <%= f.label :reference_link, "Reference Link (Eg. Amazon):" %>
                  <%= f.url_field :reference_link, class: "req-item-input", placeholder: "https://...", required: true %>
                </div>

                <div class="req-item-actions">
                  <button type="submit" class="req-item-submit-btn" aria-label="Submit Request">
                    <%= image_tag "req_items/button.png", alt: "Submit Request", class: "req-item-submit-btn-img" %>
                  </button>
                </div>
              <% end %>
            <% else %>
              <div class="req-item-blocked" role="status">
                <p>You've already submitted a request recently. You can request one item every 2 weeks.</p>
                <% if @next_allowed_on.present? %>
                  <p>Your next request is allowed on <strong><%= @next_allowed_on.strftime('%A, %B %-d') %></strong>.</p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
  (function() {
    var el = document.getElementById('reqItemUpgradeCountdown');
    if (!el) return;
    function tzParts(date, timeZone) {
      var dtf = new Intl.DateTimeFormat('en-US', {
        timeZone: timeZone,
        hour12: false,
        weekday: 'short',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
      var parts = dtf.formatToParts(date);
      var out = {};
      parts.forEach(function(p) { if (p.type !== 'literal') out[p.type] = p.value; });
      return out;
    }
    function tzOffsetMs(date, timeZone) {
      var p = tzParts(date, timeZone);
      var asUtc = Date.UTC(
        parseInt(p.year, 10),
        parseInt(p.month, 10) - 1,
        parseInt(p.day, 10),
        parseInt(p.hour, 10),
        parseInt(p.minute, 10),
        parseInt(p.second, 10)
      );
      return asUtc - date.getTime();
    }
    function zonedTimeToUtcMs(ymdhms, timeZone) {
      var utcGuess = Date.UTC(ymdhms.year, ymdhms.month - 1, ymdhms.day, ymdhms.hour, ymdhms.minute, ymdhms.second);
      var d1 = new Date(utcGuess);
      var off1 = tzOffsetMs(d1, timeZone);
      var utc1 = utcGuess - off1;
      var d2 = new Date(utc1);
      var off2 = tzOffsetMs(d2, timeZone);
      return utcGuess - off2;
    }
    function nextFridayMidnightUtcMs(now) {
      var tz = 'America/New_York';
      var p = tzParts(now, tz);
      var weekdayMap = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
      var dow = weekdayMap[p.weekday] == null ? 0 : weekdayMap[p.weekday];
      var hour = parseInt(p.hour, 10);
      var minute = parseInt(p.minute, 10);
      var second = parseInt(p.second, 10);
      var days = (5 - dow + 7) % 7;
      if (days === 0 && (hour > 0 || minute > 0 || second > 0)) days = 7;
      var baseNoonUtc = zonedTimeToUtcMs({
        year: parseInt(p.year, 10),
        month: parseInt(p.month, 10),
        day: parseInt(p.day, 10),
        hour: 12, minute: 0, second: 0
      }, tz);
      var fridayNoonUtc = baseNoonUtc + (days * 86400000);
      var fri = tzParts(new Date(fridayNoonUtc), tz);
      return zonedTimeToUtcMs({
        year: parseInt(fri.year, 10),
        month: parseInt(fri.month, 10),
        day: parseInt(fri.day, 10),
        hour: 0, minute: 0, second: 0
      }, tz);
    }
    function pad2(n) { return String(n).padStart(2, '0'); }
    function render() {
      var now = new Date();
      var target = nextFridayMidnightUtcMs(now);
      var ms = target - now.getTime();
      if (ms < 0) ms = 0;
      var totalSeconds = Math.floor(ms / 1000);
      var hours = Math.floor(totalSeconds / 3600);
      var minutes = Math.floor((totalSeconds % 3600) / 60);
      var seconds = totalSeconds % 60;
      el.textContent = pad2(hours) + ':' + pad2(minutes) + ':' + pad2(seconds);
    }
    render();
    var iv = setInterval(render, 1000);
  })();
  </script>
  <% else %>
  <div class="req-item-coming-soon-wrap">
    <div class="req-item-coming-soon" aria-label="Coming Soon">Coming Soon!</div>
  </div>
  <% end %>
</div>
