<% content_for(:title) { "Request Item" } %>

<div class="req-item-page" role="main" aria-label="Request Item">
  <% if @show_req_item_form %>
  <div class="req-item-content">
    <header class="req-item-header">
      <h1 class="req-item-title">Welcome to the Jackpot Exchange Desk</h1>
      <p class="req-item-intro">Step up and talk to our dealer.</p>
      <p class="req-item-how">Here's how it works:</p>
      <ol class="req-item-steps">
        <li>Fill out the form with the item you want added to the <%= link_to "shop", shop_path, class: "req-item-link" %>. (please be specific, or your item might be canceled!)</li>
        <li>Wait for the shop refresh (check the <%= link_to "countdown", shop_path, class: "req-item-link" %>, it's every Friday!)</li>
        <li>Earn your prize!!</li>
      </ol>
      <p class="req-item-attention">
        <strong>ATTENTION!</strong> You can request one item every 2 weeks, so choose wisely.<br>
        <span class="req-item-warning"><u><strong>Once the form is submitted, it cannot be edited or canceled.</strong></u></span>
      </p>
    </header>

    <% if flash[:notice].present? %>
      <div class="req-item-flash req-item-flash--success" role="alert"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert].present? %>
      <div class="req-item-flash req-item-flash--error" role="alert"><%= flash[:alert] %></div>
    <% end %>

    <% if @can_submit %>
      <%= form_with model: @shop_item_request, url: req_item_path, method: :post, local: true, class: "req-item-form" do |f| %>
        <% if @shop_item_request.errors.any? %>
          <div class="req-item-errors" role="alert">
            <ul>
              <% @shop_item_request.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="req-item-field">
          <%= f.label :item_name, "Item name:" %>
          <%= f.text_field :item_name, class: "req-item-input", placeholder: "e.g. Arduino Starter Kit", required: true, autocomplete: "off" %>
        </div>

        <div class="req-item-field">
          <%= f.label :price, "Item $$ price:" %>
          <%= f.number_field :price, class: "req-item-input", placeholder: "e.g. 24.99", min: 0, step: 0.01, required: true %>
        </div>

        <div class="req-item-field">
          <%= f.label :reference_link, "Reference link (e.g. buying page like Amazon):" %>
          <%= f.url_field :reference_link, class: "req-item-input", placeholder: "https://...", required: true %>
        </div>

        <div class="req-item-actions">
          <%= f.submit "Submit request", class: "req-item-submit" %>
        </div>
      <% end %>
    <% else %>
      <div class="req-item-blocked" role="status">
        <p>You've already submitted a request recently. You can request one item every 2 weeks.</p>
        <% if @next_allowed_on.present? %>
          <p>Your next request is allowed on <strong><%= @next_allowed_on.strftime('%A, %B %-d') %></strong>.</p>
        <% end %>
      </div>
    <% end %>

    <section class="req-item-week-section" aria-label="This week's requests">
      <h2 class="req-item-week-heading">This week's requests</h2>
      <% if @this_week_item_names.any? %>
        <ul class="req-item-week-list">
          <% @this_week_item_names.each do |name| %>
            <li><%= name %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="req-item-week-empty">No requests this week yet.</p>
      <% end %>
    </section>
  </div>
  <% else %>
  <div class="req-item-coming-soon-wrap">
    <div class="req-item-coming-soon" aria-label="Coming Soon">Coming Soon!</div>
  </div>
  <% end %>
</div>
