# Copy to `.env` and fill in. Comma-separated emails (spaces around commas are fine).

# Optional: only if you want the OLD dev behavior (every signed-in user on localhost = admin + reviewer).
# Leave unset to use real roles from the database (recommended).
# JACKPOT_LOCALHOST_STAFF_BYPASS=true

# --- Staff roles (run `bin/rails jackpot:sync_roles_from_env` after changing) ---
# Highest role wins if the same email appears in more than one list.
#
# JACKPOT_REVIEWER_EMAILS=reviewer1@example.com
# JACKPOT_ADMIN_EMAILS=admin@example.com
# JACKPOT_SUPER_ADMIN_EMAILS=
